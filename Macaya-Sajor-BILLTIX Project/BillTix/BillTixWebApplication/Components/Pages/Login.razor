@page "/login"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager _Nav
@using Domain.ICommands
@using BillTixWebApplication.Components.Layout
@inject ILoginUser _loginUser
@inject ICreate_User _create
@using Microsoft.AspNetCore.WebUtilities;
<PageTitle>Login</PageTitle>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', sans-serif; }

    .login-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        background: white;
        border-radius: 16px;
        padding: 40px 36px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }

    .login-card h2 {
        font-size: 1.6rem;
        font-weight: 800;
        margin-bottom: 4px;
        color: #111;
    }

    .login-card .role-badge {
        display: inline-block;
        background: #ede9fe;
        color: #4f46e5;
        font-size: 0.78rem;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 24px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: #444;
        margin-bottom: 6px;
    }

    .form-group input {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 0.95rem;
        outline: none;
        transition: border 0.2s;
    }

    .form-group input:focus { border-color: #4f46e5; }

    .error { color: #ef4444; font-size: 0.85rem; margin-bottom: 12px; }

    .btn-submit {
        width: 100%;
        padding: 12px;
        background: #4f46e5;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.2s;
    }

    .btn-submit:hover { background: #3730a3; }

    .back-link {
        display: block;
        text-align: center;
        margin-top: 16px;
        font-size: 0.85rem;
        color: #4f46e5;
        cursor: pointer;
        text-decoration: underline;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <h2>Login</h2>
        <span class="role-badge">@(ExpectedRole ?? "User") Portal</span>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <p class="error">@errorMessage</p>
        }

        <div class="form-group">
            <label>Username</label>
            <input placeholder="Enter username" @bind="username" />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" placeholder="Enter password" @bind="password" />
        </div>

        <button class="btn-submit" @onclick="HandleLogin">Login</button>
        <span class="back-link" @onclick='() => _Nav.NavigateTo("/")'>← Back to Home</span>
    </div>
</div>

@code {
    private string? ExpectedRole { get; set; }

    private string username = "";
    private string password = "";
    private string errorMessage = "";

    protected override void OnInitialized()
    {
        var uri = new Uri(_Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        ExpectedRole = query["role"];
    }

    private async Task HandleLogin()
    {
        var user = await _loginUser.LoginAsync(username, password);

        if (user == null)
        {
            errorMessage = "Invalid username or password.";
            return;
        }

        // Check if role matches the expected role
        if (!string.IsNullOrEmpty(ExpectedRole) && user.Role != ExpectedRole)
        {
            errorMessage = $"Access denied. This portal is for {ExpectedRole} only.";
            return;
        }

        if (user.Role == "Admin")
            _Nav.NavigateTo("/admindashboard");
        else if (user.Role == "Subscriber")
            _Nav.NavigateTo("/subcriberdashboard");
        else if (user.Role == "Technician")
            _Nav.NavigateTo("/technicaldashboard");
        else if (user.Role == "Staff")
            _Nav.NavigateTo("/staffdashboard");
        else
            _Nav.NavigateTo("/");
    }
}
