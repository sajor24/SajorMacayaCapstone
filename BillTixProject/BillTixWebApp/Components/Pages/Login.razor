@page "/login"
@rendermode InteractiveServer
@inject NavigationManager _Nav
@using BillTixWebApp.Components.Layout
@layout EmptyLayout

<PageTitle>Login - BillTix</PageTitle>

<div class="page">
    <div class="bg-layer"></div>
    <div class="mesh mesh-1"></div>
    <div class="mesh mesh-2"></div>

    <div class="card">
        <div class="brand">BILLTIX</div>
        <div class="subtitle">@roleLabel Portal</div>

        @if (error == 1)
        {
            <div class="alert">Invalid username or password.</div>
        }
        else if (error == 2)
        {
            <div class="alert">Invalid username or password</div>
        }

        <form method="post" action="/account/login">
            <AntiforgeryToken />
            <input type="hidden" name="returnRole" value="@ExpectedRole" />

            <div class="field">
                <label>Username</label>
                <input name="username" placeholder="Enter your username" autocomplete="username" />
            </div>

            <div class="field">
                <label>Password</label>
                <div class="password-wrap">
                    <input name="password"
                           type="@(showPassword ? "text" : "password")"
                           placeholder="Enter your password"
                           autocomplete="current-password" />

                    <button type="button"
                            class="toggle-pass"
                            @onclick="TogglePassword"
                            aria-label="Toggle password visibility"
                            title="Show/Hide password">
                        @if (showPassword)
                        {
                            <!-- Eye Off SVG -->
                            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                                <path d="M3 3l18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                                <path d="M10.6 10.6a2 2 0 0 0 2.8 2.8" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
                                <path d="M9.9 5.1A10.9 10.9 0 0 1 12 5c5 0 8.7 3.1 10 7-0.5 1.6-1.5 3-2.8 4.1M6.1 6.1C4.2 7.4 2.8 9.3 2 12c1.3 3.9 5 7 10 7 1.7 0 3.2-.4 4.6-1.1"
                                      stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" />
                            </svg>
                        }
                        else
                        {
                            <!-- Eye SVG -->
                            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" fill="none" stroke="currentColor" stroke-width="2" />
                                <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2" />
                            </svg>
                        }
                    </button>
                </div>
            </div>

            <button type="submit" class="btn">Login</button>
        </form>

        <a href="/" class="back">← Back to Home</a>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? role { get; set; }
    [SupplyParameterFromQuery] private int error { get; set; }

    // add this so we can preserve role on failed redirects
    [SupplyParameterFromQuery(Name = "returnRole")]
    private string? returnRole { get; set; }

    private bool showPassword = false;
    private void TogglePassword() => showPassword = !showPassword;

    // priority: role -> returnRole -> Subscriber
    private string ExpectedRole => NormalizeRole(role) ?? NormalizeRole(returnRole) ?? "Subscriber";
    private string roleLabel => ExpectedRole;

    private static string? NormalizeRole(string? value)
    {
        return value?.Trim().ToLower() switch
        {
            "subscriber" => "Subscriber",
            "staff" => "Staff",
            "admin" or "administrator" => "Admin",
            "technician" => "Technician",
            _ => null
        };
    }
}


