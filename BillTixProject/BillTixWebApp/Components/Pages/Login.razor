@page "/login"
@rendermode InteractiveServer
@inject NavigationManager _Nav
@using BillTixWebApp.Components.Layout
@layout EmptyLayout

<PageTitle>Login - BillTix</PageTitle>


<div class="login-bg">
    <!-- Animated background blobs -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <div class="glass-card">
        <div class="glass-icon-bg">
            <div class="glass-icon">🔐</div>
        </div>

        <div class="glass-title">BillTix</div>
        <div class="role-badge">✦ @roleLabel Portal ✦</div>

        @if (error == 1)
        {
            <div class="error">⚠ Invalid username or password.</div>
        }
        else if (error == 2)
        {
            <div class="error">⚠ Access denied. This portal is for @roleLabel only.</div>
        }

        <form method="post" action="/account/login">
            <AntiforgeryToken />
            <input type="hidden" name="returnRole" value="@ExpectedRole" />

            <div class="form-group">
                <label>Username</label>
                <input name="username" placeholder="Enter your username" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input name="password" type="password" placeholder="Enter your password" />
            </div>

            <button type="submit" class="btn-submit">Login →</button>
        </form>

        <div class="divider">or</div>
        <a href="/" class="back-link">← Back to Home</a>
    </div>
</div>


@code {
    [SupplyParameterFromQuery]
    private string? role { get; set; }

    [SupplyParameterFromQuery]
    private int error { get; set; }

    private string? ExpectedRole => role;
    private string roleLabel => role ?? "User";
}
<style>
html, body {
    height: 100%;
    min-height: 100vh;
    margin: 0;
    padding: 0;
}

body {
    background: #0f0e17;
}

.login-bg {
    min-height: 100vh;
    width: 100vw;
    background: radial-gradient(ellipse at 60% 40%, #1a1040 0%, #0f0e17 70%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

/* Animated blobs */
.blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.18;
    animation: blobMove 8s ease-in-out infinite alternate;
}
.blob-1 {
    width: 420px; height: 420px;
    background: #7367f0;
    top: -80px; left: -100px;
    animation-delay: 0s;
}
.blob-2 {
    width: 320px; height: 320px;
    background: #28c76f;
    bottom: -60px; right: -80px;
    animation-delay: 2s;
}
.blob-3 {
    width: 200px; height: 200px;
    background: #00cfe8;
    top: 40%; left: 60%;
    animation-delay: 4s;
}

@@keyframes blobMove {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.15) translate(30px, 20px); }
}

.glass-card {
    background: rgba(18, 17, 32, 0.75);
    border-radius: 28px;
    box-shadow: 0 24px 64px 0 rgba(0,0,0,0.45),
                0 2px 12px rgba(115,103,240,0.10),
                inset 0 1px 0 rgba(255,255,255,0.06);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1.5px solid rgba(115,103,240,0.18);
    padding: 64px 40px 38px 40px;
    max-width: 420px;
    min-width: 320px;
    width: 100%;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
}

/* Glow ring around card */
.glass-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(115,103,240,0.3), transparent 50%, rgba(40,199,111,0.2));
    z-index: -1;
    pointer-events: none;
}

.glass-icon-bg {
    position: absolute;
    top: -52px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
}

.glass-icon {
    background: linear-gradient(135deg, #7367f0 40%, #28c76f 100%);
    color: #fff;
    border-radius: 50%;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.4rem;
    box-shadow: 0 8px 32px rgba(115,103,240,0.45),
                0 0 0 6px rgba(18,17,32,0.85);
    animation: floatY 3.5s ease-in-out infinite;
}

@@keyframes floatY {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-12px); }
}

.glass-title {
    margin-top: 28px;
    margin-bottom: 4px;
    font-size: 2.2rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: 1px;
    text-align: center;
    text-shadow: 0 0 40px rgba(115,103,240,0.4);
}

.role-badge {
    background: linear-gradient(90deg, rgba(115,103,240,0.18), rgba(40,199,111,0.12));
    color: #a89ff7;
    border: 1px solid rgba(115,103,240,0.3);
    padding: 5px 16px;
    font-size: 0.88rem;
    border-radius: 24px;
    font-weight: 600;
    margin-bottom: 28px;
    margin-top: 6px;
    letter-spacing: 0.5px;
}

.glass-card form {
    width: 100%;
}

.form-group {
    margin-bottom: 18px;
}

.form-group label {
    display: block;
    font-size: 0.88rem;
    font-weight: 700;
    color: #9e97e8;
    margin-bottom: 8px;
    letter-spacing: .5px;
    text-transform: uppercase;
}

.form-group input {
    width: 100%;
    padding: 14px 18px;
    border-radius: 12px;
    font-size: 1rem;
    background: rgba(255,255,255,0.05);
    color: #e7e7ff;
    border: 1.5px solid rgba(115,103,240,0.2);
    outline: none;
    transition: border 0.2s, background 0.2s, box-shadow 0.2s;
}

.form-group input::placeholder {
    color: rgba(180,175,240,0.35);
}

.form-group input:focus {
    border-color: #7367f0;
    background: rgba(115,103,240,0.08);
    box-shadow: 0 0 0 3px rgba(115,103,240,0.15);
}

.error {
    width: 100%;
    color: #ff8080;
    font-size: 0.92rem;
    margin-bottom: 14px;
    background: rgba(255,80,80,0.08);
    padding: 11px 16px;
    border-radius: 10px;
    font-weight: 600;
    border: 1px solid rgba(255,80,80,0.15);
}

.btn-submit {
    width: 100%;
    padding: 14px;
    background: linear-gradient(110deg, #7367f0 60%, #28c76f 100%);
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 1.08rem;
    font-weight: 700;
    cursor: pointer;
    margin-top: 8px;
    letter-spacing: 0.8px;
    box-shadow: 0 4px 24px rgba(115,103,240,0.35);
    transition: transform 0.15s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(115,103,240,0.5);
}

.btn-submit:active {
    transform: translateY(0);
}

.divider {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 18px 0 4px 0;
    color: rgba(180,175,240,0.3);
    font-size: 0.82rem;
}

.divider::before,
.divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(115,103,240,0.15);
}

.back-link {
    display: block;
    text-align: center;
    margin-top: 18px;
    font-size: 0.92rem;
    color: #7367f0;
    cursor: pointer;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: color 0.15s;
}

.back-link:hover {
    color: #28c76f;
}

@@media (max-width: 500px) {
    .glass-card {
        padding: 56px 5vw 28px 5vw;
        min-width: 0;
        max-width: 97vw;
        border-radius: 20px;
    }
    .glass-title { font-size: 1.6rem; }
}
</style>
