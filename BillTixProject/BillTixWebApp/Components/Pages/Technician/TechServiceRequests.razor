@page "/tech-service-requests"
@layout TechnicianLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@using BillTixWebApp.Components.Layout
@attribute [Authorize(Roles = "Technician")]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_ServiceRequest getAllRequests
@inject IUpdate_ServiceRequest updateRequest
@inject IGetAll_User getUsers
@inject IUpdateCompletedJobs_User updateCompletedJobs

<PageTitle>My Tickets - BillTix</PageTitle>

<div class="tickets-page">

    <div class="page-header">
        <h2>My Tickets</h2>
        <p>View and manage your assigned service requests</p>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") mx-4 mb-0">
            @message
            <button class="btn-close float-end" @onclick="() => message = string.Empty"></button>
        </div>
    }

    <!-- Stat Cards -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">My Tickets</div>
                <div class="stat-value">@requests.Count</div>
            </div>
            <div class="stat-icon icon-blue">
                <i class="bi bi-calendar2-check"></i>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">Completed Today</div>
                <div class="stat-value">@completedToday</div>
            </div>
            <div class="stat-icon icon-green">
                <i class="bi bi-check-circle"></i>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">In Progress</div>
                <div class="stat-value">@inProgressCount</div>
            </div>
            <div class="stat-icon icon-yellow">
                <i class="bi bi-clock"></i>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">Pending</div>
                <div class="stat-value">@pendingCount</div>
            </div>
            <div class="stat-icon icon-orange">
                <i class="bi bi-clock-history"></i>
            </div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="d-flex align-items-center gap-1">
            <span class="text-muted" style="font-size:.82rem; white-space:nowrap;">Resolved on:</span>
            <input type="date" class="form-control form-control-sm" style="width:150px;"
                   @bind="filterDate" @bind:event="oninput" />
            @if (filterDate.HasValue)
            {
                <button class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"
                        @onclick="() => filterDate = null" title="Clear">
                    <i class="bi bi-x"></i>
                </button>
            }
        </div>
        <div class="d-flex gap-2 align-items-center">
            <select class="form-select form-select-sm" style="width:150px;" @bind="searchField">
                <option value="all">All Fields</option>
                <option value="id">Request ID</option>
                <option value="name">Subscriber</option>
                <option value="issue">Issue Type</option>
                <option value="address">Address</option>
                <option value="status">Status</option>
            </select>
            <div class="tech-search-box">
                <i class="bi bi-search text-muted"></i>
                <input placeholder="Search..." @bind="searchText" @bind:event="oninput" />
            </div>
        </div>
    </div>

    <!-- Ticket Cards -->
    <div class="tickets-list">
        @if (!filteredRequests.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No tickets found.</p>
            </div>
        }
        @foreach (var ticket in filteredRequests)
        {
            <div class="ticket-card">
                <div class="ticket-top">
                    <div class="ticket-icon-wrap">
                        <i class="bi bi-tools"></i>
                    </div>
                    <div class="ticket-meta">
                        <div class="ticket-title-row">
                            <span class="ticket-id">@ticket.RequestId</span>
                            <span class="badge-status @GetStatusClass(ticket.Status)">@ticket.Status</span>
                        </div>
                        <div class="ticket-issue">@ticket.IssueType</div>
                        <div class="ticket-assigned">Assigned to: @(ticket.AssignedTo ?? "Unassigned")</div>
                    </div>
                </div>

                <div class="ticket-details">
                    <div class="detail-left">
                        <div class="detail-item">
                            <i class="bi bi-person"></i>
                            <span>Customer: <strong>@ticket.FirstName @ticket.LastName</strong></span>
                        </div>
                        <div class="detail-item">
                            <i class="bi bi-telephone"></i>
                            <span>Phone: <strong>@(ticket.ContactNumber ?? "—")</strong></span>
                        </div>
                        <div class="detail-item">
                            <i class="bi bi-geo-alt"></i>
                            <span>Address: <strong>@(ticket.Address ?? "—")</strong></span>
                        </div>

                    </div>
                    <div class="detail-right">
                        <div class="detail-item">
                            <i class="bi bi-calendar3"></i>
                            <span>Created: <strong>@ticket.CreatedAt.ToString("MMM dd, yyyy")</strong></span>
                        </div>
                        @if (ticket.ResolvedAt.HasValue)
                        {
                            <div class="detail-item">
                                <i class="bi bi-check2-circle"></i>
                                <span>Resolved: <strong>@ticket.ResolvedAt.Value.ToString("MMM dd, yyyy")</strong></span>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ticket.Description))
                {
                    <div class="ticket-notes">
                        <div class="notes-label">📋 Description</div>
                        <div class="notes-text">@ticket.Description</div>
                    </div>
                }

                <div class="ticket-actions">
                    @if (ticket.Status != "Resolved")
                    {
                        @if (ticket.Status == "Open" || ticket.Status == "Pending")
                        {
                            <button class="btn-inprogress" @onclick="() => MarkInProgress(ticket)">
                                <i class="bi bi-play-circle"></i> Start Working
                            </button>
                        }
                        <button class="btn-complete" @onclick="() => MarkComplete(ticket)">
                            <i class="bi bi-check-circle"></i> Mark as Complete
                        </button>
                    }
                    else
                    {
                        <span class="resolved-label"><i class="bi bi-check-circle-fill"></i> Resolved</span>
                    }
                </div>
            </div>
        }
    </div>
</div>


@code {
    private List<ServiceRequest> requests = new();
    private string message = string.Empty;
    private bool isError = false;
    private string technicianFullName = string.Empty;
    private string searchText = string.Empty;
    private string searchField = "all";
    private DateTime? filterDate = null;

    private IEnumerable<ServiceRequest> filteredRequests
    {
        get
        {
            var result = requests.AsEnumerable();

            if (filterDate.HasValue)
                result = result.Where(x => x.ResolvedAt.HasValue && x.ResolvedAt.Value.Date == filterDate.Value.Date);

            if (!string.IsNullOrWhiteSpace(searchText))
                result = result.Where(x => searchField switch
                {
                    "id" => x.RequestId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    "name" => ($"{x.FirstName} {x.LastName}").Contains(searchText, StringComparison.OrdinalIgnoreCase),
                    "issue" => x.IssueType?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    "address" => x.Address?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    "status" => x.Status?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    _ =>
                        (x.RequestId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        ($"{x.FirstName} {x.LastName}").Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                        (x.IssueType?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        (x.Address?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        (x.Status?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true)
                });

            return result;
        }
    }

    private int completedToday => requests.Count(x =>
        x.Status == "Resolved" && x.ResolvedAt?.Date == DateTime.Today);
    private int inProgressCount => requests.Count(x => x.Status == "In Progress");
    private int pendingCount => requests.Count(x => x.Status == "Open" || x.Status == "Pending");

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var username = authState.User.Identity?.Name ?? "";

        var users = await getUsers.ExecuteAsync();
        var currentUser = users?.FirstOrDefault(x => x.Username == username);
        if (currentUser != null)
            technicianFullName = $"{currentUser.FirstName} {currentUser.LastName}";

        await LoadRequests();
    }

    async Task LoadRequests()
    {
        try
        {
            var result = await getAllRequests.ExecuteAsync();
            // Show only tickets assigned to this technician
            requests = result?
                .Where(x => string.Equals(x.AssignedTo, technicianFullName, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(x => x.CreatedAt)
                .ToList() ?? new();
        }
        catch { }
    }

    async Task MarkInProgress(ServiceRequest ticket)
    {
        try
        {
            ticket.Status = "In Progress";
            await updateRequest.ExecuteAsync(ticket);
            await LoadRequests();
            message = "Ticket marked as In Progress.";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }

    async Task MarkComplete(ServiceRequest ticket)
    {
        try
        {
            ticket.Status = "Resolved";
            ticket.ResolvedAt = DateTime.Now;
            await updateRequest.ExecuteAsync(ticket);

            // Increment TechCompletedJobs using dedicated SP
            var allUsers = await getUsers.ExecuteAsync();
            var techUser = allUsers?.FirstOrDefault(x =>
                string.Equals($"{x.FirstName} {x.LastName}", technicianFullName, StringComparison.OrdinalIgnoreCase));

            if (techUser != null)
            {
                var newCount = (techUser.TechCompletedJobs ?? 0) + 1;
                await updateCompletedJobs.ExecuteAsync(techUser.UserId!, newCount);
            }

            await LoadRequests();
            message = "Ticket marked as complete!";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }

    string GetStatusClass(string? s) => s?.ToLower() switch
    {
        "open" => "status-pending",
        "pending" => "status-pending",
        "in progress" => "status-inprogress",
        "resolved" => "status-resolved",
        _ => ""
    };
}
