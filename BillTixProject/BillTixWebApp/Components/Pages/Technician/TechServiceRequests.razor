@page "/tech-service-requests"
@layout TechnicianLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@using BillTixWebApp.Components.Layout
@attribute [Authorize(Roles = "Technician")]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_ServiceRequest getAllRequests
@inject IUpdate_ServiceRequest updateRequest

<PageTitle>My Tickets - BillTix</PageTitle>

<div class="tickets-page">

    <div class="page-header">
        <h2>My Tickets</h2>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") mx-4 mb-0">
            @message
            <button class="btn-close float-end" @onclick="() => message = string.Empty"></button>
        </div>
    }

    <!-- Stat Cards -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">My Tickets</div>
                <div class="stat-value">@requests.Count</div>
            </div>
            <div class="stat-icon icon-blue">
                <i class="bi bi-calendar2-check"></i>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">Completed Today</div>
                <div class="stat-value">@completedToday</div>
            </div>
            <div class="stat-icon icon-green">
                <i class="bi bi-check-circle"></i>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">In Progress</div>
                <div class="stat-value">@inProgressCount</div>
            </div>
            <div class="stat-icon icon-yellow">
                <i class="bi bi-clock"></i>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <div class="stat-label">Pending</div>
                <div class="stat-value">@pendingCount</div>
            </div>
            <div class="stat-icon icon-orange">
                <i class="bi bi-clock-history"></i>
            </div>
        </div>
    </div>

    <!-- Ticket Cards -->
    <div class="tickets-list">
        @if (!requests.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No tickets found.</p>
            </div>
        }
        @foreach (var ticket in requests)
        {
            <div class="ticket-card">
                <div class="ticket-top">
                    <div class="ticket-icon-wrap">
                        <i class="bi bi-tools"></i>
                    </div>
                    <div class="ticket-meta">
                        <div class="ticket-title-row">
                            <span class="ticket-id">@ticket.RequestId</span>
                            <span class="badge-status @GetStatusClass(ticket.Status)">@ticket.Status</span>
                            <span class="badge-priority @GetPriorityClass(ticket.Priority)">@ticket.Priority</span>
                        </div>
                        <div class="ticket-issue">@ticket.IssueType</div>
                        <div class="ticket-assigned">Assigned to: @(ticket.AssignedTo ?? "Unassigned")</div>
                    </div>
                </div>

                <div class="ticket-details">
                    <div class="detail-left">
                        <div class="detail-item">
                            <i class="bi bi-person"></i>
                            <span>Customer: <strong>@ticket.FirstName @ticket.LastName</strong></span>
                        </div>
                        <div class="detail-item">
                            <i class="bi bi-telephone"></i>
                            <span>Phone: <strong>@(ticket.ContactNumber ?? "—")</strong></span>
                        </div>
                    </div>
                    <div class="detail-right">
                        <div class="detail-item">
                            <i class="bi bi-calendar3"></i>
                            <span>Created: <strong>@ticket.CreatedAt.ToString("MMM dd, yyyy")</strong></span>
                        </div>
                        @if (ticket.ResolvedAt.HasValue)
                        {
                            <div class="detail-item">
                                <i class="bi bi-check2-circle"></i>
                                <span>Resolved: <strong>@ticket.ResolvedAt.Value.ToString("MMM dd, yyyy")</strong></span>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ticket.Description))
                {
                    <div class="ticket-notes">
                        <div class="notes-label">📋 Description</div>
                        <div class="notes-text">@ticket.Description</div>
                    </div>
                }

                <div class="ticket-actions">
                    @if (ticket.Status != "Resolved")
                    {
                        @if (ticket.Status == "Pending")
                        {
                            <button class="btn-inprogress" @onclick="() => MarkInProgress(ticket)">
                                <i class="bi bi-play-circle"></i> Start Working
                            </button>
                        }
                        <button class="btn-complete" @onclick="() => MarkComplete(ticket)">
                            <i class="bi bi-check-circle"></i> Mark as Complete
                        </button>
                    }
                    else
                    {
                        <span class="resolved-label"><i class="bi bi-check-circle-fill"></i> Resolved</span>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    .tickets-page {
        min-height: 100vh;
        background: #f5f6fa;
        padding-bottom: 40px;
    }

    .page-header {
        padding: 28px 32px 0;
    }

    .page-header h2 {
        font-size: 1.6rem;
        font-weight: 800;
        color: #111;
        margin: 0 0 20px;
    }

    /* Stat Cards */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        padding: 0 32px 24px;
        border: 2px solid #2563eb;
        border-radius: 16px;
        margin: 0 32px 24px;
        padding-top: 20px;
        background: white;
    }

    .stat-card {
        background: #fafafa;
        border: 1px solid #f0f0f0;
        border-radius: 12px;
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .stat-label {
        font-size: .8rem;
        color: #888;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: #111;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .icon-blue { background: #eff6ff; color: #2563eb; }
    .icon-green { background: #f0fdf4; color: #16a34a; }
    .icon-yellow { background: #fefce8; color: #ca8a04; }
    .icon-orange { background: #fff7ed; color: #ea580c; }

    /* Tickets List */
    .tickets-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding: 0 32px;
    }

    .ticket-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 10px rgba(0,0,0,.05);
        border: 1px solid #f0f0f0;
    }

    .ticket-top {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 16px;
    }

    .ticket-icon-wrap {
        width: 48px;
        height: 48px;
        background: #eff6ff;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2563eb;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .ticket-meta { flex: 1; }

    .ticket-title-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 4px;
    }

    .ticket-id {
        font-size: .85rem;
        font-weight: 700;
        color: #374151;
    }

    .ticket-issue {
        font-size: 1.1rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 2px;
    }

    .ticket-assigned {
        font-size: .82rem;
        color: #888;
    }

    /* Badges */
    .badge-status, .badge-priority {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-pending { background: #fff7ed; color: #ea580c; }
    .status-inprogress { background: #eff6ff; color: #2563eb; }
    .status-resolved { background: #f0fdf4; color: #16a34a; }
    .priority-high, .priority-urgent { background: #fee2e2; color: #dc2626; }
    .priority-medium { background: #fef9c3; color: #ca8a04; }
    .priority-low { background: #f0fdf4; color: #16a34a; }

    /* Details */
    .ticket-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-bottom: 14px;
        padding-top: 14px;
        border-top: 1px solid #f3f4f6;
    }

    .detail-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .88rem;
        color: #555;
    }

    .detail-item i { color: #9ca3af; font-size: .9rem; }
    .detail-item strong { color: #111; }
    .detail-right .detail-item i { color: #2563eb; }

    /* Notes */
    .ticket-notes {
        background: #fefce8;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 16px;
        border: 1px solid #fde68a;
    }

    .notes-label {
        font-size: .8rem;
        font-weight: 700;
        color: #92400e;
        margin-bottom: 4px;
    }

    .notes-text {
        font-size: .88rem;
        color: #b45309;
        line-height: 1.5;
    }

    /* Actions */
    .ticket-actions {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .btn-complete {
        background: #16a34a;
        color: white;
        border: none;
        padding: 9px 20px;
        border-radius: 10px;
        font-size: .88rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background .2s;
    }

    .btn-complete:hover { background: #15803d; }

    .btn-inprogress {
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #bfdbfe;
        padding: 9px 20px;
        border-radius: 10px;
        font-size: .88rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background .2s;
    }

    .btn-inprogress:hover { background: #dbeafe; }

    .resolved-label {
        color: #16a34a;
        font-size: .88rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 0;
        color: #aaa;
    }

    .empty-state i { font-size: 3rem; display: block; margin-bottom: 12px; }
    .empty-state p { font-size: 1rem; }

    @@media (max-width: 900px) {
        .stats-row { grid-template-columns: repeat(2, 1fr); margin: 0 16px 20px; padding: 16px; }
        .tickets-list { padding: 0 16px; }
        .page-header { padding: 20px 16px 0; }
        .ticket-details { grid-template-columns: 1fr; }
    }

    @@media (max-width: 500px) {
        .stats-row { grid-template-columns: 1fr 1fr; }
    }
</style>

@code {
    private List<ServiceRequest> requests = new();
    private string message = string.Empty;
    private bool isError = false;

    private int completedToday => requests.Count(x =>
        x.Status == "Resolved" && x.ResolvedAt?.Date == DateTime.Today);
    private int inProgressCount => requests.Count(x => x.Status == "In Progress");
    private int pendingCount => requests.Count(x => x.Status == "Pending");

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();
    }

    async Task LoadRequests()
    {
        try
        {
            var result = await getAllRequests.ExecuteAsync();
            requests = result?.OrderByDescending(x => x.CreatedAt).ToList() ?? new();
        }
        catch { }
    }

    async Task MarkInProgress(ServiceRequest ticket)
    {
        try
        {
            ticket.Status = "In Progress";
            await updateRequest.ExecuteAsync(ticket);
            await LoadRequests();
            message = "Ticket marked as In Progress.";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }

    async Task MarkComplete(ServiceRequest ticket)
    {
        try
        {
            ticket.Status = "Resolved";
            ticket.ResolvedAt = DateTime.Now;
            await updateRequest.ExecuteAsync(ticket);
            await LoadRequests();
            message = "Ticket marked as complete!";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }

    string GetPriorityClass(string? p) => p?.ToLower() switch
    {
        "high"   => "priority-high",
        "urgent" => "priority-urgent",
        "medium" => "priority-medium",
        "low"    => "priority-low",
        _        => ""
    };

    string GetStatusClass(string? s) => s?.ToLower() switch
    {
        "pending"     => "status-pending",
        "in progress" => "status-inprogress",
        "resolved"    => "status-resolved",
        _             => ""
    };
}
