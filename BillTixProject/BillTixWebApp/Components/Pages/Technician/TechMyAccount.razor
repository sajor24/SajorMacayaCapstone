@page "/tech-myaccount"
@layout TechnicianLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@using BillTixWebApp.Components.Layout
@attribute [Authorize(Roles = "Technician")]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll
@inject IUpdate_User update

<PageTitle>My Account - BillTix</PageTitle>

<div class="account-page">

    <div class="account-header">
        <h2>My Account</h2>
        <p>Manage your personal information</p>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @message
            <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
        </div>
    }

    <div class="account-grid">

        <!-- LEFT -->
        <div class="left-col">
            <div class="card">
                <h4>Profile Information</h4>
                <p class="muted">Update your personal details</p>

                <div class="form-grid">
                    <div>
                        <label>First Name</label>
                        <input class="input" @bind="user.FirstName" />
                    </div>
                    <div>
                        <label>Last Name</label>
                        <input class="input" @bind="user.LastName" />
                    </div>
                    <div>
                        <label>Email Address</label>
                        <input class="input" @bind="user.Email" />
                    </div>
                    <div>
                        <label>Phone Number</label>
                        <input class="input" @bind="user.ContactNumber" />
                    </div>
                    <div class="full">
                        <label>Address</label>
                        <input class="input" @bind="user.Address" />
                    </div>
                </div>

                <button class="btn btn-primary mt-3" @onclick="SaveProfile">Save Changes</button>
            </div>

            <div class="card">
                <h4>Change Password</h4>
                <p class="muted">Leave blank if you don't want to change</p>

                <div class="form-grid">
                    <div class="full">
                        <label>New Password</label>
                        <input type="password" class="input" placeholder="Enter new password" @bind="newPassword" />
                    </div>
                    <div class="full">
                        <label>Confirm Password</label>
                        <input type="password" class="input" placeholder="Confirm new password" @bind="confirmPassword" />
                    </div>
                </div>

                <button class="btn btn-outline-secondary mt-3" @onclick="ChangePassword">Update Password</button>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="right-col">
            <div class="card">
                <h4>Account Summary</h4>
                <div class="summary-list">
                    <div><span>Account ID</span><strong>@user.UserId</strong></div>
                    <div><span>Username</span><strong>@user.Username</strong></div>
                    <div><span>Role</span><span class="badge-role">Technician</span></div>
                    <div><span>Email</span><strong>@(user.Email ?? "—")</strong></div>
                    <div><span>Member Since</span><strong>@user.CreatedAt.ToString("MMM dd, yyyy")</strong></div>
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    private Users user = new();
    private string message = string.Empty;
    private bool isError = false;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;

        if (authUser.Identity?.IsAuthenticated == true)
        {
            var username = authUser.Identity.Name ?? "";
            var users = await getAll.ExecuteAsync();
            var found = users?.FirstOrDefault(x => x.Username == username);
            if (found != null)
                user = found;
        }
    }

    async Task SaveProfile()
    {
        try
        {
            await update.ExecuteAsync(user);
            message = "Profile updated successfully!";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }

    async Task ChangePassword()
    {
        if (string.IsNullOrWhiteSpace(newPassword))
        {
            message = "Please enter a new password.";
            isError = true;
            return;
        }
        if (newPassword != confirmPassword)
        {
            message = "Passwords do not match.";
            isError = true;
            return;
        }
        try
        {
            user.Password = newPassword;
            await update.ExecuteAsync(user);
            newPassword = string.Empty;
            confirmPassword = string.Empty;
            message = "Password updated successfully!";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }
}
