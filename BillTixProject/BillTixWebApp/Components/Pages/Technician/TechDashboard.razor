@page "/tech-dashboard"
@layout TechnicianLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@using BillTixWebApp.Components.Layout
@attribute [Authorize(Roles = "Technician")]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll
@inject IGetAll_ServiceRequest getAllRequests

<PageTitle>Tech Dashboard - BillTix</PageTitle>

<div class="wrapper">

    <div class="topnav">
        <div class="topnav-left">
            <h2>Welcome, @username</h2>
            <p>Manage your assigned service requests</p>
        </div>
    </div>

    <div class="content">
        <h1>Dashboard</h1>

        <div class="stat-cards">
            <div class="stat-card">
                <div>
                    <div class="label">Total Requests</div>
                    <div class="value">@totalRequests</div>
                    <div class="trend">All service requests</div>
                </div>
                <div class="stat-icon icon-blue">🔧</div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="label">Active</div>
                    <div class="value">@pendingCount</div>
                    <div class="trend">Open & In Progress</div>
                </div>
                <div class="stat-icon icon-orange">⏳</div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="label">Resolved</div>
                    <div class="value">@resolvedCount</div>
                    <div class="trend">Completed requests</div>
                </div>
                <div class="stat-icon icon-green">✅</div>
            </div>
        </div>

        <div class="bottom-grid">
            <div class="card">
                <div class="card-title">Recent Service Requests</div>
                <div class="card-sub">Latest submitted service requests</div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Request ID</th>
                                <th>Subscriber</th>
                                <th>Issue Type</th>
                                <th>Adress</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Assigned to</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in recentRequests)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.RequestId</td>
                                    <td>@item.FirstName @item.LastName</td>
                                    <td>@item.IssueType</td>
                                    <td class="text-muted">@(item.Address ?? "—")</td>
                                    <td>
                                        <span class="badge-status @GetStatusClass(item.Status)">@item.Status</span>
                                    </td>
                                    <td class="text-muted">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>@item.AssignedTo</td>
                                </tr>
                            }
                            @if (!recentRequests.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-3">No service requests found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "Technician";
    private string techFullName = string.Empty;
    private int totalRequests = 0;
    private int pendingCount = 0;
    private int resolvedCount = 0;
    private List<ServiceRequest> recentRequests = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
            username = user.Identity.Name ?? "Technician";

        try
        {
            // Get full name of current technician
            var users = await getAll.ExecuteAsync();
            var currentUser = users?.FirstOrDefault(x => x.Username == username);
            if (currentUser != null)
                techFullName = $"{currentUser.FirstName} {currentUser.LastName}";

            var all = await getAllRequests.ExecuteAsync();
            if (all != null)
            {
                // Only show requests assigned to this technician
                var list = all
                    .Where(x => string.Equals(x.AssignedTo, techFullName, StringComparison.OrdinalIgnoreCase))
                    .ToList();

                totalRequests = list.Count;
                pendingCount  = list.Count(x => x.Status == "Open" || x.Status == "In Progress");
                resolvedCount = list.Count(x => x.Status == "Resolved");
                recentRequests = list.OrderByDescending(x => x.CreatedAt).Take(10).ToList();
            }
        }
        catch { }
    }

    string GetStatusClass(string? s) => s?.ToLower() switch
    {
        "open"        => "status-pending",
        "pending"     => "status-pending",
        "in progress" => "status-inprogress",
        "resolved"    => "status-resolved",
        _             => ""
    };
}
