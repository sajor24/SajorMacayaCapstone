@page "/sub-support"
@layout SubscriberLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Subscriber")]
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll
@inject IGetByUser_ServiceRequest getRequests
@inject ICreate_ServiceRequest createRequest

<div class="support-wrapper">

    <div class="support-header">
        <h3 class="fw-bold mb-0">Support</h3>
        <p class="text-muted">Submit and track your service requests</p>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @message
            <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
        </div>
    }

    <div class="support-grid">

        <!-- LEFT: Submit Form -->
        <div class="form-card">
            <div class="form-card-title">Report an Issue</div>
            <p class="text-muted" style="font-size:.85rem; margin-top:-8px;">Submit a new service request</p>

            <div class="mb-3">
                <label class="form-label fw-semibold">Issue Type <span class="text-danger">*</span></label>
                <select class="form-select" @bind="issueType">
                    <option value="">Select issue type</option>
                    <option value="No Connection">No Connection</option>
                    <option value="Slow Internet">Slow Internet</option>
                    <option value="Router Problem">Router Problem</option>
                    <option value="WiFi Issue">WiFi Issue</option>
                    <option value="Billing Concern">Billing Concern</option>
                    <option value="Plan Upgrade">Plan Upgrade</option>
                    <option value="Installation">Installation</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                <textarea class="form-control" rows="4"
                          placeholder="Describe your issue in detail..."
                          @bind="description"></textarea>
                <small class="text-muted">Please provide as much detail as possible</small>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Contact Number</label>
                <input class="form-control" placeholder="+63 912 345 6789" @bind="contactNumber" />
            </div>

            <button class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2"
                    @onclick="SubmitRequest" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                else
                {
                    <i class="bi bi-send-fill"></i>
                }
                @(isSubmitting ? "Submitting..." : "Submit Request")
            </button>
        </div>

        <!-- RIGHT: My Requests -->
        <div class="requests-card">
            <div class="requests-title">My Service Requests</div>
            <p class="text-muted" style="font-size:.85rem; margin-top:-8px;">Track your submitted requests</p>

            @if (!_loaded)
            {
                <div class="text-center text-muted py-4">
                    <div class="spinner-border spinner-border-sm"></div>
                </div>
            }
            else if (!requests.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-ticket-perforated" style="font-size:2.5rem; color:#ccc;"></i>
                    <p class="mt-2">No requests submitted yet.</p>
                </div>
            }
            else
            {
                <div class="requests-list">
                    @foreach (var req in requests)
                    {
                        <div class="request-item">
                            <div class="request-top">
                                <span class="request-type">@req.IssueType</span>
                                <span class="status-badge @GetStatusClass(req.Status)">@req.Status</span>
                            </div>
                            <div class="request-desc">@req.Description</div>
                            <div class="request-meta">
                                <span>ID: @req.RequestId</span>
                                <span>Created: @req.CreatedAt.ToString("M/d/yyyy")</span>
                                @if (req.ResolvedAt.HasValue)
                                {
                                    <span>Resolved: @req.ResolvedAt.Value.ToString("M/d/yyyy")</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(req.AssignedTo))
                            {
                                <div class="request-assigned">
                                    <i class="bi bi-person-fill me-1"></i> Assigned to technician: @req.AssignedTo
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
@code {
    private List<ServiceRequest> requests = new();
    private string userId = string.Empty;
    private string contactNumber = string.Empty;
    private string issueType = string.Empty;
    private string description = string.Empty;
    private string message = string.Empty;
    private bool isError = false;
    private bool isSubmitting = false;
    private bool _loaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded) return;
        _loaded = true;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var username = user.Identity.Name ?? "";
                var users = await getAll.ExecuteAsync();
                var currentUser = users?.FirstOrDefault(x => x.Username == username);

                if (currentUser != null)
                {
                    userId = currentUser.UserId ?? "";
                    contactNumber = currentUser.ContactNumber ?? string.Empty;
                    await LoadRequests();
                }
            }
        }
        catch
        {
            // DB table may not exist yet
        }

        StateHasChanged();
    }

    async Task LoadRequests()
    {
        var result = await getRequests.ExecuteAsync(userId);
        requests = result?.ToList() ?? new();
    }

    async Task SubmitRequest()
    {
        if (string.IsNullOrWhiteSpace(issueType) || string.IsNullOrWhiteSpace(description))
        {
            message = "Issue Type and Description are required.";
            isError = true;
            return;
        }

        isSubmitting = true;
        try
        {
            await createRequest.ExecuteAsync(new ServiceRequest
            {
                UserId        = userId,
                IssueType     = issueType,
                Priority      = "Medium",
                Description   = description,
                ContactNumber = contactNumber
            });

            await LoadRequests();
            message = "Request submitted successfully! Our team will get back to you soon.";
            isError = false;
            issueType   = string.Empty;
            description = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
        isSubmitting = false;
    }

    string GetStatusClass(string? status) => status switch
    {
        "Open"        => "badge-open",
        "In Progress" => "badge-inprogress",
        "Resolved"    => "badge-resolved",
        "Closed"      => "badge-closed",
        _             => "badge-open"
    };

    string GetPriorityClass(string? priority) => priority switch
    {
        "Low"      => "priority-low",
        "Medium"   => "priority-medium",
        "High"     => "priority-high",
        "Critical" => "priority-critical",
        _          => "priority-medium"
    };
}
