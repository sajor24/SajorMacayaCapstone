@page "/sub-support"
@layout SubscriberLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Subscriber")]
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll
@inject IGetByUser_ServiceRequest getRequests
@inject ICreate_ServiceRequest createRequest

<div class="support-wrapper">

    <div class="support-header">
        <h3 class="fw-bold mb-0">Support</h3>
        <p class="text-muted">Submit and track your service requests</p>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @message
            <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
        </div>
    }

    <div class="support-grid">

        <!-- LEFT: Submit Form -->
        <div class="form-card">
            <div class="form-card-title">Report an Issue</div>
            <p class="text-muted" style="font-size:.85rem; margin-top:-8px;">Submit a new service request</p>

            <div class="mb-3">
                <label class="form-label fw-semibold">Issue Type <span class="text-danger">*</span></label>
                <select class="form-select" @bind="issueType">
                    <option value="">Select issue type</option>
                    <option value="No Connection">No Connection</option>
                    <option value="Slow Internet">Slow Internet</option>
                    <option value="Router Problem">Router Problem</option>
                    <option value="WiFi Issue">WiFi Issue</option>
                    <option value="Billing Concern">Billing Concern</option>
                    <option value="Plan Upgrade">Plan Upgrade</option>
                    <option value="Installation">Installation</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Priority</label>
                <select class="form-select" @bind="priority">
                    <option value="Low">Low</option>
                    <option value="Medium" selected>Medium</option>
                    <option value="High">High</option>
                    <option value="Critical">Critical</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                <textarea class="form-control" rows="4"
                          placeholder="Describe your issue in detail..."
                          @bind="description"></textarea>
                <small class="text-muted">Please provide as much detail as possible</small>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Contact Number</label>
                <input class="form-control" placeholder="+63 912 345 6789" @bind="contactNumber" />
            </div>

            <button class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2"
                    @onclick="SubmitRequest" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                else
                {
                    <i class="bi bi-send-fill"></i>
                }
                @(isSubmitting ? "Submitting..." : "Submit Request")
            </button>
        </div>

        <!-- RIGHT: My Requests -->
        <div class="requests-card">
            <div class="requests-title">My Service Requests</div>
            <p class="text-muted" style="font-size:.85rem; margin-top:-8px;">Track your submitted requests</p>

            @if (!_loaded)
            {
                <div class="text-center text-muted py-4">
                    <div class="spinner-border spinner-border-sm"></div>
                </div>
            }
            else if (!requests.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-ticket-perforated" style="font-size:2.5rem; color:#ccc;"></i>
                    <p class="mt-2">No requests submitted yet.</p>
                </div>
            }
            else
            {
                <div class="requests-list">
                    @foreach (var req in requests)
                    {
                        <div class="request-item">
                            <div class="request-top">
                                <span class="request-type">@req.IssueType</span>
                                <span class="status-badge @GetStatusClass(req.Status)">@req.Status</span>
                                <span class="priority-badge @GetPriorityClass(req.Priority)">@req.Priority</span>
                            </div>
                            <div class="request-desc">@req.Description</div>
                            <div class="request-meta">
                                <span>ID: @req.RequestId</span>
                                <span>Created: @req.CreatedAt.ToString("M/d/yyyy")</span>
                                @if (req.ResolvedAt.HasValue)
                                {
                                    <span>Resolved: @req.ResolvedAt.Value.ToString("M/d/yyyy")</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(req.AssignedTo))
                            {
                                <div class="request-assigned">
                                    <i class="bi bi-person-fill me-1"></i> Assigned to technician: @req.AssignedTo
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .support-wrapper {
        padding: 32px;
        background: #f5f6fa;
        min-height: 100vh;
    }

    .support-header {
        margin-bottom: 24px;
    }

    .support-header h3 { color: #111; font-size: 1.5rem; }

    .support-grid {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 24px;
        align-items: start;
    }

    /* Form Card */
    .form-card {
        background: white;
        border-radius: 16px;
        padding: 28px 24px;
        box-shadow: 0 2px 10px rgba(0,0,0,.06);
    }

    .form-card-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 4px;
    }

    /* Requests Card */
    .requests-card {
        background: white;
        border-radius: 16px;
        padding: 28px 24px;
        box-shadow: 0 2px 10px rgba(0,0,0,.06);
    }

    .requests-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #111;
        margin-bottom: 4px;
    }

    .requests-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-top: 12px;
    }

    .request-item {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px 18px;
        transition: box-shadow .15s;
    }

    .request-item:hover {
        box-shadow: 0 3px 12px rgba(0,0,0,.06);
    }

    .request-top {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        flex-wrap: wrap;
    }

    .request-type {
        font-weight: 700;
        font-size: .95rem;
        color: #111;
    }

    .request-desc {
        font-size: .88rem;
        color: #555;
        margin-bottom: 8px;
        line-height: 1.5;
    }

    .request-meta {
        display: flex;
        gap: 16px;
        font-size: .78rem;
        color: #aaa;
        flex-wrap: wrap;
    }

    .request-assigned {
        font-size: .82rem;
        color: #6b7280;
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px solid #f3f4f6;
    }

    /* Status badges */
    .status-badge {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
    }

    .badge-open       { background: #dbeafe; color: #1d4ed8; }
    .badge-inprogress { background: #ede9fe; color: #7c3aed; }
    .badge-resolved   { background: #d1fae5; color: #059669; }
    .badge-closed     { background: #f3f4f6; color: #6b7280; }

    /* Priority badges */
    .priority-badge {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 700;
    }

    .priority-low      { background: #d1fae5; color: #059669; }
    .priority-medium   { background: #fef3c7; color: #d97706; }
    .priority-high     { background: #fee2e2; color: #dc2626; }
    .priority-critical { background: #dc2626; color: white; }

    @@media (max-width: 900px) {
        .support-grid { grid-template-columns: 1fr; }
        .support-wrapper { padding: 70px 16px 16px; }
    }
</style>

@code {
    private List<ServiceRequest> requests = new();
    private string userId = string.Empty;
    private string contactNumber = string.Empty;
    private string issueType = string.Empty;
    private string priority = "Medium";
    private string description = string.Empty;
    private string message = string.Empty;
    private bool isError = false;
    private bool isSubmitting = false;
    private bool _loaded = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded) return;
        _loaded = true;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var username = user.Identity.Name ?? "";
                var users = await getAll.ExecuteAsync();
                var currentUser = users?.FirstOrDefault(x => x.Username == username);

                if (currentUser != null)
                {
                    userId = currentUser.UserId ?? "";
                    contactNumber = currentUser.ContactNumber ?? string.Empty;
                    await LoadRequests();
                }
            }
        }
        catch
        {
            // DB table may not exist yet
        }

        StateHasChanged();
    }

    async Task LoadRequests()
    {
        var result = await getRequests.ExecuteAsync(userId);
        requests = result?.ToList() ?? new();
    }

    async Task SubmitRequest()
    {
        if (string.IsNullOrWhiteSpace(issueType) || string.IsNullOrWhiteSpace(description))
        {
            message = "Issue Type and Description are required.";
            isError = true;
            return;
        }

        isSubmitting = true;
        try
        {
            await createRequest.ExecuteAsync(new ServiceRequest
            {
                UserId        = userId,
                IssueType     = issueType,
                Priority      = priority,
                Description   = description,
                ContactNumber = contactNumber
            });

            await LoadRequests();
            message = "Request submitted successfully! Our team will get back to you soon.";
            isError = false;
            issueType   = string.Empty;
            priority    = "Medium";
            description = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
        isSubmitting = false;
    }

    string GetStatusClass(string? status) => status switch
    {
        "Open"        => "badge-open",
        "In Progress" => "badge-inprogress",
        "Resolved"    => "badge-resolved",
        "Closed"      => "badge-closed",
        _             => "badge-open"
    };

    string GetPriorityClass(string? priority) => priority switch
    {
        "Low"      => "priority-low",
        "Medium"   => "priority-medium",
        "High"     => "priority-high",
        "Critical" => "priority-critical",
        _          => "priority-medium"
    };
}
