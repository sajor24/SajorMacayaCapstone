@page "/sub-internetplans"
@layout SubscriberLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Subscriber")]
@inject IGetAll_InternetPlan getPlans
@inject IGetByUser_Subscription getSubscription
@inject ICreate_UpgradeRequest createRequest
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll

<div class="plans-wrapper">

    <div class="plans-header">
        <h3 class="fw-bold mb-0">Internet Plans</h3>
        <p class="text-muted">Choose the perfect plan for your needs. No hidden fees, cancel anytime.</p>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @message
            <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
        </div>
    }

    <div class="plans-grid">
        @foreach (var plan in plans)
        {
            var features = plan.FeatureList;
            var isCurrent = currentSub?.PlanName == plan.PlanName && currentSub?.Status == "Active";
            var hasPending = pendingRequests.Any(x => x.PlanName == plan.PlanName && x.Status == "Pending");

            <div class="plan-card @(isCurrent ? "plan-current" : "")">
                @if (isCurrent)
                {
                    <div class="plan-badge current-badge">Current Plan</div>
                }
                else if (hasPending)
                {
                    <div class="plan-badge pending-badge">Pending Approval</div>
                }

                <div class="plan-name">@plan.PlanName</div>
                <div class="plan-speed">@plan.Speed</div>
                <div class="plan-price">₱@plan.Price.ToString("N2")<span>/Month</span></div>

                <ul class="plan-features">
                    @foreach (var feature in features)
                    {
                        <li>✓ @feature</li>
                    }
                </ul>

                @if (isCurrent)
                {
                    <button class="btn-current" disabled>Active Plan</button>
                }
                else if (hasPending)
                {
                    <button class="btn-pending" disabled>Waiting for Approval</button>
                }
                else
                {
                    <button class="btn-upgrade" @onclick="() => OpenUpgradeForm(plan)">
                        Upgrade to @plan.PlanName
                    </button>
                }
            </div>
        }

        @if (!plans.Any())
        {
            <p class="text-muted">No plans available.</p>
        }
    </div>
</div>

<!-- UPGRADE REQUEST MODAL -->
@if (showUpgradeForm)
{
    <div class="modal-backdrop-custom" @onclick="CancelUpgrade"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Upgrade to @selectedPlan?.PlanName</h5>
            <button class="btn-close" @onclick="CancelUpgrade"></button>
        </div>

        <div class="mb-3">
            <p class="text-muted">Price: <strong>₱@selectedPlan?.Price.ToString("N2")/Month</strong></p>
            <p class="text-muted small">Your plan will be upgraded after admin approval. Please provide your payment reference number.</p>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Reference Number <span class="text-danger">*</span></label>
            <input class="form-control" placeholder="e.g. GCash ref: 1234567890" @bind="referenceNo" />
            <small class="text-muted">Enter your GCash, bank transfer, or payment reference number.</small>
        </div>

        @if (!string.IsNullOrEmpty(formError))
        {
            <div class="alert alert-danger">@formError</div>
        }

        <div class="d-flex gap-2 mt-4 justify-content-end">
            <button class="btn btn-secondary" @onclick="CancelUpgrade">Cancel</button>
            <button class="btn btn-primary" @onclick="SubmitUpgradeRequest" disabled="@isSubmitting">
                @(isSubmitting ? "Submitting..." : "Submit Request")
            </button>
        </div>
    </div>
}

@code {
    private List<InternetPlan> plans = new();
    private Subscription? currentSub;
    private List<UpgradeRequest> pendingRequests = new();
    private string userId = string.Empty;
    private string message = string.Empty;
    private bool isError = false;
    private bool showUpgradeForm = false;
    private bool isSubmitting = false;
    private string referenceNo = string.Empty;
    private string formError = string.Empty;
    private InternetPlan? selectedPlan;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var username = user.Identity.Name ?? "";
            var users = await getAll.ExecuteAsync();
            var currentUser = users?.FirstOrDefault(x => x.Username == username);

            if (currentUser != null)
            {
                userId = currentUser.UserId ?? "";
                var subs = await getSubscription.ExecuteAsync(userId);
                currentSub = subs?.FirstOrDefault(x => x.Status == "Active");
            }
        }

        var result = await getPlans.ExecuteAsync();
        plans = result?.Where(x => x.IsActive).ToList() ?? new();
    }

    void OpenUpgradeForm(InternetPlan plan)
    {
        selectedPlan = plan;
        referenceNo = string.Empty;
        formError = string.Empty;
        showUpgradeForm = true;
    }

    void CancelUpgrade()
    {
        showUpgradeForm = false;
        selectedPlan = null;
        referenceNo = string.Empty;
        formError = string.Empty;
    }

    async Task SubmitUpgradeRequest()
    {
        if (string.IsNullOrWhiteSpace(referenceNo))
        {
            formError = "Reference number is required.";
            return;
        }

        if (selectedPlan == null) return;

        isSubmitting = true;
        formError = string.Empty;

        try
        {
            var request = new UpgradeRequest
            {
                UserId = userId,
                PlanId = selectedPlan.PlanId,
                PlanName = selectedPlan.PlanName,
                ReferenceNo = referenceNo,
                Status = "Pending"
            };

            await createRequest.ExecuteAsync(request);

            // Refresh pending requests
            pendingRequests.Add(request);

            showUpgradeForm = false;
            selectedPlan = null;
            referenceNo = string.Empty;

            message = "Upgrade request submitted! Please wait for admin approval.";
            isError = false;
        }
        catch (Exception ex)
        {
            formError = $"Error: {ex.Message}";
        }

        isSubmitting = false;
    }
}
