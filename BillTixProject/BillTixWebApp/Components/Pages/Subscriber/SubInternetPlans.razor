@page "/sub-internetplans"
@layout SubscriberLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Subscriber")]
@inject IGetAll_InternetPlan getPlans
@inject IGetByUser_Subscription getSubscription
@inject ICreate_Subscription createSub
@inject IUpdate_Subscription updateSub
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll

<div class="plans-wrapper">

    <!-- HEADER -->
    <div class="plans-header">
        <h3 class="fw-bold mb-0">Internet Plans</h3>
        <p class="text-muted">Choose the perfect plan for your needs. No hidden fees, cancel anytime.</p>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @message
            <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
        </div>
    }

    <!-- CARDS -->
    <div class="plans-grid">
        @foreach (var plan in plans)
        {
            var features = plan.FeatureList;
            var isCurrent = currentSub?.PlanName == plan.PlanName && currentSub?.Status == "Active";

            <div class="plan-card @(isCurrent ? "plan-current" : "")">
                @if (isCurrent)
                {
                    <div class="plan-badge current-badge">Current Plan</div>
                }

                <div class="plan-name">@plan.PlanName</div>
                <div class="plan-speed">@plan.Speed</div>
                <div class="plan-price">₱@plan.Price.ToString("N2")<span>/Month</span></div>

                <ul class="plan-features">
                    @foreach (var feature in features)
                    {
                        <li>✓ @feature</li>
                    }
                </ul>

                @if (!isCurrent)
                {
                    <button class="btn-upgrade" @onclick="() => UpgradePlan(plan)" disabled="@isUpgrading">
                        @(isUpgrading && selectedPlanName == plan.PlanName ? "Upgrading..." : "Upgrade to @plan.PlanName")
                    </button>
                }
                else
                {
                    <button class="btn-current" disabled>Active Plan</button>
                }
            </div>
        }

        @if (!plans.Any())
        {
            <p class="text-muted">No plans available.</p>
        }
    </div>

</div>

<!-- CONFIRM UPGRADE MODAL -->
@if (showConfirm)
{
    <div class="modal-backdrop-custom" @onclick="CancelUpgrade"></div>
    <div class="modal-box shadow-lg" style="width:420px;">
        <div class="text-center py-2">
            <div style="font-size:3rem;">🚀</div>
            <h5 class="fw-bold mt-2">Upgrade Plan?</h5>
            <p class="text-muted mt-1">Are you sure you want to upgrade to <strong>@selectedPlanName</strong>?</p>
            <p class="text-muted">₱@selectedPlanPrice.ToString("N2")/Month</p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="CancelUpgrade">Cancel</button>
            <button class="btn btn-primary px-4" @onclick="ConfirmUpgrade">Yes, Upgrade</button>
        </div>
    </div>
}

@code {
    private List<InternetPlan> plans = new();
    private Subscription? currentSub;
    private string userId = string.Empty;
    private string message = string.Empty;
    private bool isError = false;
    private bool isUpgrading = false;
    private bool showConfirm = false;
    private string selectedPlanName = string.Empty;
    private decimal selectedPlanPrice = 0;
    private InternetPlan? selectedPlan;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var username = user.Identity.Name ?? "";
            var users = await getAll.ExecuteAsync();
            var currentUser = users?.FirstOrDefault(x => x.Username == username);

            if (currentUser != null)
            {
                userId = currentUser.UserId ?? "";
                var subs = await getSubscription.ExecuteAsync(userId);
                currentSub = subs?.FirstOrDefault(x => x.Status == "Active");
            }
        }

        var result = await getPlans.ExecuteAsync();
        plans = result?.Where(x => x.IsActive).ToList() ?? new();
    }

    void UpgradePlan(InternetPlan plan)
    {
        selectedPlan = plan;
        selectedPlanName = plan.PlanName ?? "";
        selectedPlanPrice = plan.Price;
        showConfirm = true;
    }

    void CancelUpgrade()
    {
        showConfirm = false;
        selectedPlan = null;
    }

    async Task ConfirmUpgrade()
    {
        if (selectedPlan == null) return;

        isUpgrading = true;
        showConfirm = false;

        try
        {
            if (currentSub != null)
            {
                // Update existing subscription
                currentSub.PlanName = selectedPlan.PlanName;
                currentSub.PlanPrice = selectedPlan.Price;
                currentSub.StartDate = DateTime.Now;
                currentSub.EndDate = DateTime.Now.AddMonths(1);
                currentSub.Status = "Active";
                await updateSub.ExecuteAsync(currentSub);
            }
            else
            {
                // Create new subscription
                var newSub = new Subscription
                {
                    UserId = userId,
                    PlanName = selectedPlan.PlanName,
                    PlanPrice = selectedPlan.Price,
                    StartDate = DateTime.Now,
                    EndDate = DateTime.Now.AddMonths(1),
                    Status = "Active"
                };
                await createSub.ExecuteAsync(newSub);
            }

            var subs = await getSubscription.ExecuteAsync(userId);
            currentSub = subs?.FirstOrDefault(x => x.Status == "Active");

            message = $"Successfully upgraded to {selectedPlan.PlanName}!";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }

        isUpgrading = false;
        selectedPlan = null;
    }
}
