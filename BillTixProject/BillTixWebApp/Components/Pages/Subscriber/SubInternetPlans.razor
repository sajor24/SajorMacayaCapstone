@page "/sub-internetplans"
@layout SubscriberLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Subscriber")]
@inject IGetAll_InternetPlan getPlans
@inject IGetByUser_Subscription getSubscription
@inject ICreate_UpgradeRequest createRequest
@inject IGetAll_UpgradeRequest getAllRequests
@inject IDelete_UpgradeRequest deleteRequest
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll
@inject IGetByUser_Billing getBillings
<div class="plans-wrapper">

    
    <div class="header">
        <h3 class="fw-bold mb-0">Available Internet Plans</h3>
        <p class="text-muted">Upgrade or change your subscription plan</p>
    </div>
   
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @message
            <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
        </div>
    }

    @* Current Plan Banner *@
    @if (currentSubs.Any())
    {
        <div class="current-plan-banner mb-4">
            <div style="flex:1;">
                <div class="current-plan-label">Your Current Plan@(currentSubs.Count > 1 ? "s" : "")</div>
                @foreach (var sub in currentSubs)
                {
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <div>
                            <div class="current-plan-name">@sub.PlanName</div>
                            <div class="current-plan-price">₱@sub.PlanPrice.ToString("N2") / month</div>
                        </div>
                        <span class="current-plan-status">Active</span>
                    </div>
                }
            </div>
        </div>
    }

    <div class="plans-grid">
        @foreach (var plan in plans)
        {
            var features = plan.FeatureList;
            var isCurrent = currentSubs.Any(s => s.PlanName == plan.PlanName && s.Status == "Active");
            var hasPending = pendingRequests.Any(x => x.PlanId == plan.PlanId && x.Status == "Pending");

            <div class="plan-card @(isCurrent ? "plan-current" : "")">

                @* Top badges *@
                <div class="plan-top-badges">
                    @if (isCurrent)
                    {
                        <span class="badge-current-plan">Current Plan</span>
                    }
                    @if (hasPending)
                    {
                        <span class="badge-pending-plan">Pending</span>
                    }
                </div>

                <div class="plan-name">@plan.PlanName</div>
                <div class="plan-speed-display">
                    <span class="speed-number">@plan.Speed</span>
                </div>

                <div class="plan-price-display">
                    ₱@plan.Price.ToString("N2")
                    <span class="price-period">/month</span>
                </div>

                <ul class="plan-features">
                    @foreach (var feature in features)
                    {
                        <li><i class="bi bi-check2 feature-check"></i> @feature</li>
                    }
                </ul>

                @if (isCurrent)
                {
                    <button class="btn-plan btn-plan-current" disabled>Current Plan</button>
                }
                else if (hasPending)
                {
                    var pendingReq = pendingRequests.First(x => x.PlanId == plan.PlanId && x.Status == "Pending");
                    <button class="btn-plan btn-plan-cancel" @onclick="() => ConfirmCancelRequest(pendingReq)">
                        <i class="bi bi-x-circle me-1"></i> Cancel Request
                    </button>
                }
                else
                {
                    <div class="plan-container">
                        <button class="btn-plan btn-plan-switch"
                                @onclick="() => OpenUpgradeForm(plan)"
                                disabled="@HasPendingBilling">
                            Select to This Plan
                        </button>

                        @if (HasPendingBilling)
                        {
                            <div class="billing-warning-box" style="margin-top: 8px; font-size: 13px; color: #d9534f;">
                                <p style="margin: 0; font-weight: bold;">⚠️ Action Required:</p>
                                <span style="display: block; font-size: 12px; color: #666;">
                                    Please settle your pending payment or wait for Admin approval.
                                </span>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (!plans.Any())
        {
            <p class="text-muted">No plans available.</p>
        }
    </div>
</div>

<!-- UPGRADE REQUEST MODAL -->
@if (showUpgradeForm)
{
    <div class="modal-backdrop-custom" @onclick="CancelUpgrade"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Upgrade to @selectedPlan?.PlanName</h5>
            <button class="btn-close" @onclick="CancelUpgrade"></button>
        </div>

        <div class="mb-3">
            <p class="text-muted">Price: <strong>₱@selectedPlan?.Price.ToString("N2")/Month</strong></p>
            <p class="text-muted small">Your plan will be upgraded after admin approval. Please provide your payment reference number.</p>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Reference Number <span class="text-danger">*</span></label>
            <input class="form-control" placeholder="e.g. GCash ref: 1234567890" @bind="referenceNo" />
            <small class="text-muted">Enter your GCash, bank transfer, or payment reference number.</small>
        </div>

        @if (!string.IsNullOrEmpty(formError))
        {
            <div class="alert alert-danger">@formError</div>
        }

        <div class="d-flex gap-2 mt-4 justify-content-end">
            <button class="btn btn-secondary" @onclick="CancelUpgrade">Cancel</button>
            <button class="btn btn-primary" @onclick="SubmitUpgradeRequest" disabled="@isSubmitting">
                @(isSubmitting ? "Submitting..." : "Submit Request")
            </button>
        </div>
    </div>
}

<!-- CANCEL CONFIRM MODAL -->
@if (showCancelConfirm && cancelTarget != null)
{
    <div class="modal-backdrop-custom" @onclick="() => showCancelConfirm = false"></div>
    <div class="modal-box shadow-lg" style="width:420px;">
        <div class="text-center py-2">
            <div style="font-size:3rem;">⚠️</div>
            <h5 class="fw-bold mt-2">Cancel Request?</h5>
            <p class="text-muted mt-1">Are you sure you want to cancel your upgrade request for <strong>@cancelTarget.PlanName</strong>?</p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="() => showCancelConfirm = false">No, Keep It</button>
            <button class="btn btn-danger px-4" @onclick="ExecuteCancelRequest">Yes, Cancel</button>
        </div>
    </div>
}

@code {
    private List<InternetPlan> plans = new();
    private List<Subscription> currentSubs = new();
    private List<UpgradeRequest> pendingRequests = new();
    private string userId = string.Empty;
    private string message = string.Empty;
    private bool isError = false;
    private bool showUpgradeForm = false;
    private bool isSubmitting = false;
    private string referenceNo = string.Empty;
    private string formError = string.Empty;
    private InternetPlan? selectedPlan;
    private bool showCancelConfirm = false;
    private UpgradeRequest? cancelTarget;
    private List<Billing> billings = new();
    private bool HasPendingBilling =>
    billings.Any(x =>
        (x.Status == "Pending" || x.Status == "Overdue") &&
        !string.IsNullOrWhiteSpace(x.PaymentMethod));

    protected override async Task OnInitializedAsync()
    {

      
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var username = user.Identity.Name ?? "";
            var users = await getAll.ExecuteAsync();
            var currentUser = users?.FirstOrDefault(x => x.Username == username);

            if (currentUser != null)
            {
                userId = currentUser.UserId ?? "";
                var subs = await getSubscription.ExecuteAsync(userId);
                currentSubs = subs?.Where(x => x.Status == "Active").ToList() ?? new();
                billings = (await getBillings.ExecuteAsync(userId))?.ToList() ?? new();

                // Load this user's pending requests from DB
                var allReqs = await getAllRequests.ExecuteAsync();
                pendingRequests = allReqs?
                    .Where(x => x.UserId == userId && x.Status == "Pending")
                    .ToList() ?? new();
            }
        }

        var result = await getPlans.ExecuteAsync();
        plans = result?.Where(x => x.IsActive).ToList() ?? new();
        StateHasChanged();
    }

    void OpenUpgradeForm(InternetPlan plan)
    {
        selectedPlan = plan;
        referenceNo = string.Empty;
        formError = string.Empty;
        showUpgradeForm = true;
    }

    void CancelUpgrade()
    {
        showUpgradeForm = false;
        selectedPlan = null;
        referenceNo = string.Empty;
        formError = string.Empty;
    }

    async Task SubmitUpgradeRequest()
    {
        if (HasPendingBilling)
        {
            formError = "You already have a pending billing payment. Please wait until it is approved.";
            return;
        }

        if (string.IsNullOrWhiteSpace(referenceNo))
        {
            formError = "Reference number is required.";
            return;
        }

        if (selectedPlan == null)
            return;

        isSubmitting = true;
        formError = string.Empty;

        try
        {
            // Check if there is already a pending request for this plan
            var allReqs = await getAllRequests.ExecuteAsync();

            bool duplicatePending = allReqs?.Any(x =>
                x.UserId == userId &&
                x.PlanId == selectedPlan.PlanId &&
                x.Status == "Pending") == true;

            if (duplicatePending)
            {
                formError = "You already have a pending request for this plan.";
                return;
            }

            var request = new UpgradeRequest
            {
                UserId = userId,
                PlanId = selectedPlan.PlanId,
                PlanName = selectedPlan.PlanName,
                ReferenceNo = referenceNo,
                Status = "Pending"
            };

            await createRequest.ExecuteAsync(request);

            // Refresh pending requests
            pendingRequests = (await getAllRequests.ExecuteAsync())?
                .Where(x => x.UserId == userId && x.Status == "Pending")
                .ToList() ?? new();

            showUpgradeForm = false;
            selectedPlan = null;
            referenceNo = string.Empty;

            message = "Upgrade request submitted! Please wait for admin approval.";
            isError = false;
        }
        catch (Exception ex)
        {
            formError = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
    void ConfirmCancelRequest(UpgradeRequest req)
    {
        cancelTarget = req;
        showCancelConfirm = true;

    }

    async Task ExecuteCancelRequest()
    {
        if (cancelTarget == null) return;
        try
        {
            await deleteRequest.ExecuteAsync(cancelTarget);
            pendingRequests.Remove(cancelTarget);
            message = "Upgrade request cancelled.";
            isError = false;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
        cancelTarget = null;
        showCancelConfirm = false;
    }
}
