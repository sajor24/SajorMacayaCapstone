@page "/sub-dashboard"
@layout SubscriberLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Subscriber")]
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll
@inject IGetByUser_Subscription getSubscription
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="dashboard-container">

    <!-- HEADER -->
    <div class="dashboard-header">
        <div>
            <h2>Welcome Back, @fullName 👋</h2>
            <p class="sub-text">Manage your internet subscription and billing.</p>
        </div>

        <button class="logout-btn" @onclick="Logout">
            Logout
        </button>
    </div>

    <!-- CARDS -->
    <div class="cards-grid">

        <!-- USER INFO -->
        <div class="dashboard-card">
            <div class="card-icon">👤</div>
            <h5>Subscriber ID</h5>
            <h3>@userId</h3>
        </div>

        <!-- PLAN -->
        <div class="dashboard-card">
            <div class="card-icon">🚀</div>
            <h5>Current Plan</h5>
            <h3>@(currentSub?.PlanName ?? "No Plan")</h3>
            <p>@planSpeed</p>
        </div>

        <!-- BILLING -->
        <div class="dashboard-card">
            <div class="card-icon">📅</div>
            <h5>Next Billing</h5>
            <h3>@daysUntilBilling Days</h3>
        </div>

    </div>

    <!-- SUBSCRIPTION DETAILS -->
    <div class="subscription-section">

        <div class="section-header">
            <h4>Subscription Details</h4>
        </div>

        <div class="details-grid">

            <div class="detail-box">
                <span>Plan Name</span>
                <strong>@(currentSub?.PlanName ?? "N/A")</strong>
            </div>

            <div class="detail-box">
                <span>Status</span>
                <strong class="status-active">
                    @(currentSub?.Status ?? "Inactive")
                </strong>
            </div>

            <div class="detail-box">
                <span>Start Date</span>
                <strong>
                    @(currentSub?.StartDate.ToString("MMMM dd, yyyy") ?? "N/A")
                </strong>
            </div>

            <div class="detail-box">
                <span>End Date</span>
                <strong>
                    @(currentSub?.EndDate?.ToString("MMMM dd, yyyy") ?? "N/A")
                </strong>
            </div>

        </div>
    </div>

</div>

<style>

    .dashboard-container {
        padding: 30px;
        background: #f4f7fb;
        min-height: 100vh;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }

        .dashboard-header h2 {
            font-weight: 700;
            margin: 0;
        }

    .sub-text {
        color: #6c757d;
        margin-top: 5px;
    }

    .logout-btn {
        background: #dc3545;
        border: none;
        color: white;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

        .logout-btn:hover {
            background: #bb2d3b;
        }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .dashboard-card {
        background: white;
        padding: 25px;
        border-radius: 18px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
        }

    .card-icon {
        font-size: 40px;
        margin-bottom: 10px;
    }

    .dashboard-card h5 {
        color: #6c757d;
        margin-bottom: 10px;
    }

    .dashboard-card h3 {
        font-weight: 700;
        margin-bottom: 5px;
    }

    .subscription-section {
        background: white;
        padding: 25px;
        border-radius: 18px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    .section-header {
        margin-bottom: 20px;
    }

        .section-header h4 {
            font-weight: 700;
        }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
    }

    .detail-box {
        background: #f8f9fc;
        padding: 20px;
        border-radius: 14px;
    }

        .detail-box span {
            display: block;
            color: #6c757d;
            margin-bottom: 8px;
        }

        .detail-box strong {
            font-size: 18px;
        }

    .status-active {
        color: #198754;
    }

    @@media(max-width: 768px) {

        .dashboard-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .logout-btn {
            width: 100%;
        }
    }

</style>

@code {
    private string fullName = "";
    private string userId = "";
    private string planSpeed = "—";
    private int daysUntilBilling = 0;
    private Subscription? currentSub;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var username = user.Identity.Name ?? "";
            var users = await getAll.ExecuteAsync();
            var currentUser = users?.FirstOrDefault(x => x.Username == username);

            if (currentUser != null)
            {
                fullName = $"{currentUser.FirstName} {currentUser.LastName}";
                userId = currentUser.UserId ?? "";

                var subs = await getSubscription.ExecuteAsync(currentUser.UserId ?? "");
                currentSub = subs?.FirstOrDefault(x => x.Status == "Active");

                if (currentSub?.EndDate != null)
                {
                    DateTime today = DateTime.Now;
                    DateTime nextBilling = today.AddMonths(1);

                    daysUntilBilling = (nextBilling - today).Days;
                }
            }
        }
    }

    private async Task Logout()
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to logout?");

        if (confirm)
            Nav.NavigateTo("/account/logout", forceLoad: true);
    }
}