@page "/sub-dashboard"
@layout SubscriberLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Subscriber")]
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll
@inject IGetByUser_Subscription getSubscription
@inject IGetByUser_Billing getBillings
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="dashboard-container">

    <!-- TOPNAV -->
    <div class="dashboard-topnav">
        <div>
            <h2>Welcome Back, @fullName</h2>
            <p>Manage your internet subscription and billing.</p>
        </div>
    </div>

    <!-- CARDS -->
    <div class="dashboard-content">
    <div class="cards-grid">

        <!-- USER INFO -->
        <div class="dashboard-card">
            <div class="card-icon">👤</div>
            <h5>Subscriber ID</h5>
            <h3>@userId</h3>
        </div>

        <!-- PLAN -->
        <div class="dashboard-card">
            <i class="bi bi-card-checklist card-checklist"></i>
            <h5>Current Plan</h5>
            <h3>@(currentSub?.PlanName ?? "No Plan")</h3>
        </div>

        <!-- BILLING -->
        <div class="dashboard-card">
            <div class="card-icon">📅</div>
            <h5>Next Billing</h5>
            <h3>@(nextDueDate.HasValue ? nextDueDate.Value.ToString("MMM dd, yyyy") : "N/A")</h3>
        </div>

    </div>

    <!-- SUBSCRIPTION DETAILS -->
    <div class="subscription-section">

        <div class="section-header">
            <h4>Subscription Details</h4>
        </div>

        <div class="details-grid">

            <div class="detail-box">
                <span>Plan Name</span>
                <strong>@(currentSub?.PlanName ?? "N/A")</strong>
            </div>

            <div class="detail-box">
                <span>Status</span>
                <strong class="@GetStatusCss()">
                    @GetStatusText()
                </strong>
            </div>

            <div class="detail-box">
                <span>Start Date</span>
                <strong>
                    @(currentSub?.StartDate.ToString("MMMM dd, yyyy") ?? "N/A")
                </strong>
            </div>

            <div class="detail-box">
                <span>End Date</span>
                <strong>
                    @(nextDueDate?.ToString("MMMM dd, yyyy") ?? currentSub?.EndDate?.ToString("MMMM dd, yyyy") ?? "N/A")
                </strong>
            </div>

        </div>
    </div>

    </div>
</div>

@code {
    private string fullName = "";
    private string userId = "";
    private Subscription? currentSub;
    private DateTime? nextDueDate;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var username = user.Identity.Name ?? "";
            var users = await getAll.ExecuteAsync();
            var currentUser = users?.FirstOrDefault(x => x.Username == username);

            if (currentUser != null)
            {
                fullName = $"{currentUser.FirstName} {currentUser.LastName}";
                userId = currentUser.UserId ?? "";

                var subs = await getSubscription.ExecuteAsync(currentUser.UserId ?? "");
                currentSub = subs?.FirstOrDefault(x => x.Status == "Active");

                // Get due date from the earliest unpaid bill
                var billResult = await getBillings.ExecuteAsync(userId);
                var unpaidBill = billResult?
                    .Where(x => x.Status != "Paid" && x.Status != "Cancelled")
                    .OrderBy(x => x.DueDate ?? DateTime.MaxValue)
                    .FirstOrDefault();

                nextDueDate = unpaidBill?.DueDate ?? currentSub?.EndDate;
            }
        }
    }

    string GetStatusText()
    {
        if (currentSub == null) return "Inactive";
        if (currentSub.Status == "Inactive") return "Inactive";
        if (currentSub.EndDate.HasValue && currentSub.EndDate.Value.Date < DateTime.Today)
            return "Due Date";
        return "Active";
    }

    string GetStatusCss()
    {
        return GetStatusText() switch
        {
            "Active"   => "status-active",
            "Due Date" => "status-duedate",
            _          => "status-inactive"
        };
    }

}