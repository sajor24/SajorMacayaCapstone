@page "/staff-support"
@layout StaffLayout
@using Microsoft.AspNetCore.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Staff")]
@inject IGetAll_ServiceRequest getAll
@inject IUpdate_ServiceRequest updateRequest
@inject IGetAll_User getUsers

<div class="sub-wrapper">

    <div class="topnav">
        <div class="topnav-left">
            <h2>Service Requests</h2>
            <p>Manage and resolve subscriber issues</p>
        </div>
    </div>

    <div class="page-content">

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
                @message
                <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
            </div>
        }

        <!-- SUMMARY -->
        <div class="summary-cards mb-4">
            <div class="summary-card">
                <div class="summary-label">Total</div>
                <div class="summary-value">@requests.Count</div>
            </div>
            <div class="summary-card blue">
                <div class="summary-label">Open</div>
                <div class="summary-value">@requests.Count(x => x.Status == "Open")</div>
            </div>
            <div class="summary-card orange">
                <div class="summary-label">In Progress</div>
                <div class="summary-value">@requests.Count(x => x.Status == "In Progress")</div>
            </div>
            <div class="summary-card green">
                <div class="summary-label">Resolved</div>
                <div class="summary-value">@requests.Count(x => x.Status == "Resolved")</div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="table-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="fw-semibold" style="color:#111;">All Requests</div>
                <div class="search-box">
                    <i class="bi bi-search text-muted"></i>
                    <input placeholder="Search..." @bind="searchText" @bind:event="oninput" />
                </div>
            </div>
            <div class="table-responsive">
                <table class="sub-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Subscriber</th>
                            <th>Issue Type</th>
                            <th>Priority</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Assigned To</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in filteredRequests)
                        {
                            <tr>
                                <td class="fw-semibold">@req.RequestId</td>
                                <td>
                                    <div class="fw-semibold">@req.FirstName @req.LastName</div>
                                    <small class="text-muted">@req.ContactNumber</small>
                                </td>
                                <td>@req.IssueType</td>
                                <td><span class="priority-badge @GetPriorityClass(req.Priority)">@req.Priority</span></td>
                                <td class="text-muted" style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@req.Description</td>
                                <td><span class="status-badge @GetStatusClass(req.Status)">@req.Status</span></td>
                                <td class="text-muted">@(req.AssignedTo ?? "—")</td>
                                <td class="text-muted">@req.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <button class="action-btn edit-btn" title="Update" @onclick="() => OpenUpdate(req)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (!filteredRequests.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">No service requests found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- UPDATE MODAL -->
@if (showModal && selected != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModal"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Update Request — @selected.RequestId</h5>
            <button class="btn-close" @onclick="CloseModal"></button>
        </div>

        <div class="mb-3 p-3" style="background:#f8f9fa; border-radius:10px;">
            <div class="fw-semibold">@selected.IssueType</div>
            <div class="text-muted small mt-1">@selected.Description</div>
            <div class="text-muted small mt-1">Subscriber: @selected.FirstName @selected.LastName</div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Status</label>
                <select class="form-select" @bind="editStatus">
                    <option value="Open">Open</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Resolved">Resolved</option>
                    <option value="Closed">Closed</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Assign To (Technician ID)</label>
                <input class="form-control" placeholder="e.g. TECH001" @bind="editAssignedTo" />
            </div>
        </div>

        <div class="d-flex gap-2 mt-4 justify-content-end">
            <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveUpdate">Save Changes</button>
        </div>
    </div>
}

<style>
    .sub-wrapper { min-height: 100vh; background: #f5f6fa; display: flex; flex-direction: column; }
    .topnav { background: white; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #4f46e5; }
    .topnav-left h2 { font-size: 1.2rem; font-weight: 700; color: #111; margin: 0; }
    .topnav-left p { font-size: .82rem; color: #4f46e5; margin: 0; }
    .page-content { padding: 32px; flex: 1; }

    .summary-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .summary-card { background: white; border-radius: 14px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,.05); border-left: 4px solid #4f46e5; }
    .summary-card.blue   { border-left-color: #3b82f6; }
    .summary-card.orange { border-left-color: #f59e0b; }
    .summary-card.green  { border-left-color: #22c55e; }
    .summary-label { font-size: .8rem; color: #888; margin-bottom: 4px; }
    .summary-value { font-size: 1.5rem; font-weight: 800; color: #111; }

    .table-card { background: white; border-radius: 16px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .sub-table { width: 100%; border-collapse: collapse; }
    .sub-table thead tr { border-bottom: 2px solid #f3f4f6; }
    .sub-table th { text-align: left; padding: 10px 12px; font-size: .82rem; color: #888; font-weight: 600; white-space: nowrap; }
    .sub-table td { padding: 14px 12px; border-bottom: 1px solid #f3f4f6; font-size: .88rem; color: #333; vertical-align: middle; }
    .sub-table tbody tr:hover { background: #fafafa; }

    .search-box { display: flex; align-items: center; gap: 8px; border: 1px solid #e5e7eb; border-radius: 10px; padding: 8px 14px; width: 240px; background: white; }
    .search-box input { border: none; outline: none; font-size: .9rem; width: 100%; }

    .status-badge { padding: 4px 12px; border-radius: 20px; font-size: .72rem; font-weight: 700; }
    .badge-open       { background: #dbeafe; color: #1d4ed8; }
    .badge-inprogress { background: #ede9fe; color: #7c3aed; }
    .badge-resolved   { background: #d1fae5; color: #059669; }
    .badge-closed     { background: #f3f4f6; color: #6b7280; }

    .priority-badge { padding: 4px 12px; border-radius: 20px; font-size: .72rem; font-weight: 700; }
    .priority-low      { background: #d1fae5; color: #059669; }
    .priority-medium   { background: #fef3c7; color: #d97706; }
    .priority-high     { background: #fee2e2; color: #dc2626; }
    .priority-critical { background: #dc2626; color: white; }

    .action-btn { border: 1px solid #e5e7eb; background: white; border-radius: 8px; padding: 6px 10px; cursor: pointer; transition: .2s; font-size: .9rem; }
    .edit-btn:hover { background: #f0f0ff; border-color: #4f46e5; color: #4f46e5; }

    .modal-backdrop-custom { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1040; }
    .modal-box { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); background: white; border-radius: 16px; padding: 2rem; width: 520px; max-width: 95vw; z-index: 1050; }

    @@media (max-width: 800px) {
        .summary-cards { grid-template-columns: repeat(2, 1fr); }
        .page-content { padding: 70px 12px 12px; }
    }
</style>

@code {
    private List<ServiceRequest> requests = new();
    private ServiceRequest? selected;
    private string editStatus = string.Empty;
    private string editAssignedTo = string.Empty;
    private string searchText = string.Empty;
    private string message = string.Empty;
    private bool isError = false;
    private bool showModal = false;

    private IEnumerable<ServiceRequest> filteredRequests =>
        string.IsNullOrWhiteSpace(searchText) ? requests
        : requests.Where(x =>
            (x.RequestId   != null && x.RequestId.Contains(searchText,   StringComparison.OrdinalIgnoreCase)) ||
            (x.FirstName   != null && x.FirstName.Contains(searchText,   StringComparison.OrdinalIgnoreCase)) ||
            (x.LastName    != null && x.LastName.Contains(searchText,    StringComparison.OrdinalIgnoreCase)) ||
            (x.IssueType   != null && x.IssueType.Contains(searchText,   StringComparison.OrdinalIgnoreCase)) ||
            (x.Status      != null && x.Status.Contains(searchText,      StringComparison.OrdinalIgnoreCase))
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();
    }

    async Task LoadRequests()
    {
        try
        {
            var result = await getAll.ExecuteAsync();
            requests = result?.ToList() ?? new();
        }
        catch { }
    }

    void OpenUpdate(ServiceRequest req)
    {
        selected       = req;
        editStatus     = req.Status ?? "Open";
        editAssignedTo = req.AssignedTo ?? string.Empty;
        showModal      = true;
    }

    void CloseModal()
    {
        showModal = false;
        selected  = null;
    }

    async Task SaveUpdate()
    {
        if (selected == null) return;
        try
        {
            selected.Status     = editStatus;
            selected.AssignedTo = editAssignedTo;
            selected.ResolvedAt = editStatus is "Resolved" or "Closed" ? DateTime.Now : null;
            await updateRequest.ExecuteAsync(selected);
            await LoadRequests();
            message = "Request updated.";
            isError = false;
            CloseModal();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }

    string GetStatusClass(string? s) => s switch
    {
        "Open"        => "badge-open",
        "In Progress" => "badge-inprogress",
        "Resolved"    => "badge-resolved",
        "Closed"      => "badge-closed",
        _             => "badge-open"
    };

    string GetPriorityClass(string? p) => p switch
    {
        "Low"      => "priority-low",
        "Medium"   => "priority-medium",
        "High"     => "priority-high",
        "Critical" => "priority-critical",
        _          => "priority-medium"
    };
}
