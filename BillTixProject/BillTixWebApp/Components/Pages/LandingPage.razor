@page "/"
@layout EmptyLayout
@inject NavigationManager _Nav
@using BillTixWebApp.Components.Layout
@using Domain.ICommands
@using Domain.Models
@inject IGetAll_InternetPlan getAll

<PageTitle>Palma IMTECH - FBR Internet</PageTitle>


<div class="navbar">
    <a href="#" class="brand">
        <div class="brand-icon-wrap">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Wifi signal arcs -->
                <path d="M5 12.55a11 11 0 0 1 14.08 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
                <path d="M1.42 9a16 16 0 0 1 21.16 0" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round"/>
                <path d="M8.53 16.11a6 6 0 0 1 6.95 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
                <circle cx="12" cy="20" r="1.5" fill="white"/>
            </svg>
        </div>
        <div class="brand-texts">
            <span class="brand-name">Palma <span class="brand-imtech">IMTECH</span></span>
            <span class="brand-sub">FBR INTERNET</span>
        </div>
    </a>
    <ul class="nav-links @(mobileNavOpen ? "open" : "")">
        <li><a href="#pricing" class="nav-link-item" @onclick="CloseMobileNav">Plans</a></li>
        <li><a href="#roles" class="nav-link-item" @onclick="CloseMobileNav">Portals</a></li>
        <li><a href="#contact" class="nav-link-item" @onclick="CloseMobileNav">Contact</a></li>
    </ul>
    <div class="nav-right">
        <button class="nav-cta" @onclick='() => _Nav.NavigateTo("/login")'>Login</button>
        <button class="hamburger" @onclick="ToggleMobileNav">
            <span></span><span></span><span></span>
        </button>
    </div>
</div>

<div class="hero">
    <div class="hero-copy">
        <div class="eyebrow reveal"><span class="dot"></span> FBR Fiber Internet</div>
        <h1 class="reveal delay-1">Stay Connected<br />with <span class="accent">Fast &amp; Reliable</span><br />Internet.</h1>
        <p class="reveal delay-2">Palma iMTECH Solutions and Data Provider — delivering high-speed FBR internet to your home and business. Manage your billing anytime, anywhere.</p>
        <div class="hero-actions reveal delay-2">
            <button class="hero-btn" @onclick='() => _Nav.NavigateTo("/login")'>Get Started</button>
            <a class="hero-btn-outline" href="#pricing">View Plans</a>
        </div>
    </div>
    <svg class="signal-art" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <linearGradient id="sg" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#059669" />
                <stop offset="100%" stop-color="#34d399" />
            </linearGradient>
        </defs>
        <g fill="none" stroke="url(#sg)" stroke-width="2.5" stroke-linecap="round">
            <path d="M 60 460 A 400 400 0 0 1 460 60" />
            <path d="M 110 460 A 350 350 0 0 1 460 110" />
            <path d="M 165 460 A 295 295 0 0 1 460 165" />
            <path d="M 225 460 A 235 235 0 0 1 460 225" />
            <path d="M 290 460 A 170 170 0 0 1 460 290" />
        </g>
        <circle cx="460" cy="460" r="10" fill="#059669" />
    </svg>
</div>

<div class="stats-bar reveal">
    <div class="stat-item"><div class="stat-val">99.9%</div><div class="stat-lbl">Uptime</div></div>
    <div class="stat-item"><div class="stat-val">24/7</div><div class="stat-lbl">Support</div></div>
    <div class="stat-item"><div class="stat-val">FBR</div><div class="stat-lbl">Fiber Technology</div></div>
    <div class="stat-item"><div class="stat-val">Fast</div><div class="stat-lbl">High Speed Internet</div></div>
</div>

<div class="pricing-section" id="pricing">
    <h2 class="reveal">Our Internet Plans</h2>
    <p class="sub reveal delay-1">Flexible plans for every need. No hidden fees, no surprises.</p>
    <div class="pricing-cards">
        @if (plans.Count == 0)
        {
            <p class="sub">No plans available right now. Please check back soon.</p>
        }
        else
        {
            @for (int i = 0; i < plans.Count; i++)
            {
                var item = plans[i];
                var delay = (0.1 + (i * 0.1)).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
                <div class="pricing-card reveal" style="transition-delay:@(delay)s">
                    <h3>@item.PlanName</h3>
                    <div class="speed">@item.Speed</div>
                    <div class="price">&#8369;@item.Price.ToString("N2")<span>/mo</span></div>
                    <ul>
                        @foreach (var f in (item.Features ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <li>@f.Trim()</li>
                        }
                    </ul>
                </div>
            }
        }
    </div>
</div>

<div class="roles-section" id="roles">
    <h2 class="reveal">Login to Your Portal</h2>
    <p class="sub reveal delay-1">Select your role to access your dashboard.</p>
    <div class="role-cards">
        <div class="role-card reveal delay-1">
            <div class="icon">👤</div>
            <h4>Subscriber</h4>
            <div class="subtitle">My Account</div>
            <p>View and pay your bills, track payment history, and manage your subscription.</p>
            <button class="btn-login" @onclick='() => _Nav.NavigateTo("/login?role=Subscriber")'>Login as Subscriber</button>
        </div>
        <div class="role-card reveal delay-2">
            <div class="icon">👥</div>
            <h4>Staff</h4>
            <div class="subtitle">Manage Accounts</div>
            <p>Assist subscribers, process payments, and handle customer concerns.</p>
            <button class="btn-login" @onclick='() => _Nav.NavigateTo("/login?role=Staff")'>Login as Staff</button>
        </div>
        <div class="role-card reveal delay-3">
            <div class="icon">🛡️</div>
            <h4>Administrator</h4>
            <div class="subtitle">Full Access</div>
            <p>Manage all accounts, billing, financial reports, and system configuration.</p>
            <button class="btn-login" @onclick='() => _Nav.NavigateTo("/login?role=Admin")'>Login as Admin</button>
        </div>
        <div class="role-card reveal delay-4">
            <div class="icon">🔧</div>
            <h4>Technician</h4>
            <div class="subtitle">Field Operations</div>
            <p>View assigned service requests and manage field installations and repairs.</p>
            <button class="btn-login" @onclick='() => _Nav.NavigateTo("/login?role=Technician")'>Login as Technician</button>
        </div>
    </div>
</div>

<div class="footer" id="contact">
    <div class="footer-brand">Palma IMTECH Solutions and Data Provider</div>
    <h3>FBR Internet</h3>
    <p>Fast. Reliable. Always connected.</p>
    <p style="margin-top:16px; font-size:.8rem;">&#169; @DateTime.Now.Year Palma iMTECH. All rights reserved.</p>
</div>

<script>
    (() => {
        const io = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
        }, { threshold: 0.1 });
        function obs(root) { root.querySelectorAll('.reveal:not(.show)').forEach(el => io.observe(el)); }
        obs(document);
        new MutationObserver(mutations => mutations.forEach(m => m.addedNodes.forEach(n => {
            if (n.nodeType !== 1) return;
            if (n.matches && n.matches('.reveal')) io.observe(n);
            if (n.querySelectorAll) obs(n);
        }))).observe(document.body, { childList: true, subtree: true });
    })();
</script>

@code {
    private List<InternetPlan> plans = new();
    private bool mobileNavOpen = false;

    protected override async Task OnInitializedAsync()
    {
        var result = await getAll.ExecuteAsync();
        plans = result?.Where(x => x.IsActive).ToList() ?? new();
    }

    void ToggleMobileNav() => mobileNavOpen = !mobileNavOpen;
    void CloseMobileNav() => mobileNavOpen = false;
}
