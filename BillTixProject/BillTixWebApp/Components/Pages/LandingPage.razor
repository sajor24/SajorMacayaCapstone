@page "/"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager _Nav
@using BillTixWebApp.Components.Layout

<PageTitle>BILLTIX</PageTitle>

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        background: #191825;
    }

    .navbar {
        padding: 18px 40px;
        background: #221c36;
        color: #f1eaff;
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 2px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    }

    .hero {
        background: linear-gradient(135deg, #191825 60%, #302b63 100%);
        color: #f1eaff;
        text-align: center;
        padding: 80px 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    }

        .hero h1 {
            font-size: 2.7rem;
            font-weight: 800;
            letter-spacing: 1px;
            margin-bottom: 12px;
            color: #fff;
        }

        .hero p {
            font-size: 1.12rem;
            opacity: 0.83;
            color: #b4baff;
        }

    .hero-btn {
        margin-top: 28px;
        padding: 14px 36px;
        background: linear-gradient(90deg, #7367f0 60%, #28c76f 100%);
        color: #fff;
        border: none;
        border-radius: 30px;
        font-size: 1.01rem;
        cursor: pointer;
        transition: background 0.2s, box-shadow 0.2s;
        font-weight: 700;
        box-shadow: 0 2px 16px rgba(82,73,202,0.13);
    }

        .hero-btn:hover {
            background: linear-gradient(90deg, #4739ab 40%, #26a04f 100%);
            box-shadow: 0 4px 24px rgba(72,110,190,0.18);
        }

    .pricing-section {
        text-align: center;
        padding: 60px 20px 40px;
        background: #222030;
    }

        .pricing-section h2 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 8px;
            color: #d1c7ff;
            letter-spacing: 1px;
        }

        .pricing-section .sub {
            color: #b5aad5;
            margin-bottom: 36px;
            font-size: 0.99rem;
        }

    .pricing-cards {
        display: flex;
        justify-content: center;
        gap: 24px;
        flex-wrap: wrap;
    }

    .pricing-card {
        background: rgba(37,37,60,0.95);
        border: 1.5px solid #3b3755;
        border-radius: 17px;
        padding: 30px 24px;
        width: 230px;
        text-align: left;
        box-shadow: 0 4px 20px rgba(22,14,40,0.15);
        transition: transform 0.2s, border 0.21s;
    }

        .pricing-card:hover {
            transform: translateY(-6px) scale(1.03);
            border: 1.5px solid #7367f0;
        }

        .pricing-card h3 {
            font-size: 1rem;
            color: #88b4ff;
            font-weight: 700;
        }

        .pricing-card .speed {
            color: #28c76f;
            font-weight: 700;
            font-size: 1.01rem;
            margin-bottom: 12px;
            letter-spacing: .5px;
            background: rgba(76,224,164,0.08);
            padding: 2px 9px;
            border-radius: 10px;
            display: inline-block;
        }

        .pricing-card .price {
            font-size: 1.55rem;
            font-weight: 800;
            color: #f1eaff;
            margin-bottom: 16px;
        }

            .pricing-card .price span {
                font-size: 0.86rem;
                font-weight: 400;
                color: #b2acf4;
            }

        .pricing-card ul {
            list-style: none;
            padding: 0;
        }

            .pricing-card ul li {
                font-size: 0.93rem;
                color: #bebef7;
                padding: 4px 0;
                font-weight: 500;
                letter-spacing: .4px;
            }

                .pricing-card ul li::before {
                    content: "✓ ";
                    color: #7367f0;
                    font-weight: bold;
                }

    .roles-section {
        padding: 50px 20px;
        background: #191825;
        text-align: center;
    }

        .roles-section h2 {
            font-size: 1.7rem;
            font-weight: 700;
            margin-bottom: 8px;
            color: #ebe8fd;
            letter-spacing: 1px;
        }

        .roles-section .sub {
            color: #bcbfe0;
            margin-bottom: 36px;
            font-size: 0.97rem;
        }

    .role-cards {
        display: flex;
        justify-content: center;
        gap: 22px;
        flex-wrap: wrap;
    }

    .role-card {
        background: rgba(30,28,42,0.90);
        border: 1.5px solid #332f48;
        border-radius: 16px;
        padding: 28px 20px;
        width: 210px;
        text-align: left;
        box-shadow: 0 2px 14px rgba(0,0,0,0.09);
        transition: transform 0.20s, border 0.21s;
    }

        .role-card:hover {
            transform: translateY(-6px) scale(1.04);
            border: 1.5px solid #28c76f;
        }

        .role-card .icon {
            font-size: 2rem;
            margin-bottom: 12px;
            color: #e7e7ff;
            text-shadow: 0 4px 20px rgba(68,110,222,0.16);
        }

        .role-card h4 {
            font-size: 1.08rem;
            font-weight: 700;
            margin-bottom: 4px;
            color: #b8aaff;
        }

        .role-card .subtitle {
            font-size: 0.83rem;
            color: #28c76f;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .role-card p {
            font-size: 0.81rem;
            color: #b5b1df;
            margin-bottom: 18px;
            line-height: 1.6;
        }

    .btn-login {
        background: linear-gradient(90deg, #7367f0 70%, #28c76f 100%);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 0;
        width: 100%;
        cursor: pointer;
        font-size: 0.94rem;
        font-weight: 700;
        box-shadow: 0 2px 14px rgba(82,73,202,0.11);
        transition: background 0.19s, box-shadow 0.21s;
    }

        .btn-login:hover {
            background: linear-gradient(90deg, #4339ab 45%, #17e398 100%);
            box-shadow: 0 4px 22px rgba(44,80,120,0.13);
        }

    .footer {
        background: linear-gradient(135deg, #181728 80%, #221c3a 100%);
        color: #cec8f9;
        text-align: center;
        padding: 52px 20px;
    }

        .footer h3 {
            font-size: 1.62rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: #fff;
            letter-spacing: 1px;
        }

        .footer p {
            font-size: 0.95rem;
            opacity: 0.78;
            margin-bottom: 26px;
            color: #b3b9d9;
        }

    .footer-btn {
        padding: 13px 32px;
        background: linear-gradient(90deg, #7367f0 70%, #28c76f 100%);
        color: #fff;
        border: none;
        border-radius: 30px;
        font-size: 1.01rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.19s, box-shadow 0.19s;
        box-shadow: 0 2px 14px rgba(82,73,202,0.10);
    }

        .footer-btn:hover {
            opacity: 0.88;
            box-shadow: 0 4px 20px rgba(82,73,202,0.18);
        }

    /* Responsive for mobile */
    @@media (max-width: 700px) {
        .pricing-cards, .role-cards {
            flex-direction: column;
            gap: 16px;
            align-items: center;
        }

        .hero {
            padding: 50px 12px;
        }

        .footer {
            padding: 34px 8px;
        }
    }
</style>
<!-- Navbar -->
<div class="navbar">BILLTIX</div>

<!-- Hero -->
<div class="hero">
    <h1>Welcome to BILLTIX</h1>
    <p>Fast, reliable internet service for everyone.</p>
    <button class="hero-btn" @onclick='() => _Nav.NavigateTo("/login")'>Get Started</button>
</div>

<!-- Pricing -->
<div class="pricing-section">
    <h2>Simple, Transparent Pricing</h2>
    <p class="sub">Choose the perfect plan for your needs. No hidden fees, cancel anytime.</p>
    <div class="pricing-cards">
        <div class="pricing-card">
            <h3>Upto</h3>
            <div class="speed">150 MBPS</div>
            <div class="price">₱1,000.00<span>/Month</span></div>
            <ul>
                <li>Waived Installation Fee</li>
                <li>Unlimited Data</li>
                <li>Free Router</li>
            </ul>
        </div>
        <div class="pricing-card">
            <h3>Upto</h3>
            <div class="speed">200 MBPS</div>
            <div class="price">₱1,300.00<span>/Month</span></div>
            <ul>
                <li>Waived Installation Fee</li>
                <li>Unlimited Data</li>
                <li>Free Router</li>
            </ul>
        </div>
        <div class="pricing-card">
            <h3>Upto</h3>
            <div class="speed">250 MBPS</div>
            <div class="price">₱1,500.00<span>/Month</span></div>
            <ul>
                <li>Waived Installation Fee</li>
                <li>Unlimited Data</li>
                <li>Free Router</li>
            </ul>
        </div>
    </div>
</div>

<!-- Roles -->
<div class="roles-section">
    <h2>Login to Your Portal</h2>
    <p class="sub">Select your role to access your dashboard.</p>
    <div class="role-cards">
        <div class="role-card">
            <div class="icon">👤</div>
            <h4>Subscriber</h4>
            <div class="subtitle">Access your account</div>
            <p>View billing statements, pay bills online, and track your payment history.</p>
            <button class="btn-login" @onclick='() => _Nav.NavigateTo("/login?role=Subscriber")'>Login as Subscriber</button>
        </div>
        <div class="role-card">
            <div class="icon">👥</div>
            <h4>Staff</h4>
            <div class="subtitle">Manage accounts</div>
            <p>View your billing statements, pay bills online, and track your payment history.</p>
            <button class="btn-login" @onclick='() => _Nav.NavigateTo("/login?role=Staff")'>Login as Staff</button>
        </div>
        <div class="role-card">
            <div class="icon">🛡️</div>
            <h4>Administrator</h4>
            <div class="subtitle">Full system access</div>
            <p>Manage subscriber accounts, configure billing rates, and process payments.</p>
            <button class="btn-login" @onclick='() => _Nav.NavigateTo("/login?role=Admin")'>Login as Admin</button>
        </div>
        <div class="role-card">
            <div class="icon">🔧</div>
            <h4>Technician</h4>
            <div class="subtitle">Field operations</div>
            <p>Manage subscriber accounts, configure billing rates, and process payments.</p>
            <button class="btn-login" @onclick='() => _Nav.NavigateTo("/login?role=Technician")'>Login as Technician</button>
        </div>
    </div>
</div>

<!-- Footer -->
<div class="footer">
    <h3>Ready to Get Started?</h3>
    <p>Join thousands of satisfied customers enjoying fast, reliable internet service.</p>
    <button class="footer-btn" @onclick='() => _Nav.NavigateTo("/login")'>Get Started Now</button>
</div>
