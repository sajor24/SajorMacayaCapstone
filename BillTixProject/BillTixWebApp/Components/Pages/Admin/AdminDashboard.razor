@page "/admin-dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager _Nav
@layout AdminLayout
@using BillTixWebApp.Components.Layout
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAll
@inject IGetRecent_Billing getRecentBilling
@inject IGetAll_Billing getAllBilling

<PageTitle>Admin Dashboard - BillTix</PageTitle>


<div class="wrapper">

    <div class="topnav">
        <div class="topnav-left">
            <h2>Welcome, @username</h2>
            <p>Manage your internet billing system</p>
        </div>
        <div class="topnav-right">
            <button class="notif-btn">
                🔔
                <span class="notif-dot"></span>
            </button>
            <div class="avatar">👤</div>
        </div>
    </div>

    <div class="content">
        <h1>Dashboard</h1>

        <div class="stat-cards">
            <div class="stat-card">
                <div>
                    <div class="label">Total Subscribers</div>
                    <div class="value">@totalSubscribers</div>
                    <div class="trend">Active accounts</div>
                </div>
                <div class="stat-icon icon-blue">👥</div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="label">Total Revenue</div>
                    <div class="value">₱@totalRevenue.ToString("N2")</div>
                    <div class="trend">Paid billing total</div>
                </div>
                <div class="stat-icon icon-green">💲</div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="label">Pending Bills</div>
                    <div class="value">@pendingBills</div>
                </div>
                <div class="stat-icon icon-orange">🪪</div>
            </div>
        </div>

        <div class="bottom-grid">

            <div class="card">
                <div class="card-title">Recent Transactions</div>
                <div class="card-sub">Latest payment activities</div>
                <table>
                    <thead>
                        <tr>
                            <th>Transaction ID</th>
                            <th>Subscriber</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var txn in transactions)
                        {
                            <tr>
                                <td>@txn.Id</td>
                                <td>@txn.Subscriber</td>
                                <td>@txn.Amount</td>
                                <td>@txn.Method</td>
                                <td><span class="badge">@txn.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="card">
                <div class="card-title">🔔 Notifications</div>
                <div class="card-sub">Recent system alerts</div>

                @foreach (var notif in notifications)
                {
                    <div class="notif-item">
                        <p>@notif.Message</p>
                        <span>@notif.Time</span>
                    </div>
                }

                <button class="view-all-btn">View All Notifications</button>
            </div>

        </div>
    </div>
</div>

@code {
    private string username = "Admin";
    private int totalSubscribers = 0;
    private decimal totalRevenue = 0;
    private int pendingBills = 0;
    private List<Billing> recentBillings = new();

    private record Transaction(string Id, string Subscriber, string Amount, string Method, string Status);
    private record Notification(string Message, string Time);

    private List<Transaction> transactions = new()
    {
        new("TXN001", "Juan Dela Cruz",  "₱1,499", "GCash", "completed"),
        new("TXN002", "Maria Santos",    "₱2,499", "GCash", "completed"),
        new("TXN003", "Ana Garcia",      "₱3,999", "GCash", "completed"),
        new("TXN004", "Pedro Reyes",     "₱999",   "GCash", "completed"),
        new("TXN005", "Juan Dela Cruz",  "₱1,499", "GCash", "completed"),
    };

    private List<Notification> notifications = new()
    {
        new("New subscriber registration",          "2 minutes ago"),
        new("Payment received from Juan Dela Cruz", "15 minutes ago"),
        new("Overdue bill for Pedro Reyes",         "1 hour ago"),
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
            username = user.Identity.Name ?? "Admin";

        var users = await getAll.ExecuteAsync();
        totalSubscribers = users?.Count(x => x.Role == "Subscriber") ?? 0;

        try
        {
            var allBillings = await getAllBilling.ExecuteAsync();
            if (allBillings != null)
            {
                totalRevenue = allBillings.Where(x => x.Status == "Paid").Sum(x => x.Amount);
                pendingBills = allBillings.Count(x => x.Status == "Pending");
            }

            var recent = await getRecentBilling.ExecuteAsync(5);
            recentBillings = recent?.ToList() ?? new();
        }
        catch
        {
            // Billing table may not have data yet
        }
    }


}