@page "/admin-subscriber"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@inject IDelete_User delete
@inject IGetAll_User getAll
@inject ICreate_User create
@inject IUpdate_User update
@inject IGetAll_Subscription getAllSubscription
@inject ICreate_Subscription createSubscription
@inject IUpdate_Subscription updateSubscription
@inject IDelete_Subscription deleteSubscription
@inject IGetAll_InternetPlan getAllPlans
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "Admin")]

<div class="sub-wrapper">

    <!-- TOP NAV -->
    <div class="topnav">
        <div class="topnav-left">
            <h2>Welcome, @username</h2>
            <p>Manage your internet billing system</p>
        </div>
        <div class="topnav-right">
            <div class="avatar">👤</div>
        </div>
    </div>

    <!-- PAGE CONTENT -->
    <div class="page-content">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0" style="color:#111;">Subscribers</h3>
            <button class="btn btn-primary d-flex align-items-center gap-2 px-4" @onclick="OpenAddForm">
                <i class="bi bi-person-plus-fill"></i> Add Subscriber
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible mb-3">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }

        <div class="table-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <div class="fw-semibold" style="color:#111;">All Subscribers</div>
                    <small class="text-muted">Total: @users.Count subscriber@(users.Count != 1 ? "s" : "")</small>
                </div>
                <div class="search-box">
                    <i class="bi bi-search text-muted"></i>
                    <input placeholder="Search subscribers..."
                           @bind="searchText"
                           @bind:event="oninput" />
                </div>
            </div>

            <div class="table-responsive">
                <table class="sub-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Plan</th>
                            <th>Status</th>
                            <th>Next Billing</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in filteredUsers)
                        {
                            var sub = GetSubscription(item.UserId);
                            <tr>
                                <td class="fw-semibold">@item.UserId</td>
                                <td>@item.FirstName @item.LastName</td>
                                <td class="text-muted">@item.Email</td>
                                <td class="text-muted">@item.ContactNumber</td>
                                <td>@(sub?.PlanName ?? "—")</td>
                                <td>
                                    @if (sub != null)
                                    {
                                        <span class="status-badge @(sub.Status == "Active" ? "badge-active" : "Over Due")">
                                            @sub.Status
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-muted">@(sub?.EndDate?.ToString("M/d/yyyy") ?? "—")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button class="action-btn edit-btn" title="Edit" @onclick="() => EditUser(item)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="action-btn delete-btn" title="Delete" @onclick="() => Delete(item.UserId)">
                                            <i class="bi bi-power"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!filteredUsers.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">No subscribers found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- DELETE CONFIRMATION MODAL -->
@if (showDeleteConfirm)
{
    <div class="modal-backdrop-custom" @onclick="CancelDelete"></div>
    <div class="modal-box shadow-lg" style="width:420px;">
        <div class="text-center py-2">
            <div style="font-size:3rem;">⚠️</div>
            <h5 class="fw-bold mt-2">Delete Subscriber?</h5>
            <p class="text-muted mt-1">Are you sure you want to delete <strong>@deleteTargetName</strong>? This action cannot be undone.</p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="CancelDelete">Cancel</button>
            <button class="btn btn-danger px-4" @onclick="ConfirmDelete">Yes, Delete</button>
        </div>
    </div>
}

<!-- ADD / EDIT MODAL -->
@if (showForm)
{
    <div class="modal-backdrop-custom" @onclick="CancelForm"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">@(isEditing ? "Edit Subscriber" : "Add Subscriber")</h5>
            <button class="btn-close" @onclick="CancelForm"></button>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">First Name <span class="text-danger">*</span></label>
                <input class="form-control" placeholder="First Name" @bind="user.FirstName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Last Name <span class="text-danger">*</span></label>
                <input class="form-control" placeholder="Last Name" @bind="user.LastName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Username <span class="text-danger">*</span></label>
                <input class="form-control" placeholder="Username" @bind="user.Username" />
            </div>
            <div class="col-md-6">
                <label class="form-label">
                    Password
                    @if (!isEditing)
                    {
                        <span class="text-danger">*</span>
                    }
                    else
                    {
                        <span class="text-muted small">(leave blank to keep)</span>
                    }
                </label>
                <input type="password" class="form-control"
                       placeholder="@(isEditing ? "Leave blank to keep current" : "Password")"
                       @bind="passwordInput" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input class="form-control" placeholder="Email" @bind="user.Email" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Contact Number</label>
                <input class="form-control" placeholder="Contact Number" @bind="user.ContactNumber" />
            </div>
            <div class="col-12">
                <label class="form-label">Address</label>
                <input class="form-control" placeholder="Address" @bind="user.Address" />
            </div>

            <!-- Internet Plan Selector (from Internet Plans table) -->
            <div class="col-12">
                <label class="form-label">Internet Plan <span class="text-danger">*</span></label>
                <select class="form-select" @bind="selectedPlanId">
                    <option value="">Select Plan</option>
                    @foreach (var p in internetPlans)
                    {
                        <option value="@p.PlanId">@p.PlanName - @p.Speed - ₱@p.Price.ToString("N2")</option>
                    }
                </select>
            </div>

            @if (isEditing)
            {
                <div class="col-md-6">
                    <label class="form-label">Subscription Status</label>
                    <select class="form-select" @bind="editSubStatus">
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                        <option value="Expired">Expired</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Start Date</label>
                    <input type="date" class="form-control" @bind="editStartDate" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">End Date</label>
                    <input type="date" class="form-control" @bind="editEndDate" />
                </div>
            }
        </div>
        <div class="d-flex gap-2 mt-4 justify-content-end">
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveUser">
                @(isEditing ? "Update" : "Add Subscriber")
            </button>
        </div>
    </div>
}

@code {
    private string username = "Admin";
    private List<Users> users = new();
    private List<Subscription> subscriptions = new();
    private List<InternetPlan> internetPlans = new();

    private Users user = new();
    private bool isEditing = false;
    private bool showForm = false;
    private bool showDeleteConfirm = false;
    private string deleteTargetId = string.Empty;
    private string deleteTargetName = string.Empty;
    private string searchText = string.Empty;
    private string passwordInput = string.Empty;
    private string errorMessage = string.Empty;

    private string selectedPlanId = string.Empty;
    private InternetPlan? selectedPlan => internetPlans.FirstOrDefault(x => x.PlanId == selectedPlanId);

    private string editSubStatus = "Active";
    private DateTime editStartDate = DateTime.Today;
    private DateTime? editEndDate = null;

    private Subscription? GetSubscription(string? userId) =>
        subscriptions.FirstOrDefault(x => x.UserId == userId && x.Status == "Active")
        ?? subscriptions.FirstOrDefault(x => x.UserId == userId);

    private IEnumerable<Users> filteredUsers =>
        string.IsNullOrWhiteSpace(searchText)
        ? users
        : users.Where(x =>
            (x.FirstName != null && x.FirstName.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            || (x.LastName != null && x.LastName.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            || (x.Username != null && x.Username.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            || (x.UserId != null && x.UserId.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        );

    protected override async Task OnInitializedAsync()
    {
        showForm = false;
        showDeleteConfirm = false;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var u = authState.User;
        if (u.Identity?.IsAuthenticated == true)
            username = u.Identity.Name ?? "Admin";

        await LoadUsers();
    }

    async Task LoadUsers()
    {
        var result = await getAll.ExecuteAsync();
        users = result?.Where(x => x.Role == "Subscriber").ToList() ?? new();

        var subs = await getAllSubscription.ExecuteAsync();
        subscriptions = subs?.ToList() ?? new();

        var plans = await getAllPlans.ExecuteAsync();
        internetPlans = plans?.Where(x => x.IsActive).ToList() ?? new();
    }

    void OpenAddForm()
    {
        user = new Users { Role = "Subscriber" };
        passwordInput = string.Empty;
        selectedPlanId = string.Empty;

        isEditing = false;
        errorMessage = string.Empty;
        showForm = true;
    }

    void EditUser(Users item)
    {
        user = new Users
        {
            UserId = item.UserId,
            FirstName = item.FirstName,
            LastName = item.LastName,
            Username = item.Username,
            Password = item.Password,
            Role = item.Role,
            Email = item.Email,
            ContactNumber = item.ContactNumber,
            Address = item.Address
        };
        passwordInput = string.Empty;
        isEditing = true;
        errorMessage = string.Empty;
        showForm = true;

        var existingSub = subscriptions.FirstOrDefault(x => x.UserId == item.UserId && x.Status == "Active")
                       ?? subscriptions.FirstOrDefault(x => x.UserId == item.UserId);

        editSubStatus = existingSub?.Status ?? "Active";
        editStartDate = existingSub?.StartDate ?? DateTime.Today;
        editEndDate = existingSub?.EndDate;

        selectedPlanId = string.Empty;
        if (!string.IsNullOrWhiteSpace(existingSub?.PlanName))
        {
            var planMatch = internetPlans.FirstOrDefault(x =>
                string.Equals(x.PlanName, existingSub.PlanName, StringComparison.OrdinalIgnoreCase));
            if (planMatch != null) selectedPlanId = planMatch.PlanId ?? "";
        }
    }

    async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(user.FirstName) ||
            string.IsNullOrWhiteSpace(user.LastName) ||
            string.IsNullOrWhiteSpace(user.Username))
        {
            errorMessage = "First Name, Last Name, and Username are required.";
            return;
        }

        if (!isEditing && string.IsNullOrWhiteSpace(passwordInput))
        {
            errorMessage = "Password is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedPlanId) || selectedPlan == null)
        {
            errorMessage = "Please select an Internet Plan.";
            return;
        }

        user.Role = "Subscriber";
        errorMessage = string.Empty;

        try
        {
            if (isEditing)
            {
                if (!string.IsNullOrWhiteSpace(passwordInput))
                    user.Password = passwordInput;

                await update.ExecuteAsync(user);

                var existingSub = subscriptions.FirstOrDefault(x => x.UserId == user.UserId);
                if (existingSub != null)
                {
                    existingSub.PlanName = selectedPlan.PlanName;
                    existingSub.PlanPrice = selectedPlan.Price;
                    existingSub.StartDate = editStartDate;
                    existingSub.EndDate = editEndDate;
                    existingSub.Status = editSubStatus;
                    await updateSubscription.ExecuteAsync(existingSub);
                }
                else
                {
                    var newSub = new Subscription
                    {
                        UserId = user.UserId,
                        PlanName = selectedPlan.PlanName,
                        PlanPrice = selectedPlan.Price,
                        StartDate = editStartDate,
                        EndDate = editEndDate,
                        Status = editSubStatus
                    };
                    await createSubscription.ExecuteAsync(newSub);
                }
            }
            else
            {
                user.Password = passwordInput;
                await create.ExecuteAsync(user);

                var allUsers = await getAll.ExecuteAsync();
                var newUser = allUsers?.FirstOrDefault(x => x.Username == user.Username);

                if (newUser != null)
                {
                    var sub = new Subscription
                    {
                        UserId = newUser.UserId,
                        PlanName = selectedPlan.PlanName,
                        PlanPrice = selectedPlan.Price,
                        StartDate = DateTime.Now,
                        EndDate = DateTime.Now.AddMonths(1),
                        Status = "Active"
                    };
                    await createSubscription.ExecuteAsync(sub);
                }
            }

            user = new Users();
            passwordInput = string.Empty;
            selectedPlanId = string.Empty;
            isEditing = false;
            showForm = false;

            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    void CancelForm()
    {
        user = new Users();
        passwordInput = string.Empty;
        selectedPlanId = string.Empty;

        editSubStatus = "Active";
        editStartDate = DateTime.Today;
        editEndDate = null;

        isEditing = false;
        showForm = false;
        errorMessage = string.Empty;
    }

    void Delete(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;
        var target = users.FirstOrDefault(x => x.UserId == id);
        deleteTargetId = id;
        deleteTargetName = target != null ? $"{target.FirstName} {target.LastName}" : id;
        showDeleteConfirm = true;
    }

    void CancelDelete()
    {
        deleteTargetId = string.Empty;
        deleteTargetName = string.Empty;
        showDeleteConfirm = false;
    }

    async Task ConfirmDelete()
    {
        try
        {
            var existingSub = subscriptions.FirstOrDefault(x => x.UserId == deleteTargetId);
            if (existingSub != null)
            {
                await deleteSubscription.ExecuteAsync(existingSub);
            }

            var deleteUser = new Users { UserId = deleteTargetId };
            await delete.ExecuteAsync(deleteUser);

            showDeleteConfirm = false;
            deleteTargetId = string.Empty;
            deleteTargetName = string.Empty;
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            showDeleteConfirm = false;
        }
    }
}