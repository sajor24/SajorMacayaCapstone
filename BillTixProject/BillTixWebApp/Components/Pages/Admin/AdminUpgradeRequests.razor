@page "/admin-upgrade-requests"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject IGetAll_UpgradeRequest getAll
@inject IUpdate_UpgradeRequest updateRequest
@inject IDelete_UpgradeRequest deleteRequest
@inject IGetAll_Subscription getAllSubs
@inject IUpdate_Subscription updateSub
@inject ICreate_Subscription createSub
@inject ICreate_Billing createBilling
@inject IGetAll_Billing getAllBillings
@inject IUpdate_Billing updateBilling
@inject IGetAll_InternetPlan getPlans

<div class="sub-wrapper">

    <div class="topnav">
        <div class="topnav-left">
            <h2>Payment Request</h2>
            <p>Review and approve subscriber plan upgrades</p>
        </div>
    </div>

    <div class="page-content">

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
                @message
                <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
            </div>
        }

        <div class="table-card">
            <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
                <div>
                    <div class="fw-semibold" style="color:#111;">Payment Request</div>
                    <small class="text-muted">Pending: @requests.Count(x => x.Status == "Pending")</small>
                </div>
                <div class="d-flex gap-2 align-items-center flex-wrap justify-content-end">
                    <!-- Date filter by Requested At -->
                    <div class="d-flex align-items-center gap-1">
                        <span class="text-muted" style="font-size:.82rem; white-space:nowrap;">Date:</span>
                        <input type="date" class="form-control form-control-sm" style="width:150px;"
                               @bind="filterDate" @bind:event="oninput" />
                        @if (filterDate.HasValue)
                        {
                            <button class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"
                                    @onclick="() => filterDate = null" title="Clear date">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                    <!-- Search field selector -->
                    <select class="form-select form-select-sm" style="width:160px;" @bind="searchField">
                        <option value="all">All Fields</option>
                        <option value="id">Request ID</option>
                        <option value="name">Subscriber Name</option>
                        <option value="plan">Plan</option>
                        <option value="ref">Reference No.</option>
                        <option value="status">Status</option>
                    </select>
                    <!-- Search input -->
                    <div class="search-box">
                        <i class="bi bi-search text-muted"></i>
                        <input placeholder="Search..." @bind="searchText" @bind:event="oninput" />
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="sub-table">
                    <thead>
                        <tr>
                            <th>Request ID</th>
                            <th>Subscriber</th>
                            <th>Requested Plan</th>
                            <th>Reference No.</th>
                            <th>Status</th>
                            <th>Requested At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in filteredRequests)
                        {
                            <tr>
                                <td class="fw-semibold">@req.RequestId</td>
                                <td>@req.FirstName @req.LastName<br /><small class="text-muted">@req.Username</small></td>
                                <td>@req.PlanName</td>
                                <td>@req.ReferenceNo</td>
                                <td>
                                    <span class="status-badge @GetStatusClass(req.Status)">@req.Status</span>
                                </td>
                                <td class="text-muted">@req.RequestedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td>
                                    @if (req.Status == "Pending")
                                    {
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-success btn-sm" @onclick="() => Approve(req)">
                                                <i class="bi bi-check-lg"></i> Approve
                                            </button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => Reject(req)">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => DeleteReq(req)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex gap-2 align-items-center">
                                            <small class="text-muted">@req.ProcessedAt?.ToString("MMM dd, yyyy")</small>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => DeleteReq(req)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!filteredRequests.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No upgrade requests.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@code {
    private List<UpgradeRequest> requests = new();
    private string message = string.Empty;
    private bool isError = false;
    private string searchText = string.Empty;
    private string searchField = "all";
    private DateTime? filterDate = null;

    private IEnumerable<UpgradeRequest> filteredRequests
    {
        get
        {
            var result = requests.AsEnumerable();

            // Date filter — by RequestedAt date
            if (filterDate.HasValue)
                result = result.Where(x => x.RequestedAt.Date == filterDate.Value.Date);

            if (string.IsNullOrWhiteSpace(searchText))
                return result;

            return result.Where(x => searchField switch
            {
                "id" => x.RequestId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                "name" => ($"{x.FirstName} {x.LastName}").Contains(searchText, StringComparison.OrdinalIgnoreCase)
                            || (x.Username?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true),
                "plan" => x.PlanName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                "ref" => x.ReferenceNo?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                "status" => x.Status?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                _ =>
                    (x.RequestId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.FirstName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.LastName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.Username?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.PlanName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.ReferenceNo?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.Status?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true)
            });
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();
    }

    async Task LoadRequests()
    {
        var result = await getAll.ExecuteAsync();
        requests = result?.ToList() ?? new();
    }

    string GetStatusClass(string? status) => status switch
    {
        "Pending" => "badge-pending",
        "Approved" => "badge-approved",
        "Rejected" => "badge-rejected",
        _ => ""
    };

    async Task Approve(UpgradeRequest req)
    {
        try
        {
            // 1. Update request status
            req.Status = "Approved";
            req.ProcessedAt = DateTime.Now;
            await updateRequest.ExecuteAsync(req);

            // 2. Get plan price
            var plans = await getPlans.ExecuteAsync();
            var plan = plans?.FirstOrDefault(x => x.PlanName == req.PlanName);
            decimal planPrice = plan?.Price ?? 0;

            // 3. Update subscription — ADD 1 month ON TOP of the existing EndDate
            //    (hindi na basta ni-reset sa "ngayon + 1 buwan", para hindi mawala
            //    ang natitirang bilang ng araw ng subscriber kung mag-upgrade sila mid-cycle)
            var allSubs = await getAllSubs.ExecuteAsync();
            var currentSub = allSubs?.FirstOrDefault(x => x.UserId == req.UserId && x.Status == "Active");

            DateTime newEndDate;

            if (currentSub != null)
            {
                var baseDate = currentSub.EndDate ?? DateTime.Now;
                newEndDate = baseDate.AddMonths(1);

                currentSub.PlanName = req.PlanName;
                currentSub.PlanPrice = planPrice;
                // NOTE: StartDate ay hindi na dinidiin/binabago dito para hindi
                // mawala ang tunay na simula ng subscription ng subscriber.
                currentSub.EndDate = newEndDate;
                currentSub.Status = "Active";
                await updateSub.ExecuteAsync(currentSub);
            }
            else
            {
                newEndDate = DateTime.Now.AddMonths(1);

                var newSub = new Subscription
                {
                    UserId = req.UserId,
                    PlanName = req.PlanName,
                    PlanPrice = planPrice,
                    StartDate = DateTime.Now,
                    EndDate = newEndDate,
                    Status = "Active"
                };
                await createSub.ExecuteAsync(newSub);
            }

            // 4. Resolve the ORIGINAL Pending bill (galing sa sub-billing.razor SubmitPayment)
            //    sa halip na gumawa ng bagong hiwalay/orphaned na Billing record.
            var allBillings = await getAllBillings.ExecuteAsync();

            var originalBill = allBillings?
                .Where(x => x.UserId == req.UserId
                         && !string.Equals(x.Status, "Paid", StringComparison.OrdinalIgnoreCase)
                         && !string.Equals(x.Status, "Cancelled", StringComparison.OrdinalIgnoreCase)
                         && !string.IsNullOrEmpty(req.ReferenceNo)
                         && x.PaymentMethod != null
                         && x.PaymentMethod.Contains(req.ReferenceNo, StringComparison.OrdinalIgnoreCase))
                .OrderBy(x => x.DueDate ?? DateTime.MaxValue)
                .FirstOrDefault();

            // Fallback: kung walang match sa reference number (edge case), kunin na lang
            // yung pinakalumang unresolved bill ng subscriber
            originalBill ??= allBillings?
                .Where(x => x.UserId == req.UserId
                         && !string.Equals(x.Status, "Paid", StringComparison.OrdinalIgnoreCase)
                         && !string.Equals(x.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                .OrderBy(x => x.DueDate ?? DateTime.MaxValue)
                .FirstOrDefault();

            if (originalBill != null)
            {
                originalBill.Status = "Paid";
                originalBill.PaidAt = DateTime.Now;
                originalBill.Amount = planPrice;
                originalBill.Description = $"Plan upgrade to {req.PlanName}";
                await updateBilling.ExecuteAsync(originalBill);
            }
            else
            {
                // Walang nahanap na existing bill — gumawa na lang ng bago
                var newBilling = new Billing
                {
                    UserId = req.UserId,
                    Amount = planPrice,
                    PaymentMethod = "Reference: " + req.ReferenceNo,
                    Status = "Paid",
                    DueDate = DateTime.Now,
                    PaidAt = DateTime.Now,
                    Description = $"Plan upgrade to {req.PlanName}"
                };
                await createBilling.ExecuteAsync(newBilling);
            }

            message = $"Approved! {req.FirstName}'s plan upgraded to {req.PlanName}. Billing record updated.";
            isError = false;
            await LoadRequests();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }

    async Task Reject(UpgradeRequest req)
    {
        try
        {
            req.Status = "Rejected";
            req.ProcessedAt = DateTime.Now;
            await updateRequest.ExecuteAsync(req);

            message = $"Request rejected for {req.FirstName}.";
            isError = false;
            await LoadRequests();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }

    async Task DeleteReq(UpgradeRequest req)
    {
        try
        {
            await deleteRequest.ExecuteAsync(req);
            message = "Request deleted.";
            isError = false;
            await LoadRequests();
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
        }
    }
}
