@page "/admin-technicians"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@inject IDelete_User delete
@inject IGetAll_User getAll
@inject ICreate_User create
@inject IUpdate_User update
@inject IGetAll_ServiceRequest getAllRequests
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Roles = "Admin")]

<div class="sub-wrapper">

    <!-- TOP NAV -->
    <div class="topnav">
        <div class="topnav-left">
            <h2>Technician Management</h2>
            <p>Manage and monitor field technicians</p>
        </div>
        <div class="topnav-right">
            <button class="btn btn-primary d-flex align-items-center gap-2 px-4" @onclick="OpenAddForm">
                <i class="bi bi-person-plus-fill"></i> Add Technician
            </button>
        </div>
    </div>

    <div class="page-content">

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible mb-3">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }

        <!-- Stat Cards -->
        <div class="tech-stats">
            <div class="tech-stat-card">
                <div>
                    <div class="tech-stat-label">Total Technicians</div>
                    <div class="tech-stat-value">@technicians.Count</div>
                </div>
                <div class="tech-stat-icon icon-blue"><i class="bi bi-tools"></i></div>
            </div>
            <div class="tech-stat-card">
                <div>
                    <div class="tech-stat-label">Open Requests</div>
                    <div class="tech-stat-value">@openRequests</div>
                </div>
                <div class="tech-stat-icon icon-green"><i class="bi bi-star"></i></div>
            </div>
            <div class="tech-stat-card">
                <div>
                    <div class="tech-stat-label">In Progress</div>
                    <div class="tech-stat-value">@inProgressRequests</div>
                </div>
                <div class="tech-stat-icon icon-pin"><i class="bi bi-geo-alt"></i></div>
            </div>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <div class="fw-semibold" style="color:#111;">All Technicians</div>
                    <small class="text-muted">Manage and monitor field technician status</small>
                </div>
                <div class="search-box">
                    <i class="bi bi-search text-muted"></i>
                    <input placeholder="Search technicians..."
                           @bind="searchText"
                           @bind:event="oninput" />
                </div>
            </div>

            <div class="table-responsive">
                <table class="sub-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Contact</th>
                            <th>Specialization</th>
                            <th>Area</th>
                            <th>Completed Jobs</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in filteredTechnicians)
                        {
                            <tr>
                                <td class="fw-semibold">@item.UserId</td>
                                <td><div class="tech-name">@item.FirstName @item.LastName</div></td>
                                <td>
                                    <div>@(item.Email ?? "—")</div>
                                    <div class="text-muted" style="font-size:.82rem">@(item.ContactNumber ?? "—")</div>
                                </td>
                                <td>@(item.TechSpecialization ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.TechArea))
                                    {
                                        <span><i class="bi bi-geo-alt text-muted me-1"></i>@item.TechArea</span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>@(item.TechCompletedJobs ?? 0)</td>
                                <td>
                                    <button class="action-btn edit-btn" title="Edit" @onclick="() => EditTech(item)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="action-btn delete-btn ms-1" title="Delete" @onclick="() => Delete(item.UserId)">
                                        <i class="bi bi-power"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (!filteredTechnicians.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No technicians found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- DELETE MODAL -->
@if (showDeleteConfirm)
{
    <div class="modal-backdrop-custom" @onclick="CancelDelete"></div>
    <div class="modal-box shadow-lg" style="width:420px;">
        <div class="text-center py-2">
            <div style="font-size:3rem;">🗑️</div>
            <h5 class="fw-bold mt-2">Delete Technician?</h5>
            <p class="text-muted mt-1">Are you sure you want to delete <strong>@deleteTargetName</strong>? This cannot be undone.</p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="CancelDelete">Cancel</button>
            <button class="btn btn-danger px-4" @onclick="ConfirmDelete">Yes, Delete</button>
        </div>
    </div>
}

<!-- ADD / EDIT MODAL -->
@if (showForm)
{
    <div class="modal-backdrop-custom" @onclick="CancelForm"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">@(isEditing ? "Edit Technician" : "Add Technician")</h5>
            <button class="btn-close" @onclick="CancelForm"></button>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">First Name <span class="text-danger">*</span></label>
                <input class="form-control" placeholder="First Name" @bind="techUser.FirstName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Last Name <span class="text-danger">*</span></label>
                <input class="form-control" placeholder="Last Name" @bind="techUser.LastName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Username <span class="text-danger">*</span></label>
                <input class="form-control" placeholder="Username" @bind="techUser.Username" />
            </div>
            <div class="col-md-6">
                <label class="form-label">
                    Password
                    @if (!isEditing) { <span class="text-danger">*</span> }
                    else { <span class="text-muted small">(leave blank to keep)</span> }
                </label>
                <input type="password" class="form-control"
                       placeholder="@(isEditing ? "Leave blank to keep" : "Password")"
                       @bind="passwordInput" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input class="form-control" placeholder="Email" @bind="techUser.Email" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Contact Number</label>
                <input class="form-control" placeholder="Contact Number" @bind="techUser.ContactNumber" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Specialization</label>
                <select class="form-select" @bind="techUser.TechSpecialization">
                    <option value="">Select Specialization</option>
                    <option value="Network Installation">Network Installation</option>
                    <option value="Troubleshooting">Troubleshooting</option>
                    <option value="Hardware Repair">Hardware Repair</option>
                    <option value="Maintenance">Maintenance</option>
                    <option value="Cable Installation">Cable Installation</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Area</label>
                <input class="form-control" placeholder="e.g. Downtown, Uptown" @bind="techUser.TechArea" />
            </div>
            @if (isEditing)
            {
                <div class="col-md-6">
                    <label class="form-label">Completed Jobs</label>
                    <input type="number" class="form-control" min="0" @bind="techCompletedJobs" />
                </div>
            }
            <div class="col-12">
                <label class="form-label">Address</label>
                <input class="form-control" placeholder="Address" @bind="techUser.Address" />
            </div>
        </div>

        <div class="d-flex gap-2 mt-4 justify-content-end">
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveTech">
                @(isEditing ? "Update Technician" : "Add Technician")
            </button>
        </div>
    </div>
}


@code {
    private string username = "Admin";
    private List<Users> technicians = new();
    private List<ServiceRequest> serviceRequests = new();
    private Users techUser = new();
    private bool isEditing = false;
    private bool showForm = false;
    private bool showDeleteConfirm = false;
    private string deleteTargetId = string.Empty;
    private string deleteTargetName = string.Empty;
    private string searchText = string.Empty;
    private string passwordInput = string.Empty;
    private string errorMessage = string.Empty;
    private int techCompletedJobs = 0;

    private int openRequests      => serviceRequests.Count(x => x.Status == "Pending");
    private int inProgressRequests => serviceRequests.Count(x => x.Status == "In Progress");

    private IEnumerable<Users> filteredTechnicians =>
        string.IsNullOrWhiteSpace(searchText)
        ? technicians
        : technicians.Where(x =>
            (x.FirstName ?? "").Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            (x.LastName  ?? "").Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            (x.Username  ?? "").Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            (x.UserId    ?? "").Contains(searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        showForm = false;
        showDeleteConfirm = false;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var u = authState.User;
        if (u.Identity?.IsAuthenticated == true)
            username = u.Identity.Name ?? "Admin";
        await LoadData();
    }

    async Task LoadData()
    {
        var users = await getAll.ExecuteAsync();
        technicians = users?.Where(x => x.Role == "Technician").ToList() ?? new();
        try
        {
            var reqs = await getAllRequests.ExecuteAsync();
            serviceRequests = reqs?.ToList() ?? new();
        }
        catch { }
    }

    void OpenAddForm()
    {
        techUser = new Users { Role = "Technician" };
        passwordInput = string.Empty;
        techCompletedJobs = 0;
        isEditing = false;
        errorMessage = string.Empty;
        showForm = true;
    }

    void EditTech(Users item)
    {
        techUser = new Users
        {
            UserId             = item.UserId,
            FirstName          = item.FirstName,
            LastName           = item.LastName,
            Username           = item.Username,
            Password           = item.Password,
            Role               = "Technician",
            Email              = item.Email,
            ContactNumber      = item.ContactNumber,
            Address            = item.Address,
            TechSpecialization = item.TechSpecialization,
            TechArea           = item.TechArea,
            TechCompletedJobs  = item.TechCompletedJobs
        };
        techCompletedJobs = item.TechCompletedJobs ?? 0;
        passwordInput = string.Empty;
        isEditing = true;
        errorMessage = string.Empty;
        showForm = true;
    }

    async Task SaveTech()
    {
        if (string.IsNullOrWhiteSpace(techUser.FirstName) ||
            string.IsNullOrWhiteSpace(techUser.LastName)  ||
            string.IsNullOrWhiteSpace(techUser.Username))
        {
            errorMessage = "First Name, Last Name, and Username are required.";
            return;
        }
        if (!isEditing && string.IsNullOrWhiteSpace(passwordInput))
        {
            errorMessage = "Password is required.";
            return;
        }

        errorMessage = string.Empty;
        techUser.Role = "Technician";
        techUser.TechCompletedJobs = techCompletedJobs;

        try
        {
            if (isEditing)
            {
                if (!string.IsNullOrWhiteSpace(passwordInput))
                    techUser.Password = passwordInput;
                await update.ExecuteAsync(techUser);
            }
            else
            {
                techUser.Password = passwordInput;
                await create.ExecuteAsync(techUser);
            }

            techUser = new Users();
            passwordInput = string.Empty;
            isEditing = false;
            showForm = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    void CancelForm()
    {
        techUser = new Users();
        passwordInput = string.Empty;
        isEditing = false;
        showForm = false;
        errorMessage = string.Empty;
    }

    void Delete(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;
        var target = technicians.FirstOrDefault(x => x.UserId == id);
        deleteTargetId = id;
        deleteTargetName = target != null ? $"{target.FirstName} {target.LastName}" : id;
        showDeleteConfirm = true;
    }

    void CancelDelete()
    {
        deleteTargetId = string.Empty;
        deleteTargetName = string.Empty;
        showDeleteConfirm = false;
    }

    async Task ConfirmDelete()
    {
        try
        {
            await delete.ExecuteAsync(new Users { UserId = deleteTargetId });
            showDeleteConfirm = false;
            deleteTargetId = string.Empty;
            deleteTargetName = string.Empty;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            showDeleteConfirm = false;
        }
    }
}
