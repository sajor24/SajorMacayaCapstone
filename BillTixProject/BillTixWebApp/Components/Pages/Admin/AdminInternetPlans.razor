@page "/admin-internet-plans"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject IGetAll_InternetPlan getAll
@inject ICreate_InternetPlan create
@inject IUpdate_InternetPlan update
@inject IDelete_InternetPlan delete

<div class="sub-wrapper">

    <!-- TOP NAV -->
    <div class="topnav">
        <div class="topnav-left">
            <h2>Internet Plans</h2>
            <p>Manage your internet plans</p>
        </div>
        <div class="topnav-right">
            <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="OpenAddForm">
                <i class="bi bi-plus-circle-fill"></i> Add Plan
            </button>
        </div>
    </div>

    <div class="page-content">

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible mb-3">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }

        <!-- TABLE CARD -->
        <div class="table-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <div class="fw-semibold" style="color:#111;">All Plans</div>
                    <small class="text-muted">Total: @plans.Count plan@(plans.Count != 1 ? "s" : "")</small>
                </div>
            </div>

            <div class="table-responsive">
                <table class="sub-table">
                    <thead>
                        <tr>
                            <th>Plan ID</th>
                            <th>Plan Name</th>
                            <th>Speed</th>
                            <th>Price</th>
                            <th>Features</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var plan in plans)
                        {
                            <tr>
                                <td class="fw-semibold">@plan.PlanId</td>
                                <td>@plan.PlanName</td>
                                <td>@plan.Speed</td>
                                <td>₱@plan.Price.ToString("N2")</td>
                                <td class="text-muted" style="font-size:.82rem;">@plan.Features</td>
                                <td>
                                    <span class="status-badge @(plan.IsActive ? "badge-active" : "badge-inactive")">
                                        @(plan.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button class="action-btn edit-btn" title="Edit" @onclick="() => EditPlan(plan)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="action-btn delete-btn" title="Delete" @onclick="() => DeletePlan(plan)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!plans.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No plans found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- DELETE CONFIRMATION -->
@if (showDeleteConfirm)
{
    <div class="modal-backdrop-custom" @onclick="() => showDeleteConfirm = false"></div>
    <div class="modal-box shadow-lg" style="width:420px;">
        <div class="text-center py-2">
            <div style="font-size:3rem;">⚠️</div>
            <h5 class="fw-bold mt-2">Delete Plan?</h5>
            <p class="text-muted mt-1">Are you sure you want to delete <strong>@deleteTargetName</strong>?</p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="() => showDeleteConfirm = false">Cancel</button>
            <button class="btn btn-danger px-4" @onclick="ConfirmDelete">Yes, Delete</button>
        </div>
    </div>
}

<!-- ADD / EDIT MODAL -->
@if (showForm)
{
    <div class="modal-backdrop-custom" @onclick="CancelForm"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">@(isEditing ? "Edit Plan" : "Add Plan")</h5>
            <button class="btn-close" @onclick="CancelForm"></button>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Plan Name <span class="text-danger">*</span></label>
                <input class="form-control" placeholder="e.g. Basic" @bind="plan.PlanName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Speed <span class="text-danger">*</span></label>
                <input class="form-control" placeholder="e.g. 150 Mbps" @bind="plan.Speed" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Price <span class="text-danger">*</span></label>
                <input type="number" class="form-control" placeholder="e.g. 1000" @bind="plan.Price" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Status</label>
                <select class="form-select" @bind="plan.IsActive">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Features <span class="text-muted small">(comma-separated)</span></label>
                <input class="form-control" placeholder="e.g. Unlimited Data,Free Router,24/7 Support" @bind="plan.Features" />
            </div>
        </div>
        <div class="d-flex gap-2 mt-4 justify-content-end">
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            <button class="btn btn-primary" @onclick="SavePlan">
                @(isEditing ? "Update" : "Add Plan")
            </button>
        </div>
    </div>
}

<style>
    .sub-wrapper { min-height: 100vh; background: #f5f6fa; display: flex; flex-direction: column; }
    .topnav { background: white; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #4f46e5; }
    .topnav-left h2 { font-size: 1.2rem; font-weight: 700; color: #111; margin: 0; }
    .topnav-left p { font-size: .82rem; color: #4f46e5; margin: 0; }
    .topnav-right { display: flex; align-items: center; gap: 16px; }
    .page-content { padding: 32px; flex: 1; }
    .table-card { background: white; border-radius: 16px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .sub-table { width: 100%; border-collapse: collapse; }
    .sub-table thead tr { border-bottom: 2px solid #f3f4f6; }
    .sub-table th { text-align: left; padding: 10px 12px; font-size: .82rem; color: #888; font-weight: 600; }
    .sub-table td { padding: 14px 12px; border-bottom: 1px solid #f3f4f6; font-size: .9rem; color: #333; }
    .sub-table tbody tr:hover { background: #fafafa; }
    .status-badge { padding: 5px 14px; border-radius: 20px; font-size: .75rem; font-weight: 600; }
    .badge-active { background: #111827; color: white; }
    .badge-inactive { background: #f3f4f6; color: #888; }
    .action-btn { border: 1px solid #e5e7eb; background: white; border-radius: 8px; padding: 6px 10px; cursor: pointer; transition: .2s; font-size: .9rem; }
    .edit-btn:hover { background: #f0f0ff; border-color: #4f46e5; color: #4f46e5; }
    .delete-btn:hover { background: #fff0f0; border-color: #ef4444; color: #ef4444; }
    .modal-backdrop-custom { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1040; }
    .modal-box { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; border-radius: 16px; padding: 2rem; width: 620px; max-width: 95vw; z-index: 1050; max-height: 90vh; overflow-y: auto; }
</style>

@code {
    private List<InternetPlan> plans = new();
    private InternetPlan plan = new();
    private bool isEditing = false;
    private bool showForm = false;
    private bool showDeleteConfirm = false;
    private string deleteTargetId = string.Empty;
    private string deleteTargetName = string.Empty;
    private string errorMessage = string.Empty;
    private InternetPlan? deleteTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlans();
    }

    async Task LoadPlans()
    {
        var result = await getAll.ExecuteAsync();
        plans = result?.ToList() ?? new();
    }

    void OpenAddForm()
    {
        plan = new InternetPlan { IsActive = true };
        isEditing = false;
        errorMessage = string.Empty;
        showForm = true;
    }

    void EditPlan(InternetPlan item)
    {
        plan = new InternetPlan
        {
            PlanId = item.PlanId,
            PlanName = item.PlanName,
            Speed = item.Speed,
            Price = item.Price,
            Features = item.Features,
            IsActive = item.IsActive
        };
        isEditing = true;
        errorMessage = string.Empty;
        showForm = true;
    }

    async Task SavePlan()
    {
        if (string.IsNullOrWhiteSpace(plan.PlanName) ||
            string.IsNullOrWhiteSpace(plan.Speed) ||
            plan.Price <= 0)
        {
            errorMessage = "Plan Name, Speed, and Price are required.";
            return;
        }

        errorMessage = string.Empty;

        try
        {
            if (isEditing)
                await update.ExecuteAsync(plan);
            else
                await create.ExecuteAsync(plan);

            plan = new InternetPlan();
            isEditing = false;
            showForm = false;
            await LoadPlans();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }

    void CancelForm()
    {
        plan = new InternetPlan();
        isEditing = false;
        showForm = false;
        errorMessage = string.Empty;
    }

    void DeletePlan(InternetPlan item)
    {
        deleteTarget = item;
        deleteTargetId = item.PlanId ?? "";
        deleteTargetName = item.PlanName ?? "";
        showDeleteConfirm = true;
    }

    async Task ConfirmDelete()
    {
        if (deleteTarget == null) return;
        try
        {
            await delete.ExecuteAsync(deleteTarget);
            showDeleteConfirm = false;
            deleteTarget = null;
            await LoadPlans();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            showDeleteConfirm = false;
        }
    }
}
