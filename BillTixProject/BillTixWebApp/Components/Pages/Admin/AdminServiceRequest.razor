@page "/admin-service-requests"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject IGetAll_ServiceRequest getAllRequests
@inject ICreate_ServiceRequest createRequest
@inject IUpdate_ServiceRequest updateRequest
@inject IDelete_ServiceRequest deleteRequest
@inject IGetAll_User getUsers

<div class="sub-wrapper">

    <div class="topnav">
        <div class="topnav-left">
            <h2>Service Requests</h2>
            <p>Manage and assign technicians to service requests</p>
        </div>
    </div>

    <div class="page-content">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0"</h3>
            <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="OpenAddModal">
                <i class="bi bi-plus-circle-fill"></i> Add Request
            </button>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
                @message
                <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
            </div>
        }

        <!-- SUMMARY CARDS -->
        <div class="summary-cards mb-4">
            <div class="summary-card">
                <div class="summary-label">Total</div>
                <div class="summary-value">@requests.Count</div>
            </div>
            <div class="summary-card orange">
                <div class="summary-label">Open</div>
                <div class="summary-value">@requests.Count(x => x.Status == "Open")</div>
            </div>
            <div class="summary-card blue">
                <div class="summary-label">In Progress</div>
                <div class="summary-value">@requests.Count(x => x.Status == "In Progress")</div>
            </div>
            <div class="summary-card green">
                <div class="summary-label">Resolved</div>
                <div class="summary-value">@requests.Count(x => x.Status == "Resolved")</div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="table-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="fw-semibold" style="color:#111;">All Service Requests</div>
                <div class="d-flex gap-2 align-items-center flex-wrap justify-content-end">

                    <!-- DATE RANGE FILTER -->
                    <div class="d-flex gap-1 align-items-center me-2">
                        <span class="text-muted small">From:</span>
                        <input type="date" class="form-select form-select-sm" style="width:140px;" @bind="startDate" />
                        <span class="text-muted small">To:</span>
                        <input type="date" class="form-select form-select-sm" style="width:140px;" @bind="endDate" />
                        @if (startDate.HasValue || endDate.HasValue)
                        {
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearDateFilter" title="Clear Date Filter">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        }
                    </div>

                    <select class="form-select form-select-sm" style="width:160px;" @bind="searchField">
                        <option value="all">All Fields</option>
                        <option value="id">Request ID</option>
                        <option value="name">Subscriber Name</option>
                        <option value="issue">Issue Type</option>
                        <option value="address">Address</option>
                        <option value="status">Status</option>
                        <option value="assigned">Assigned To</option>
                    </select>
                    <div class="search-box">
                        <i class="bi bi-search text-muted"></i>
                        <input placeholder="Search..." @bind="searchText" @bind:event="oninput" />
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="sub-table">
                    <thead>
                        <tr>
                            <th>Request ID</th>
                            <th>Subscriber</th>
                            <th>Issue</th>
                            <th>Address</th>
                            <th>Status</th>
                            <th>Assigned To</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in filteredRequests)
                        {
                            <tr>
                                <td class="fw-semibold">@item.RequestId</td>
                                <td>@item.FirstName @item.LastName</td>
                                <td>@item.IssueType</td>
                                <td class="text-muted">@(item.Address ?? "—")</td>
                                <td>
                                    <span class="status-badge @GetStatusClass(item.Status)">@item.Status</span>
                                </td>
                                <td class="text-muted">@(item.AssignedTo ?? "—")</td>
                                <td class="text-muted">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button class="action-btn edit-btn" title="Assign Technician"
                                                @onclick="() => OpenAssignModal(item)">
                                            <i class="bi bi-person-check"></i>
                                        </button>
                                        <button class="action-btn delete-btn" title="Delete"
                                                @onclick="() => OpenDeleteConfirm(item)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!filteredRequests.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">No service requests found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ADD REQUEST MODAL -->
@if (showAddModal)
{
    <div class="modal-backdrop-custom" @onclick="CloseAddModal"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Add Service Request</h5>
            <button class="btn-close" @onclick="CloseAddModal"></button>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label fw-semibold">Subscriber <span class="text-danger">*</span></label>
                <select class="form-select" @bind="newRequest.UserId">
                    <option value="">— Select Subscriber —</option>
                    @foreach (var sub in subscribers)
                    {
                        <option value="@sub.UserId">@sub.FirstName @sub.LastName (@sub.UserId)</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Issue Type <span class="text-danger">*</span></label>
                <select class="form-select" @bind="newRequest.IssueType">
                    <option value="">Select issue type</option>
                    <option value="No Connection">No Connection</option>
                    <option value="Slow Internet">Slow Internet</option>
                    <option value="Router Problem">Router Problem</option>
                    <option value="WiFi Issue">WiFi Issue</option>
                    <option value="Billing Concern">Billing Concern</option>
                    <option value="Plan Upgrade">Plan Upgrade</option>
                    <option value="Installation">Installation</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Priority</label>
                <select class="form-select" @bind="newRequest.Priority">
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                    <option value="Urgent">Urgent</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold">Description</label>
                <textarea class="form-control" rows="3"
                          placeholder="Describe the issue..."
                          @bind="newRequest.Description"></textarea>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Contact Number</label>
                <input class="form-control" placeholder="e.g. 09123456789"
                       @bind="newRequest.ContactNumber" />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Assign Technician</label>
                <select class="form-select" @bind="newAssignedTechId">
                    <option value="">— Assign Later —</option>
                    @foreach (var tech in technicians)
                    {
                        <option value="@tech.UserId">
                            @tech.FirstName @tech.LastName
                            @if (!string.IsNullOrEmpty(tech.TechSpecialization))
                            {
                                <text> · @tech.TechSpecialization</text>
                            }
                        </option>
                    }
                </select>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(addFormError))
        {
            <div class="alert alert-danger mt-3">@addFormError</div>
        }

        <div class="d-flex gap-2 mt-4 justify-content-end">
            <button class="btn btn-secondary" @onclick="CloseAddModal">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveNewRequest" disabled="@isAddSaving">
                @(isAddSaving ? "Saving..." : "Add Request")
            </button>
        </div>
    </div>
}

<!-- ASSIGN MODAL -->
@if (showAssignModal && selectedRequest != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseAssignModal"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Assign Technician</h5>
            <button class="btn-close" @onclick="CloseAssignModal"></button>
        </div>

        <!-- Request Summary -->
        <div class="mb-3 p-3" style="background:#f8f9fa; border-radius:10px;">
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted">Request ID</span>
                <strong>@selectedRequest.RequestId</strong>
            </div>
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted">Subscriber</span>
                <strong>@selectedRequest.FirstName @selectedRequest.LastName</strong>
            </div>
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted">Address</span>
                <strong>@(selectedRequest.Address ?? "—")</strong>
            </div>
            <div class="d-flex justify-content-between mb-1">
                <span class="text-muted">Issue</span>
                <strong>@selectedRequest.IssueType</strong>
            </div>
            <div class="d-flex justify-content-between">
                <span class="text-muted">Priority</span>
                <span class="status-badge @GetPriorityClass(selectedRequest.Priority)">@selectedRequest.Priority</span>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Assign To <span class="text-danger">*</span></label>
            <select class="form-select" @bind="assignedTechnicianId">
                <option value="">— Select Technician —</option>
                @foreach (var tech in technicians)
                {
                    <option value="@tech.UserId">
                        @tech.FirstName @tech.LastName
                        @if (!string.IsNullOrEmpty(tech.TechSpecialization))
                        {
                            <text> · @tech.TechSpecialization</text>
                        }
                        @if (!string.IsNullOrEmpty(tech.TechArea))
                        {
                            <text> (@tech.TechArea)</text>
                        }
                    </option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Status</label>
            <select class="form-select" @bind="assignStatus">
                <option value="Open">Open</option>
                <option value="In Progress">In Progress</option>
                <option value="Resolved">Resolved</option>
            </select>
        </div>

        @if (!string.IsNullOrEmpty(formError))
        {
            <div class="alert alert-danger">@formError</div>
        }

        <div class="d-flex gap-2 mt-4 justify-content-end">
            <button class="btn btn-secondary" @onclick="CloseAssignModal">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveAssignment" disabled="@isSaving">
                @(isSaving ? "Saving..." : "Save Assignment")
            </button>
        </div>
    </div>
}

<!-- DELETE CONFIRMATION MODAL -->
@if (showDeleteConfirm && deleteTarget != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseDeleteConfirm"></div>
    <div class="modal-box shadow-lg" style="width:420px;">
        <div class="text-center py-2">
            <div style="font-size:3rem;">⚠️</div>
            <h5 class="fw-bold mt-2">Delete Service Request?</h5>
            <p class="text-muted mt-1">
                Are you sure you want to delete request <strong>@deleteTarget.RequestId</strong>
                for <strong>@deleteTarget.FirstName @deleteTarget.LastName</strong>? This action cannot be undone.
            </p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="CloseDeleteConfirm">Cancel</button>
            <button class="btn btn-danger px-4" @onclick="ConfirmDelete" disabled="@isDeleting">
                @(isDeleting ? "Deleting..." : "Yes, Delete")
            </button>
        </div>
    </div>
}

@code {
    private List<ServiceRequest> requests = new();
    private List<Users> technicians = new();
    private string searchText = string.Empty;
    private string searchField = "all";
    private string message = string.Empty;
    private bool isError = false;

    private DateTime? startDate;
    private DateTime? endDate;

    private bool showAssignModal = false;
    private ServiceRequest? selectedRequest;
    private string assignedTechnicianId = string.Empty;
    private string assignStatus = "Open";
    private string formError = string.Empty;
    private bool isSaving = false;

    private bool showDeleteConfirm = false;
    private ServiceRequest? deleteTarget;
    private bool isDeleting = false;

    // Add Request
    private bool showAddModal = false;
    private ServiceRequest newRequest = new() { Priority = "Medium", Status = "Open" };
    private string newAssignedTechId = string.Empty;
    private string addFormError = string.Empty;
    private bool isAddSaving = false;

    private List<Users> subscribers = new();

    private void ClearDateFilter()
    {
        startDate = null;
        endDate = null;
    }

    private IEnumerable<ServiceRequest> filteredRequests
    {
        get
        {
            var result = requests.AsEnumerable();

            // 1. Date Range Filter
            if (startDate.HasValue)
            {
                result = result.Where(x => x.CreatedAt.Date >= startDate.Value.Date);
            }
            if (endDate.HasValue)
            {
                result = result.Where(x => x.CreatedAt.Date <= endDate.Value.Date);
            }

            // 2. Text Search Filter
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                result = result.Where(x => searchField switch
                {
                    "id" => x.RequestId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    "name" => ($"{x.FirstName} {x.LastName}").Contains(searchText, StringComparison.OrdinalIgnoreCase),
                    "issue" => x.IssueType?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    "address" => x.Address?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    "status" => x.Status?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    "assigned" => x.AssignedTo?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                    _ =>
                        (x.RequestId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        (x.FirstName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        (x.LastName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        (x.IssueType?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        (x.Address?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        (x.Status?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                        (x.AssignedTo?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true)
                });
            }

            return result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        var result = await getAllRequests.ExecuteAsync();
        requests = result?.OrderByDescending(x => x.CreatedAt).ToList() ?? new();

        var users = await getUsers.ExecuteAsync();
        technicians = users?.Where(x => x.Role == "Technician").ToList() ?? new();
        subscribers = users?.Where(x => x.Role == "Subscriber").ToList() ?? new();
    }

    void OpenAddModal()
    {
        newRequest = new ServiceRequest { Priority = "Medium", Status = "Open" };
        newAssignedTechId = string.Empty;
        addFormError = string.Empty;
        showAddModal = true;
    }

    void CloseAddModal()
    {
        showAddModal = false;
        addFormError = string.Empty;
    }

    async Task SaveNewRequest()
    {
        if (string.IsNullOrWhiteSpace(newRequest.UserId))
        {
            addFormError = "Please select a subscriber.";
            return;
        }
        if (string.IsNullOrWhiteSpace(newRequest.IssueType))
        {
            addFormError = "Please select an issue type.";
            return;
        }

        isAddSaving = true;
        addFormError = string.Empty;

        try
        {
            // Set address from subscriber record
            var sub = subscribers.FirstOrDefault(x => x.UserId == newRequest.UserId);
            newRequest.Address = sub?.Address;
            if (string.IsNullOrWhiteSpace(newRequest.ContactNumber))
                newRequest.ContactNumber = sub?.ContactNumber;

            // Assign technician if selected
            if (!string.IsNullOrWhiteSpace(newAssignedTechId))
            {
                var tech = technicians.FirstOrDefault(x => x.UserId == newAssignedTechId);
                if (tech != null)
                {
                    newRequest.AssignedTo = $"{tech.FirstName} {tech.LastName}";
                    newRequest.Status = "In Progress";
                }
            }

            await createRequest.ExecuteAsync(newRequest);
            await LoadData();

            message = "Service request added successfully.";
            isError = false;
            showAddModal = false;
        }
        catch (Exception ex)
        {
            addFormError = $"Error: {ex.Message}";
        }
        finally
        {
            isAddSaving = false;
        }
    }

    void OpenAssignModal(ServiceRequest req)
    {
        selectedRequest = req;
        assignStatus = req.Status ?? "Open";
        formError = string.Empty;

        // Pre-select the currently assigned technician if any
        var match = technicians.FirstOrDefault(t =>
            $"{t.FirstName} {t.LastName}" == req.AssignedTo);
        assignedTechnicianId = match?.UserId ?? string.Empty;

        showAssignModal = true;
    }

    void CloseAssignModal()
    {
        showAssignModal = false;
        selectedRequest = null;
        assignedTechnicianId = string.Empty;
        formError = string.Empty;
    }

    async Task SaveAssignment()
    {
        if (selectedRequest == null) return;

        if (string.IsNullOrWhiteSpace(assignedTechnicianId))
        {
            formError = "Please select a technician.";
            return;
        }

        isSaving = true;
        formError = string.Empty;

        try
        {
            var tech = technicians.First(x => x.UserId == assignedTechnicianId);

            selectedRequest.AssignedTo = $"{tech.FirstName} {tech.LastName}";
            selectedRequest.Status = assignStatus;

            if (assignStatus == "Resolved" && !selectedRequest.ResolvedAt.HasValue)
                selectedRequest.ResolvedAt = DateTime.Now;
            else if (assignStatus != "Resolved")
                selectedRequest.ResolvedAt = null;

            await updateRequest.ExecuteAsync(selectedRequest);
            await LoadData();

            message = $"Assigned to {selectedRequest.AssignedTo} successfully.";
            isError = false;
            showAssignModal = false;
        }
        catch (Exception ex)
        {
            formError = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    void OpenDeleteConfirm(ServiceRequest req)
    {
        deleteTarget = req;
        showDeleteConfirm = true;
    }

    void CloseDeleteConfirm()
    {
        showDeleteConfirm = false;
        deleteTarget = null;
    }

    async Task ConfirmDelete()
    {
        if (deleteTarget == null) return;

        isDeleting = true;

        try
        {
            await deleteRequest.ExecuteAsync(deleteTarget);
            await LoadData();

            message = "Service request deleted.";
            isError = false;
            showDeleteConfirm = false;
            deleteTarget = null;
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
            isError = true;
            showDeleteConfirm = false;
        }
        finally
        {
            isDeleting = false;
        }
    }

    string GetStatusClass(string? s) => s switch
    {
        "Open" => "badge-pending",
        "In Progress" => "badge-inprogress",
        "Resolved" => "badge-paid",
        _ => "badge-pending"
    };

    string GetPriorityClass(string? p) => p?.ToLower() switch
    {
        "urgent" => "badge-overdue",
        "high" => "badge-overdue",
        "medium" => "badge-pending",
        "low" => "badge-paid",
        _ => "badge-pending"
    };
}