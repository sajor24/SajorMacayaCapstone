@page "/admin-billing"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using Domain.ICommands
@using Domain.Models
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject IGetAll_Billing getAll
@inject ICreate_Billing create
@inject IUpdate_Billing update
@inject IDelete_Billing delete
@inject IGetAll_Billing getAllBill
@inject IGetAll_User getUsers
@inject IGetAll_Subscription getSubscription
@inject IGetByUser_Subscription getSubByUser
@inject IUpdate_Subscription updateSubscription
@inject IGetAll_UpgradeRequest getAllUpgradeRequests

<div class="sub-wrapper">

    <div class="topnav">
        <div class="topnav-left">
            <h2>Billing</h2>
            <p>Manage subscriber billing records</p>
        </div>
    </div>

    <div class="page-content">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0" style="color:#111;">Billing</h3>
            <button class="btn btn-primary d-flex align-items-center gap-2" @onclick="OpenAddForm">
                <i class="bi bi-plus-circle-fill"></i> Add Bill
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible mb-3">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }

        <!-- SUMMARY CARDS -->
        <div class="summary-cards mb-4">
            <div class="summary-card">
                <div class="summary-label">Total Bills</div>
                <div class="summary-value">@billings.Count</div>
            </div>
            <div class="summary-card green">
                <div class="summary-label">Paid</div>
                <div class="summary-value">@billings.Count(x => x.Status == "Paid")</div>
            </div>
            <div class="summary-card orange">
                <div class="summary-label">Pending Bills</div>
                <div class="summary-value">@pendingUpgradeCount</div>
            </div>
            <div class="summary-card red">
                <div class="summary-label" style="color: #dc2626;">Overdue</div>
                <div class="summary-value">@overdueSubCount</div>
            </div>
            <div class="summary-card blue">
                <div class="summary-label">Total Revenue</div>
                <div class="summary-value">₱@billings.Where(x => x.Status == "Paid").Sum(x => x.Amount).ToString("N2")</div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="table-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="fw-semibold" style="color:#111;">All Bills</div>
                <div class="d-flex gap-2 align-items-center flex-wrap justify-content-end">
                    <!-- Date filter -->
                    <div class="d-flex align-items-center gap-1">
                        <span class="text-muted" style="font-size:.82rem; white-space:nowrap;">Paid on:</span>
                        <input type="date" class="form-control form-control-sm" style="width:150px;"
                               @bind="filterDate" @bind:event="oninput" />
                        @if (filterDate.HasValue)
                        {
                            <button class="btn btn-sm btn-outline-secondary" style="padding:2px 8px;"
                                    @onclick="() => filterDate = null" title="Clear date">
                                <i class="bi bi-x"></i>
                            </button>
                        }
                    </div>
                    <select class="form-select form-select-sm" style="width:160px;" @bind="searchField">
                        <option value="all">All Fields</option>
                        <option value="name">Subscriber Name</option>
                        <option value="id">Billing ID</option>
                        <option value="status">Status</option>
                        <option value="method">Payment Method</option>
                        <option value="duedate">Due Date</option>
                        <option value="paidat">Paid Date</option>
                    </select>
                    <div class="search-box">
                        <i class="bi bi-search text-muted"></i>
                        <input placeholder="Search..." @bind="searchText" @bind:event="oninput" />
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="sub-table">
                    <thead>
                        <tr>
                            <th>Billing ID</th>
                            <th>Subscriber</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th>Paid At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in filteredBillings)
                        {
                            <tr>
                                <td class="fw-semibold">@item.BillingId</td>
                                <td>@item.FirstName @item.LastName</td>
                                <td>₱@item.Amount.ToString("N2")</td>
                                <td class="text-muted">@(item.PaymentMethod ?? "—")</td>
                                <td>
                                    <span class="status-badge @GetStatusClass(item.Status)">@item.Status</span>
                                </td>
                                <td class="text-muted">@(item.PaidAt?.ToString("MMM dd, yyyy") ?? "—")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button class="action-btn edit-btn" title="Edit" @onclick="() => EditBilling(item)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="action-btn delete-btn" title="Delete" @onclick="() => DeleteBill(item)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!filteredBillings.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">No billing records found.</td>
                            </tr>
                        }                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- DELETE CONFIRM -->
@if (showDeleteConfirm)
{
    <div class="modal-backdrop-custom" @onclick="() => showDeleteConfirm = false"></div>
    <div class="modal-box shadow-lg" style="width:420px;">
        <div class="text-center py-2">
            <div style="font-size:3rem;">⚠️</div>
            <h5 class="fw-bold mt-2">Delete Bill?</h5>
            <p class="text-muted mt-1">Are you sure you want to delete <strong>@deleteTarget?.BillingId</strong>?</p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="() => showDeleteConfirm = false">Cancel</button>
            <button class="btn btn-danger px-4" @onclick="ConfirmDelete">Yes, Delete</button>
        </div>
    </div>
}

<!-- ADD / EDIT MODAL -->
@if (showForm)
{
    <div class="modal-backdrop-custom" @onclick="CancelForm"></div>
    <div class="modal-box shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">@(isEditing ? "Edit Bill" : "Add Bill")</h5>
            <button class="btn-close" @onclick="CancelForm"></button>
        </div>
        <div class="row g-3">
            @if (!isEditing)
            {
                <div class="col-12">
                    <label class="form-label">Subscriber <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="billing.UserId">
                        <option value="">Select Subscriber</option>
                        @foreach (var sub in subscribers)
                        {
                            <option value="@sub.UserId">@sub.FirstName @sub.LastName (@sub.UserId)</option>
                        }
                    </select>
                </div>
            }
            <div class="col-md-6">
                <label class="form-label">Amount <span class="text-danger">*</span></label>
                <input type="number" class="form-control" placeholder="0.00" @bind="billing.Amount" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Payment Method</label>
                <select class="form-select" @bind="billing.PaymentMethod">
                    <option value="">Select Method</option>
                    <option value="GCash">GCash</option>
                    <option value="Bank Transfer">Bank Transfer</option>
                    <option value="Cash">Cash</option>
                    <option value="Maya">Maya</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Status</label>
                <select class="form-select" @bind="selectedStatus">
                    <option value="Pending">Pending</option>
                    <option value="Paid">Paid</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Due Date</label>
                <input type="date" class="form-control" @bind="billing.DueDate" />
            </div>
            <div class="col-12">
                <label class="form-label">Description</label>
                <input class="form-control" placeholder="e.g. Monthly subscription fee" @bind="billing.Description" />
            </div>
        </div>
        <div class="d-flex gap-2 mt-4 justify-content-end">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="text-danger small me-auto align-self-center">@errorMessage</div>
            }
            <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveBilling">
                @(isEditing ? "Update" : "Add Bill")
            </button>
        </div>
    </div>
}

@code {
    private List<Billing> billings = new();
    private List<Users> subscribers = new();
    private List<Subscription> allSubscriptions = new();
    private Billing billing = new() { Status = "Pending" };
    private string selectedStatus = "Pending";
    private bool isEditing = false;
    private bool showForm = false;
    private bool showDeleteConfirm = false;
    private Billing? deleteTarget;
    private string searchText = string.Empty;
    private string searchField = "all";
    private DateTime? filterDate = null;
        private string errorMessage = string.Empty;
    private int pendingUpgradeCount = 0;

    // Count of subscribers whose subscription EndDate has passed (Due Date status)
    private int overdueSubCount =>
        allSubscriptions.Count(x =>
            x.EndDate.HasValue &&
            x.EndDate.Value.Date < DateTime.Today &&
            x.Status != "Inactive");

    private IEnumerable<Billing> filteredBillings
    {
        get
        {
            var result = billings.AsEnumerable();

            // Date filter — by PaidAt date
            if (filterDate.HasValue)
                result = result.Where(x => x.PaidAt.HasValue && x.PaidAt.Value.Date == filterDate.Value.Date);

            if (string.IsNullOrWhiteSpace(searchText))
                return result;

            return result.Where(x => searchField switch
            {
                "name" => ($"{x.FirstName} {x.LastName}").Contains(searchText, StringComparison.OrdinalIgnoreCase),
                "id" => x.BillingId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                "status" => x.Status?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                "method" => x.PaymentMethod?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true,
                "duedate" =>
                    (x.DueDate.HasValue && x.DueDate.Value.ToString("MM/dd/yyyy").Contains(searchText)) ||
                    (x.DueDate.HasValue && x.DueDate.Value.ToString("MMM dd, yyyy").Contains(searchText, StringComparison.OrdinalIgnoreCase)),
                "paidat" =>
                    (x.PaidAt.HasValue && x.PaidAt.Value.ToString("MM/dd/yyyy").Contains(searchText)) ||
                    (x.PaidAt.HasValue && x.PaidAt.Value.ToString("MMM dd, yyyy").Contains(searchText, StringComparison.OrdinalIgnoreCase)),
                _ => // all
                    (x.BillingId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.FirstName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.LastName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.Status?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.PaymentMethod?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
                    (x.DueDate.HasValue && x.DueDate.Value.ToString("MM/dd/yyyy").Contains(searchText)) ||
                    (x.DueDate.HasValue && x.DueDate.Value.ToString("MMM dd, yyyy").Contains(searchText, StringComparison.OrdinalIgnoreCase)) ||
                    (x.PaidAt.HasValue && x.PaidAt.Value.ToString("MM/dd/yyyy").Contains(searchText)) ||
                    (x.PaidAt.HasValue && x.PaidAt.Value.ToString("MMM dd, yyyy").Contains(searchText, StringComparison.OrdinalIgnoreCase))
            });
        }
    }

    string GetStatusClass(string? status) => status switch
    {
        "Paid" => "badge-paid",
        "Overdue" => "badge-overdue",
        _ => "badge-pending"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadBillings();
        var users = await getUsers.ExecuteAsync();
        subscribers = users?.Where(x => x.Role == "Subscriber").ToList() ?? new();
        var upgradeReqs = await getAllUpgradeRequests.ExecuteAsync();
        var billingpeding = await getAllBill.ExecuteAsync();
        int billCount = billingpeding?.Count(x => x.Status == "Pending") ?? 0;

        int upgradeCount = upgradeReqs?.Count(x => x.Status == "Pending" ) ?? 0;
        pendingUpgradeCount = billCount + upgradeCount;
        var subs = await getSubscription.ExecuteAsync();
        allSubscriptions = subs?.ToList() ?? new();
    }

    async Task LoadBillings()
    {
        var result = await getAll.ExecuteAsync();
        billings = result?.ToList() ?? new();

        // Auto-mark overdue: Pending bills with no payment submitted and past due date
        var overdue = billings
            .Where(x =>
                x.Status == "Pending" &&
                x.DueDate.HasValue &&
                x.DueDate.Value.Date < DateTime.Today &&
                string.IsNullOrWhiteSpace(x.PaymentMethod))
            .ToList();

        foreach (var bill in overdue)
        {
            bill.Status = "Overdue";
            await update.ExecuteAsync(bill);
        }

        if (overdue.Any())
        {
            var refreshed = await getAll.ExecuteAsync();
            billings = refreshed?.ToList() ?? new();
        }
    }

    void OpenAddForm()
    {
        billing = new Billing { Status = "Pending" };
        selectedStatus = "Pending";
        isEditing = false;
        errorMessage = string.Empty;
        showForm = true;
    }

    void EditBilling(Billing item)
    {
        billing = new Billing
        {
            BillingId = item.BillingId,
            UserId = item.UserId ?? billings.FirstOrDefault(x => x.BillingId == item.BillingId)?.UserId,
            Amount = item.Amount,
            PaymentMethod = item.PaymentMethod,
            Status = item.Status,
            DueDate = item.DueDate,
            PaidAt = item.PaidAt,
            Description = item.Description,
            FirstName = item.FirstName,
            LastName = item.LastName
        };
        selectedStatus = item.Status ?? "Pending";
        isEditing = true;
        errorMessage = string.Empty;
        showForm = true;
    }

    async Task SaveBilling()
    {

        if (!isEditing && string.IsNullOrWhiteSpace(billing.UserId))
        {
            errorMessage = "Please select a subscriber.";
            return;
        }
        if (billing.Amount <= 0)
        {
            errorMessage = "Amount must be greater than 0.";
            return;
        }

        // Ensure UserId is set for edit mode
        if (isEditing && string.IsNullOrWhiteSpace(billing.UserId))
            billing.UserId = billings.FirstOrDefault(x => x.BillingId == billing.BillingId)?.UserId;

        // Apply status from dropdown
        billing.Status = selectedStatus;
        var previousStatus = billings.FirstOrDefault(x => x.BillingId == billing.BillingId)?.Status;

        if (selectedStatus == "Paid")
            billing.PaidAt ??= DateTime.Now;
        else
            billing.PaidAt = null;

        try
        {
            if (isEditing)
                await update.ExecuteAsync(billing);
            else
                await create.ExecuteAsync(billing);

            // Pag Paid — renew subscription EndDate +1 month
            bool isNewlyPaid = selectedStatus == "Paid" &&
                               previousStatus != "Paid" &&
                               !string.IsNullOrWhiteSpace(billing.UserId);

            if (isNewlyPaid)
            {
                var allSubs = await getSubscription.ExecuteAsync();
                var sub = allSubs?.FirstOrDefault(x => x.UserId == billing.UserId);

                if (sub != null)
                {
                    var baseDate = (sub.EndDate.HasValue && sub.EndDate.Value > DateTime.Today)
                        ? sub.EndDate.Value
                        : DateTime.Today;
                    var newEndDate = baseDate.AddMonths(1);

                    sub.EndDate = newEndDate;
                    sub.Status = "Active";
                    await updateSubscription.ExecuteAsync(sub);
                }
            }

            await LoadBillings();
            showForm = false;
            isEditing = false;
            billing = new Billing { Status = "Pending" };
            selectedStatus = "Pending";
            errorMessage = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }

    }
    void CancelForm()
    {
        billing = new Billing { Status = "Pending" };
        selectedStatus = "Pending";
        isEditing = false;
        showForm = false;
        errorMessage = string.Empty;
    }

    void DeleteBill(Billing item)
    {
        deleteTarget = item;
        showDeleteConfirm = true;
    }

    async Task ConfirmDelete()
    {
        if (deleteTarget == null) return;
        try
        {
            await delete.ExecuteAsync(deleteTarget);
            showDeleteConfirm = false;
            deleteTarget = null;
            await LoadBillings();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            showDeleteConfirm = false;
        }
    }
}
