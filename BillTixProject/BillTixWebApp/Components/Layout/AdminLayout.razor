@inherits LayoutComponentBase

<div class="admin-container">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-brand" style="font-size: 2.5rem; font-weight: 900; color: white;">BILLTIX</div>


        <nav class="sidebar-nav">
            <NavLink href="/admin-dashboard" Match="NavLinkMatch.All" class="nav-item">
                <span>⊞</span> Dashboard
            </NavLink>

            <NavLink href="/admin-subscriber" class="nav-item">
                <span>👤</span> Subscribers
            </NavLink>
            <NavLink href="/admin-internet-plans" class="nav-item">
                <span>🌐</span> Internet Plans
            </NavLink>
            <NavLink href="/admin-billing" class="nav-item">
                <span>🪪</span> Billing
            </NavLink>
            <NavLink href="/admin-technicians" class="nav-item">
                <span>🔧</span> Technicians
            </NavLink>
            <NavLink href="/admin-financial-report" class="nav-item">
                <span>📄</span> Financial Report

            </NavLink>
            <NavLink href="/admin-accounts" class="nav-item">
                <span>📄</span> Accounts

            </NavLink>
        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        @Body
    </div>

</div>
<style>
    html, body, *, *::before, *::after {
        font-family: 'Segoe UI', Arial, sans-serif !important;
        font-size: 16px !important;
        box-sizing: border-box;
    }

    .admin-container {
        display: flex;
        min-height: 100vh;
        background: #181825; /* DARK BACKGROUND for the whole admin area */
    }

    .sidebar {
        width: 260px;
        min-width: 260px;
        height: 100vh;
        background: linear-gradient(150deg, #1f1f38 77%, #302b63 100%);
        padding: 30px 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        border-radius: 0 22px 22px 0;
        box-shadow: 4px 0 24px rgba(0,0,0,0.23);
        position: sticky;
        top: 0;
        left: 0;
    }

    .sidebar-brand {
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
        margin-bottom: 36px;
        padding-left: 8px;
        letter-spacing: 1.6px;
        line-height: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-shadow: 0 4px 28px rgba(100,90,200,0.12);
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .nav-item,
    .sidebar a {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(33,37,70,0.91);
        color: #f1efff;
        padding: 14px 16px;
        border-radius: 12px;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 600;
        box-shadow: 0 1px 6px rgba(38,34,70,0.06);
        transition: background 0.18s, color 0.16s, font-weight 0.18s, transform 0.2s;
    }

        .nav-item:hover,
        .sidebar a:hover {
            background: linear-gradient(90deg,#282855 40%,#4e418b 100%);
            color: #fffaac;
            transform: translateX(7px);
            font-weight: 700;
        }

        .nav-item.active,
        .nav-item.nav-active,
        .sidebar a.active {
            background: linear-gradient(90deg,#ae84ff 52%,#7367f0 100%);
            color: #262248 !important;
            font-weight: bold !important;
            box-shadow: 0 1.5px 15px 0 rgba(164,125,250,0.11);
            letter-spacing: .7px;
        }

    .main-content {
        flex: 1;
        background: #20203a;
        overflow-y: auto;
        padding: 22px;
        border-radius: 22px 0 0 0;
    }

    /* Responsive sidebar for tablets/phones */
    @@media (max-width: 800px) {

        .admin-container {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            min-width: unset;
            height: auto;
            flex-direction: column;
            border-radius: 0;
            position: relative;
            padding: 16px 12px;
        }

        .sidebar-nav {
            flex-direction: column;
            gap: 8px;
        }

        .nav-item,
        .sidebar a {
            padding: 10px 12px;
            font-size: 0.9rem;
        }

        .main-content {
            padding: 12px;
            border-radius: 0;
            overflow-x: hidden;
        }
    }
</style>
