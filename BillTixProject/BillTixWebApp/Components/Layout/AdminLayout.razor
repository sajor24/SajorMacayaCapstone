@inherits LayoutComponentBase

<div class="admin-container">

    <!-- HAMBURGER BUTTON (mobile only) -->
    <button class="hamburger" @onclick="ToggleSidebar">☰</button>

    <!-- OVERLAY (mobile) -->
    @if (sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
    }

    <!-- SIDEBAR -->
    <div class="sidebar @(sidebarOpen ? "sidebar-open" : "")">
        <div class="sidebar-brand">BILLTIX</div>

        <nav class="sidebar-nav">
            <NavLink href="/admin-dashboard" Match="NavLinkMatch.All" class="nav-item" ActiveClass="nav-active" @onclick="CloseSidebar">
                <span>⊞</span> Dashboard
            </NavLink>
            <NavLink href="/admin-subscriber" class="nav-item" ActiveClass="nav-active" @onclick="CloseSidebar">
                <span>👤</span> Subscribers
            </NavLink>
            <NavLink href="/admin-internet-plans" class="nav-item" ActiveClass="nav-active" @onclick="CloseSidebar">
                <span>🌐</span> Internet Plans
            </NavLink>
            <NavLink href="/admin-billing" class="nav-item" ActiveClass="nav-active" @onclick="CloseSidebar">
                <span>🪪</span> Billing
            </NavLink>
            <NavLink href="/admin-technicians" class="nav-item" ActiveClass="nav-active" @onclick="CloseSidebar">
                <span>🔧</span> Technicians
            </NavLink>
            <NavLink href="/admin-financial-report" class="nav-item" ActiveClass="nav-active" @onclick="CloseSidebar">
                <span>📄</span> Financial Report
            </NavLink>
            <NavLink href="/admin-accounts" class="nav-item" ActiveClass="nav-active" @onclick="CloseSidebar">
                <span>👥</span> Accounts
            </NavLink>
            <NavLink href="/admin-upgrade-requests" class="nav-item" ActiveClass="nav-active" @onclick="CloseSidebar">
                <span>⬆️</span> Upgrade Requests
            </NavLink>
        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        @Body
    </div>

</div>

<style>
    html, body, *, *::before, *::after {
        font-family: 'Segoe UI', Arial, sans-serif !important;
        box-sizing: border-box;
    }

    .admin-container {
        display: flex;
        min-height: 100vh;
        background: #181825;
    }

    /* HAMBURGER - hidden on desktop */
    .hamburger {
        display: none;
        position: fixed;
        top: 12px;
        left: 12px;
        z-index: 2000;
        background: #7367f0;
        color: white;
        border: none;
        border-radius: 8px;
        width: 42px;
        height: 42px;
        font-size: 1.3rem;
        cursor: pointer;
        box-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }

    /* OVERLAY */
    .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1500;
    }

    .sidebar {
        width: 260px;
        min-width: 260px;
        height: 100vh;
        background: linear-gradient(150deg, #1f1f38 77%, #302b63 100%);
        padding: 30px 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        border-radius: 0 22px 22px 0;
        box-shadow: 4px 0 24px rgba(0,0,0,0.23);
        position: sticky;
        top: 0;
        left: 0;
        z-index: 1600;
        transition: transform 0.3s ease;
    }

    .sidebar-brand {
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
        margin-bottom: 36px;
        padding-left: 8px;
        letter-spacing: 1.6px;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .nav-item,
    .sidebar a {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(33,37,70,0.91);
        color: #f1efff;
        padding: 14px 16px;
        border-radius: 12px;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 600;
        transition: background 0.18s, color 0.16s, transform 0.2s;
    }

    .nav-item:hover, .sidebar a:hover {
        background: linear-gradient(90deg,#282855 40%,#4e418b 100%);
        color: #fffaac;
        transform: translateX(7px);
    }

    .nav-item.active, .nav-item.nav-active, .sidebar a.active {
        background: linear-gradient(90deg,#ae84ff 52%,#7367f0 100%);
        color: #262248 !important;
        font-weight: bold !important;
    }

    .main-content {
        flex: 1;
        background: #20203a;
        overflow-y: auto;
        padding: 22px;
        border-radius: 22px 0 0 0;
        min-width: 0;
    }

    /* MOBILE */
    @@media (max-width: 800px) {
        .hamburger {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sidebar-overlay {
            display: block;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            transform: translateX(-100%);
            border-radius: 0 22px 22px 0;
        }

        .sidebar.sidebar-open {
            transform: translateX(0);
        }

        .main-content {
            width: 100%;
            padding: 60px 12px 12px 12px;
            border-radius: 0;
        }
    }
</style>

@code {
    private bool sidebarOpen = false;

    void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    void CloseSidebar() => sidebarOpen = false;
}
