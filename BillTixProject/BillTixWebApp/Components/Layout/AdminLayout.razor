@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<!-- ── Mobile Top Bar (hidden on desktop via CSS) ── -->
<div class="mobile-topbar">
    <button class="mobile-menu-btn" @onclick="ToggleMobileDrawer">
        <i class="bi @(mobileOpen ? "bi-x-lg" : "bi-list")"></i>
    </button>
    <span class="mobile-brand-text">BILLTIX</span>
</div>

<!-- ── Mobile overlay ── -->
@if (mobileOpen)
{
    <div class="mobile-overlay" @onclick="CloseMobileDrawer"></div>
}

<!-- ── Main wrapper ── -->
<div class="admin-container @(collapsed ? "is-collapsed" : "") @(mobileOpen ? "drawer-open" : "")">

    <!-- SIDEBAR -->
    <nav class="sidebar">

        <div class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
            @if (!collapsed){ <span class="brand-text">BILLTIX</span> }
        </div>

        <div class="sidebar-nav">

            @if (!collapsed){ <div class="nav-group-label">General</div> }

            <NavLink href="/admin-dashboard" Match="NavLinkMatch.All" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Dashboard" : null)">
                <i class="bi bi-grid-fill nav-icon"></i>
                @if (!collapsed){ <span>Dashboard</span> }
            </NavLink>

            <NavLink href="/admin-subscriber" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Subscribers" : null)">
                <i class="bi bi-people-fill nav-icon"></i>
                @if (!collapsed){ <span>Subscribers</span> }
            </NavLink>

            <NavLink href="/admin-internet-plans" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Internet Plans" : null)">
                <i class="bi bi-wifi nav-icon"></i>
                @if (!collapsed){ <span>Internet Plans</span> }
            </NavLink>

            <NavLink href="/admin-billing" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Billing" : null)">
                <i class="bi bi-receipt nav-icon"></i>
                @if (!collapsed){ <span>Billing</span> }
            </NavLink>

            <NavLink href="/admin-upgrade-requests" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Upgrade Requests" : null)">
                <i class="bi bi-credit-card-fill nav-icon"></i>
                @if (!collapsed){ <span>Payment Request</span> }
            </NavLink>

            <NavLink href="/admin-accounts" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Accounts" : null)">
                <i class="bi bi-person-badge-fill nav-icon"></i>
                @if (!collapsed){ <span>Accounts</span> }
            </NavLink>

            @if (!collapsed){ <div class="nav-group-label mt-2">Tools</div> }
            else { <div class="nav-divider"></div> }
            
            <NavLink href="/admin-notifications" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Send Notifications" : null)">
                <i class="bi bi-bell-fill nav-icon"></i>
                @if (!collapsed){ <span>Send Notifications</span> }
            </NavLink>

           
            <NavLink href="/admin-service-requests" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Service Requests" : null)">
                <i class="bi bi-tools nav-icon"></i>
                @if (!collapsed){ <span>Service Requests</span> }
            </NavLink>
            <NavLink href="/admin-technicians" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Technicians" : null)">
                <i class="bi bi-people nav-icon"></i>
                @if (!collapsed)
                {
                    <span>Technicians</span>
                }
            </NavLink>
            <NavLink href="/admin-financial-report" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Financial Report" : null)">
                <i class="bi bi-bar-chart-fill nav-icon"></i>
                @if (!collapsed){ <span>Financial Report</span> }
            </NavLink>

         

        </div>

        <div class="sidebar-footer">
            <button class="nav-item logout-item" @onclick="ConfirmLogout" title="@(collapsed ? "Logout" : null)">
                <i class="bi bi-box-arrow-left nav-icon"></i>
                @if (!collapsed){ <span>Logout</span> }
            </button>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        @Body
    </div>

</div>

<!-- ── Desktop floating toggle (hidden on mobile) ── -->
<button class="desktop-toggle @(collapsed ? "is-collapsed" : "")" @onclick="ToggleCollapse">
    <i class="bi @(collapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
</button>

<!-- ── Logout Modal ── -->
@if (showLogoutConfirm)
{
    <div class="logout-overlay" @onclick="CancelLogout"></div>
    <div class="logout-modal shadow-lg">
        <div class="text-center py-2">
            <i class="bi bi-box-arrow-left" style="font-size: 1.5rem;"></i>
            <h5 class="fw-bold mt-2">Logout?</h5>
            <p class="text-muted mt-1">Are you sure you want to logout?</p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="CancelLogout">Cancel</button>
            <button class="btn btn-danger px-4" @onclick="DoLogout">Yes, Logout</button>
        </div>
    </div>
}

@code {
    private bool collapsed = false;
    private bool mobileOpen = false;
    private bool showLogoutConfirm = false;

    void ToggleCollapse() => collapsed = !collapsed;
    void ToggleMobileDrawer() => mobileOpen = !mobileOpen;
    void CloseMobileDrawer() => mobileOpen = false;
    void ConfirmLogout() => showLogoutConfirm = true;
    void CancelLogout() => showLogoutConfirm = false;
    void DoLogout() => NavigationManager.NavigateTo("/account/logout", forceLoad: true);
}
