@inherits LayoutComponentBase

<div class="sub-container">

    <!-- SIDEBAR -->
    <div class="sub-sidebar">
        <div class="sub-brand">BILLTIX</div>

        <nav class="sub-nav">
            <NavLink href="/sub-dashboard" Match="NavLinkMatch.All" class="sub-nav-item" ActiveClass="sub-nav-active">
                <i class="bi bi-grid-fill"></i> Dashboard
            </NavLink>
            <NavLink href="/sub-myaccount" class="sub-nav-item" ActiveClass="sub-nav-active">
                <i class="bi bi-person-fill"></i> My Account
            </NavLink>
            <NavLink href="/sub-internetplans" class="sub-nav-item" ActiveClass="sub-nav-active">
                <i class="bi bi-globe"></i> Internet Plans
            </NavLink>
            <NavLink href="/sub-billing" class="sub-nav-item" ActiveClass="sub-nav-active">
                <i class="bi bi-credit-card-fill"></i> Billing
            </NavLink>
            <NavLink href="/sub-support" class="sub-nav-item" ActiveClass="sub-nav-active">
                <i class="bi bi-headset"></i> Support
            </NavLink>
            <NavLink href="/sub-notification" class="sub-nav-item" ActiveClass="sub-nav-active">
                <i class="bi bi-bell-fill"></i> Notification
            </NavLink>
        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <div class="sub-main">
        @Body
    </div>

</div>

<style>
    .sub-container {
        display: flex;
        min-height: 100vh;
        background: #181825;
    }

    .sub-sidebar {
        width: 220px;
        min-width: 220px;
        height: 100vh;
        background: linear-gradient(150deg, #0a0a5c 77%, #1a1a8c 100%);
        padding: 30px 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        position: sticky;
        top: 0;
        left: 0;
    }

    .sub-brand {
        font-size: 1.6rem;
        font-weight: 900;
        color: white;
        letter-spacing: 2px;
        margin-bottom: 32px;
        padding-left: 8px;
    }

    .sub-nav {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .sub-nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        color: rgba(255,255,255,0.75);
        padding: 12px 16px;
        border-radius: 10px;
        text-decoration: none;
        font-size: .92rem;
        font-weight: 500;
        transition: .2s;
        background: rgba(255,255,255,0.05);
    }

    .sub-nav-item:hover {
        background: rgba(255,255,255,0.12);
        color: white;
    }

    .sub-nav-item.sub-nav-active {
        background: rgba(255,255,255,0.2);
        color: white;
        font-weight: 700;
    }

    .sub-main {
        flex: 1;
        overflow-y: auto;
        background: #f5f6fa;
    }

   @@media (max-width: 800px) {
        .sub-container {
            flex-direction: column;
        }

        .sub-sidebar {
            width: 100%;
            min-width: unset;
            height: auto;
            position: relative;
            padding: 16px 12px;
        }

        .sub-nav {
            flex-direction: column;
            gap: 6px;
        }

        .sub-nav-item {
            padding: 10px 12px;
            font-size: 0.88rem;
        }

        .sub-main {
            overflow-x: hidden;
        }
    }</style>
