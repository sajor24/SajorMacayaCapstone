@inherits LayoutComponentBase

<div class="sub-container">

    <!-- HAMBURGER BUTTON (mobile only) -->
    <button class="sub-hamburger" @onclick="ToggleSidebar">☰</button>

    <!-- OVERLAY -->
    @if (sidebarOpen)
    {
        <div class="sub-overlay" @onclick="ToggleSidebar"></div>
    }

    <!-- SIDEBAR -->
    <div class="sub-sidebar @(sidebarOpen ? "sub-sidebar-open" : "")">
        <div class="sub-brand">BILLTIX</div>

        <nav class="sub-nav">
            <NavLink href="/sub-dashboard" Match="NavLinkMatch.All" class="sub-nav-item" ActiveClass="sub-nav-active" @onclick="CloseSidebar">
                <i class="bi bi-grid-fill"></i> Dashboard
            </NavLink>
            <NavLink href="/sub-myaccount" class="sub-nav-item" ActiveClass="sub-nav-active" @onclick="CloseSidebar">
                <i class="bi bi-person-fill"></i> My Account
            </NavLink>
            <NavLink href="/sub-internetplans" class="sub-nav-item" ActiveClass="sub-nav-active" @onclick="CloseSidebar">
                <i class="bi bi-globe"></i> Internet Plans
            </NavLink>
            <NavLink href="/sub-billing" class="sub-nav-item" ActiveClass="sub-nav-active" @onclick="CloseSidebar">
                <i class="bi bi-credit-card-fill"></i> Billing
            </NavLink>
            <NavLink href="/sub-support" class="sub-nav-item" ActiveClass="sub-nav-active" @onclick="CloseSidebar">
                <i class="bi bi-headset"></i> Support
            </NavLink>
            <NavLink href="/sub-notification" class="sub-nav-item" ActiveClass="sub-nav-active" @onclick="CloseSidebar">
                <i class="bi bi-bell-fill"></i> Notification
            </NavLink>
        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <div class="sub-main">
        @Body
    </div>

</div>

<style>
    .sub-container {
        display: flex;
        min-height: 100vh;
        background: #f5f6fa;
    }

    .sub-hamburger {
        display: none;
        position: fixed;
        top: 12px;
        left: 12px;
        z-index: 2000;
        background: #0a0a5c;
        color: white;
        border: none;
        border-radius: 8px;
        width: 42px;
        height: 42px;
        font-size: 1.3rem;
        cursor: pointer;
        box-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }

    .sub-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1500;
    }

    .sub-sidebar {
        width: 220px;
        min-width: 220px;
        height: 100vh;
        background: linear-gradient(150deg, #0a0a5c 77%, #1a1a8c 100%);
        padding: 30px 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        position: sticky;
        top: 0;
        left: 0;
        z-index: 1600;
        transition: transform 0.3s ease;
    }

    .sub-brand {
        font-size: 1.6rem;
        font-weight: 900;
        color: white;
        letter-spacing: 2px;
        margin-bottom: 32px;
        padding-left: 8px;
    }

    .sub-nav {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .sub-nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        color: rgba(255,255,255,0.75);
        padding: 12px 16px;
        border-radius: 10px;
        text-decoration: none;
        font-size: .92rem;
        font-weight: 500;
        transition: .2s;
        background: rgba(255,255,255,0.05);
    }

    .sub-nav-item:hover {
        background: rgba(255,255,255,0.12);
        color: white;
    }

    .sub-nav-item.sub-nav-active {
        background: rgba(255,255,255,0.2);
        color: white;
        font-weight: 700;
    }

    .sub-main {
        flex: 1;
        overflow-y: auto;
        background: #f5f6fa;
        min-width: 0;
    }

    /* MOBILE */
    @@media (max-width: 800px) {
        .sub-hamburger {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sub-overlay {
            display: block;
        }

        .sub-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            transform: translateX(-100%);
        }

        .sub-sidebar.sub-sidebar-open {
            transform: translateX(0);
        }

        .sub-main {
            width: 100%;
            padding-top: 60px;
        }
    }
</style>

@code {
    private bool sidebarOpen = false;

    void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    void CloseSidebar() => sidebarOpen = false;
}
