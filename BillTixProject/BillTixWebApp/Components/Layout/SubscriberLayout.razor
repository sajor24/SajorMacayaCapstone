@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Authorization
@using Domain.ICommands
@using Domain.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject IGetAll_User getAllUsers
@inject IGetByUser_Notification getNotifications

<!-- ── Mobile Top Bar ── -->
<div class="mobile-topbar mobile-topbar-sub">
    <button class="mobile-menu-btn" @onclick="ToggleMobileDrawer">
        <i class="bi @(mobileOpen ? "bi-x-lg" : "bi-list")"></i>
    </button>
    <span class="mobile-brand-text">Palma IMTECH</span>
</div>

@if (mobileOpen)
{
    <div class="mobile-overlay" @onclick="CloseMobileDrawer"></div>
}

<div class="sub-container @(collapsed ? "is-collapsed" : "") @(mobileOpen ? "drawer-open" : "")">

    <!-- SIDEBAR -->
    <nav class="sidebar">

        <div class="sidebar-brand">
            <div class="brand-icon brand-icon-sub">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5 12.55a11 11 0 0 1 14.08 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    <path d="M1.42 9a16 16 0 0 1 21.16 0" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round"/>
                    <path d="M8.53 16.11a6 6 0 0 1 6.95 0" stroke="white" stroke-width="2" stroke-linecap="round"/>
                    <circle cx="12" cy="20" r="1.5" fill="white"/>
                </svg>
            </div>
            @if (!collapsed)
            {
                <div style="display:flex;flex-direction:column;line-height:1.15;overflow:hidden;">
                    <span style="font-size:.95rem;font-weight:800;color:#111827;letter-spacing:.5px;white-space:nowrap;">Palma IMTECH</span>
                    <span style="font-size:.65rem;font-weight:700;color:#d97706;letter-spacing:2px;text-transform:uppercase;white-space:nowrap;">FBR INTERNET</span>
                </div>
            }
        </div>

        <div class="sidebar-nav">

            @if (!collapsed){ <div class="nav-group-label">Menu</div> }

            <NavLink href="/sub-dashboard" Match="NavLinkMatch.All" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Dashboard" : null)">
                <i class="bi bi-grid-fill nav-icon"></i>
                @if (!collapsed){ <span>Dashboard</span> }
            </NavLink>

            <NavLink href="/sub-myaccount" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "My Account" : null)">
                <i class="bi bi-person-circle nav-icon"></i>
                @if (!collapsed){ <span>My Account</span> }
            </NavLink>

            <NavLink href="/sub-internetplans" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Internet Plans" : null)">
                <i class="bi bi-wifi nav-icon"></i>
                @if (!collapsed){ <span>Internet Plans</span> }
            </NavLink>

            <NavLink href="/sub-billing" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Billing" : null)">
                <i class="bi bi-receipt nav-icon"></i>
                @if (!collapsed){ <span>Billing</span> }
            </NavLink>

            <NavLink href="/sub-support" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Support" : null)">
                <i class="bi bi-headset nav-icon"></i>
                @if (!collapsed){ <span>Support</span> }
            </NavLink>

            <NavLink href="/sub-notification" class="nav-item" ActiveClass="nav-active" @onclick="CloseMobileDrawer" title="@(collapsed ? "Notifications" : null)">
                <i class="bi bi-bell-fill nav-icon"></i>
                @if (!collapsed)
                {
                    <span>Notifications</span>
                    @if (unreadCount > 0)
                    {
                        <span class="notif-badge">@unreadCount</span>
                    }
                }
                else if (unreadCount > 0)
                {
                    <span class="notif-dot"></span>
                }
            </NavLink>

        </div>

        <div class="sidebar-footer">
            <button class="nav-item logout-item" @onclick="ConfirmLogout" title="@(collapsed ? "Logout" : null)">
                <i class="bi bi-box-arrow-left nav-icon"></i>
                @if (!collapsed){ <span>Logout</span> }
            </button>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        @Body
    </div>

</div>

<!-- Desktop floating toggle -->
<button class="desktop-toggle sub-toggle @(collapsed ? "is-collapsed" : "")" @onclick="ToggleCollapse">
    <i class="bi @(collapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
</button>

<!-- Logout Modal -->
@if (showLogoutConfirm)
{
    <div class="logout-overlay" @onclick="CancelLogout"></div>
    <div class="logout-modal shadow-lg">
        <div class="text-center py-2">
            <i class="bi bi-box-arrow-left" style="font-size: 1.5rem;"></i>
            <h5 class="fw-bold mt-2">Logout?</h5>
            <p class="text-muted mt-1">Are you sure you want to logout?</p>
        </div>
        <div class="d-flex gap-2 mt-3 justify-content-center">
            <button class="btn btn-secondary px-4" @onclick="CancelLogout">Cancel</button>
            <button class="btn btn-danger px-4" @onclick="DoLogout">Yes, Logout</button>
        </div>
    </div>
}

<style>
    .sub-container {
        display: flex;
        min-height: 100vh;
        background: #f5f6fa;
    }

    .sub-container .sidebar {
        width: 240px;
        min-width: 240px;
        height: 100vh;
        background: #ffffff;
        border-right: 1px solid #e5e7eb;
        display: flex;
        flex-direction: column;
        position: sticky;
        top: 0;
        z-index: 100;
        overflow: hidden;
        transition: width 0.25s ease, min-width 0.25s ease;
        flex-shrink: 0;
    }

    .sub-container.is-collapsed .sidebar {
        width: 68px;
        min-width: 68px;
    }

    .sub-container .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 20px 14px 16px;
        border-bottom: 1px solid #f3f4f6;
        min-height: 68px;
        overflow: hidden;
    }

    .brand-icon-sub {
        width: 38px;
        height: 38px;
        background: #059669;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        color: white;
        flex-shrink: 0;
    }

    .sub-container .brand-text {
        font-size: 1.1rem;
        font-weight: 800;
        color: #111827;
        letter-spacing: 1.5px;
        white-space: nowrap;
        flex: 1;
    }

    .sub-container .sidebar-nav {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 12px 10px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .sub-container .sidebar-nav::-webkit-scrollbar { width: 3px; }
    .sub-container .sidebar-nav::-webkit-scrollbar-thumb { background: #d1fae5; border-radius: 4px; }

    .sub-container .nav-group-label {
        font-size: .7rem;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: .08em;
        padding: 8px 8px 4px;
        white-space: nowrap;
    }

    .sub-container .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-radius: 50px;
        color: #6b7280;
        text-decoration: none;
        font-size: .92rem;
        font-weight: 500;
        transition: background .15s, color .15s;
        white-space: nowrap;
        cursor: pointer;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
    }

    .sub-container .nav-item:hover {
        background: #f0fdf4;
        color: #059669;
        text-decoration: none;
    }

    .sub-container .nav-item.nav-active {
        background: #059669;
        color: #ffffff !important;
        font-weight: 600;
    }

    .sub-container .nav-icon {
        font-size: 1.05rem;
        min-width: 20px;
        text-align: center;
        flex-shrink: 0;
    }

    .notif-badge {
        margin-left: auto;
        background: #ef4444;
        color: white;
        font-size: .65rem;
        font-weight: 700;
        padding: 1px 6px;
        border-radius: 10px;
        min-width: 18px;
        height: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

    .notif-dot {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 8px;
        height: 8px;
        background: #ef4444;
        border-radius: 50%;
        border: 2px solid #ffffff;
    }

    .sub-container.is-collapsed .nav-item {
        justify-content: center;
        gap: 0;
        padding: 10px 0;
        position: relative;
        border-radius: 50px;
    }

    .sub-container.is-collapsed .nav-item[title]:hover::after {
        content: attr(title);
        position: absolute;
        left: calc(100% + 10px);
        top: 50%;
        transform: translateY(-50%);
        background: #111827;
        color: #ffffff;
        font-size: .8rem;
        font-weight: 500;
        white-space: nowrap;
        padding: 5px 10px;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 4px 12px rgba(0,0,0,.15);
        z-index: 9999;
        pointer-events: none;
    }

    .sub-container.is-collapsed .nav-group-label { display: none; }

    .sub-container .sidebar-footer {
        padding: 10px;
        border-top: 1px solid #f3f4f6;
    }

    .sub-container .logout-item { color: #ef4444 !important; }
    .sub-container .logout-item:hover {
        background: #fef2f2 !important;
        color: #dc2626 !important;
    }

    .sub-container .main-content {
        flex: 1;
        background: #f5f6fa;
        overflow-y: auto;
        min-width: 0;
    }

    .sub-toggle {
        position: fixed;
        top: 20px;
        left: calc(240px - 14px);
        z-index: 200;
        width: 28px;
        height: 28px;
        background: #ffffff;
        border: 2px solid #e5e7eb;
        color: #6b7280;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: .8rem;
        transition: left 0.25s ease, background .2s;
        box-shadow: 0 2px 8px rgba(0,0,0,.1);
    }

    .sub-toggle.is-collapsed { left: calc(68px - 14px); }
    .sub-toggle:hover { background: #f0fdf4; border-color: #059669; color: #059669; }

    .mobile-topbar-sub { display: none; }

    .logout-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 2000; }
    .logout-modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); background: white; border-radius: 16px; padding: 2rem; width: 360px; max-width: 95vw; z-index: 2001; }

    @@media (max-width: 768px) {
        .sub-toggle { display: none !important; }

        .mobile-topbar-sub {
            display: flex;
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 56px;
            z-index: 1500;
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;
            align-items: center;
            gap: 12px;
            padding: 0 16px;
        }

        .mobile-menu-btn {
            background: #f3f4f6;
            border: none;
            color: #374151;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
        }

        .mobile-brand-text {
            font-size: 1rem;
            font-weight: 800;
            color: #111827;
            letter-spacing: 1.5px;
        }

        .mobile-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.55);
            z-index: 1599;
        }

        .sub-container .sidebar {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            height: 100vh !important;
            width: 240px !important;
            min-width: 240px !important;
            z-index: 1600 !important;
            transform: translateX(-100%) !important;
            transition: transform 0.25s ease !important;
        }

        .sub-container.drawer-open .sidebar {
            transform: translateX(0) !important;
        }

        .sub-container .main-content { padding-top: 56px; }

        .sub-container.is-collapsed .nav-item {
            justify-content: flex-start !important;
            gap: 12px !important;
            padding: 10px 14px !important;
            border-radius: 50px !important;
        }

        .sub-container.is-collapsed .nav-item span { display: inline !important; }
        .sub-container.is-collapsed .nav-group-label { display: block !important; }
        .sub-container.is-collapsed .brand-text { display: block !important; }
        .sub-container.is-collapsed .sidebar { width: 240px !important; min-width: 240px !important; }
    }
</style>

@code {
    private bool collapsed = false;
    private bool mobileOpen = false;
    private bool showLogoutConfirm = false;
    private int unreadCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var username = user.Identity.Name ?? "";
            var users = await getAllUsers.ExecuteAsync();
            var currentUser = users?.FirstOrDefault(x => x.Username == username);

            if (currentUser != null)
            {
                var notifs = await getNotifications.ExecuteAsync(currentUser.UserId ?? "");
                unreadCount = notifs?.Count(x => !x.IsRead) ?? 0;
                StateHasChanged();
            }
        }
    }

    void ToggleCollapse() => collapsed = !collapsed;
    void ToggleMobileDrawer() => mobileOpen = !mobileOpen;
    void CloseMobileDrawer() => mobileOpen = false;
    void ConfirmLogout() => showLogoutConfirm = true;
    void CancelLogout() => showLogoutConfirm = false;
    void DoLogout() => NavigationManager.NavigateTo("/account/logout", forceLoad: true);
}
